          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{
      RowBox[{"Last", "[", 
       RowBox[{"DSolve", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}]}], ",", 
         RowBox[{"a", "[", "t", "]"}], ",", "t"}], "]"}], "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"C", "[", "1", "]"}], "->", 
         SuperscriptBox["\[CapitalKappa]", "2"]}], ",", 
        RowBox[{
         RowBox[{"C", "[", "2", "]"}], "->", "\[Alpha]"}]}], "}"}]}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"a", "[", "t", "]"}], "/.", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{"Simplify", "[", 
        RowBox[{"PowerExpand", "[", "sol", "]"}], "]"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We see that \!\(\*SubscriptBox[\(R\), \(44\)]\) is \
redundant, and the solution to \!\(\*SubscriptBox[\(R\), \(00\)]\) is:\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \[PlusMinus]\>\"", ",", 
      RowBox[{"a", "[", "t", "]"}], 
      ",", "\"\<  where \[Alpha] and \[CapitalKappa] are constants of \
integration.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs12", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs12", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], "-", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
