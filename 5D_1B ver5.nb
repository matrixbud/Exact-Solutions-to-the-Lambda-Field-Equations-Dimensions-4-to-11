  RowBox[{"\<\"     \\!\\(\\*SubscriptBox[\\(R\\), \
\\(11\\)]\\)-\\!\\(\\*SubscriptBox[\\(R\\), \\(44\\)]\\):  \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["6", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["r", "2"]}]]}], "-", 
    FractionBox[
     RowBox[{"6", " ", 
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "r", " ", "\[GothicCapitalC]"}]], "-", 
    FractionBox[
     RowBox[{"3", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
         MultilineFunction->None], ")"}], "2"]}], 
     RowBox[{"2", " ", 
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["\[GothicCapitalC]", "2"]}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", "0"}],
  SequenceForm[
  "     \!\(\*SubscriptBox[\(R\), \(11\)]\)-\!\(\*SubscriptBox[\(R\), \(44\)]\
\):  ", (-6) $CellContext`a^(-2) $CellContext`r^(-2) - 
   6 $CellContext`a^(-2) $CellContext`r^(-1) \
$CellContext`\[GothicCapitalC]^(-1) 
   Derivative[1][$CellContext`\[GothicCapitalC]] + 
   Rational[-3, 2] $CellContext`a^(-2) $CellContext`\[GothicCapitalC]^(-2) 
    Derivative[1][$CellContext`\[GothicCapitalC]]^2, " = ", 0],
  Editable->False]], "Print",
