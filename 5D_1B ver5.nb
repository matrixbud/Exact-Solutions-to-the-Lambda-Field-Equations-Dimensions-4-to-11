Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \[CapitalBeta](r) = \"\>", "\[InvisibleSpace]", 
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", 
         RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], "+", 
        RowBox[{"r", " ", 
         RowBox[{
          SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
           MultilineFunction->None], "[", "r", "]"}]}]}], ")"}], "2"], 
     RowBox[{"2", " ", 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "2"}], "+", 
        RowBox[{
         SuperscriptBox["r", "2"], " ", "\[CapitalLambda]", " ", 
         RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}]}], ")"}]}]]}]}],
  SequenceForm[
  "     \[CapitalBeta](r) = ", 
   Rational[-1, 
     2] $CellContext`\[GothicCapitalC][$CellContext`r]^(-1) (-2 + \
$CellContext`r^2 $CellContext`\[CapitalLambda] \
$CellContext`\[GothicCapitalC][$CellContext`r])^(-1) (
     2 $CellContext`\[GothicCapitalC][$CellContext`r] + $CellContext`r 
      Derivative[1][$CellContext`\[GothicCapitalC]][$CellContext`r])^2],
