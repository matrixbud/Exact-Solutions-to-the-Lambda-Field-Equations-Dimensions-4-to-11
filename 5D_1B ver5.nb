Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"   The Case b A(t,r) = \
\\!\\(\\*FractionBox[\\(\\*SuperscriptBox[\\(c\\), \\(2\\)]\\\\ \
\\*SuperscriptBox[\\(\\(\\*OverscriptBox[\\(a\\), \\(.\\)]\\)[t]\\), \\(2\\)]\
\\), \\(k + \[CapitalLambda]\\\\ \\*SuperscriptBox[\\(a[t]\\), \
\\(2\\)]\\)]\\) = \"\>", "\[InvisibleSpace]", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "4"], " ", 
      SuperscriptBox["\[CapitalKappa]", "4"], " ", 
      SuperscriptBox[
       RowBox[{"Sech", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"t", "+", "\[Alpha]"}], ")"}], " ", "\[CapitalKappa]"}], 
        "]"}], "2"], " ", 
      SuperscriptBox[
       RowBox[{"Tanh", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"t", "+", "\[Alpha]"}], ")"}], " ", "\[CapitalKappa]"}], 
        "]"}], "2"]}], 
     RowBox[{"\[CapitalLambda]", " ", 
      RowBox[{"(", 
       RowBox[{"k", "-", 
        RowBox[{
         SuperscriptBox["c", "2"], " ", 
         SuperscriptBox["\[CapitalKappa]", "2"], " ", 
         SuperscriptBox[
          RowBox[{"Sech", "[", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"t", "+", "\[Alpha]"}], ")"}], " ", "\[CapitalKappa]"}], 
           "]"}], "2"]}]}], ")"}]}]]}], "\[InvisibleSpace]", "\<\".\"\>"}],
  SequenceForm[
  "   The Case b A(t,r) = \!\(\*FractionBox[\(\*SuperscriptBox[\(c\), \
\(2\)]\\ \*SuperscriptBox[\(\(\*OverscriptBox[\(a\), \(.\)]\)[t]\), \(2\)]\), \
\(k + \[CapitalLambda]\\ \*SuperscriptBox[\(a[t]\), \(2\)]\)]\) = ", \
-$CellContext`c^4 $CellContext`\[CapitalKappa]^4 \
$CellContext`\[CapitalLambda]^(-1) 
   Sech[($CellContext`t + $CellContext`\[Alpha]) \
$CellContext`\[CapitalKappa]]^2 ($CellContext`k - $CellContext`c^2 \
$CellContext`\[CapitalKappa]^2 
     Sech[($CellContext`t + $CellContext`\[Alpha]) $CellContext`\
\[CapitalKappa]]^2)^(-1) 
   Tanh[($CellContext`t + $CellContext`\[Alpha]) \
$CellContext`\[CapitalKappa]]^2, "."],
  Editable->False]], "Print",
