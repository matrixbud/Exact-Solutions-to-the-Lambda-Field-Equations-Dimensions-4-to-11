Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"4", "4"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], 
     RowBox[{"a", " ", "\[ScriptCapitalA]"}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "."], " ", 
      OverscriptBox["\[ScriptCapitalA]", "."]}], 
     RowBox[{"2", " ", "a", " ", 
      SuperscriptBox["\[ScriptCapitalA]", "2"]}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   "\[CapitalLambda]"}],
  SequenceForm[
   Subscript["R", 
    Row[{4, 4}]], 
   ":  ", $CellContext`a^(-1) $CellContext`c^2 \
$CellContext`\[ScriptCapitalA]^(-1) OverDot[$CellContext`a, 2] + 
   Rational[-1, 
      2] $CellContext`a^(-1) $CellContext`c^2 \
$CellContext`\[ScriptCapitalA]^(-2) OverDot[$CellContext`a, 1] 
    OverDot[$CellContext`\[ScriptCapitalA], 1], 
   " = ", $CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
