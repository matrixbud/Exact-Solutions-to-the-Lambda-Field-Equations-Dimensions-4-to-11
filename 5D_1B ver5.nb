    "Print", "[", "\"\<We have generated the exact solution and it is the \
same as the exact solution, above:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"Print", "[", "\"\<     a(t) is a free parameter,\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
