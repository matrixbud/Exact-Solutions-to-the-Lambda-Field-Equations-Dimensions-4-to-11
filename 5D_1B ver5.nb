Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"Like Case b_I\[Alpha], this exact solution is simply the \
subcase of Case b obtained by plugging a(t) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"t", " ", 
       SqrtBox["\[CapitalLambda]"]}]], " ", "\[Alpha]"}], "+", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "t"}], " ", 
       SqrtBox["\[CapitalLambda]"]}]], " ", "\[Beta]"}]}], 
   "\[InvisibleSpace]", "\<\" into the free a(t) parameter of Case b and then \
setting the free constant k of Case b to -4\[Alpha] \[Beta] \[CapitalLambda]. \
We did not obtain a different solution.\"\>"}],
  SequenceForm[
  "Like Case b_I\[Alpha], this exact solution is simply the subcase of Case b \
obtained by plugging a(t) = ", 
   E^($CellContext`t $CellContext`\[CapitalLambda]^
       Rational[1, 2]) $CellContext`\[Alpha] + 
   E^(-$CellContext`t $CellContext`\[CapitalLambda]^
       Rational[1, 2]) $CellContext`\[Beta], 
   " into the free a(t) parameter of Case b and then setting the free \
constant k of Case b to -4\[Alpha] \[Beta] \[CapitalLambda]. We did not \
obtain a different solution."],
  Editable->False]], "Print",
