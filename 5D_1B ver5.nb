                  SuperscriptBox[
                   RowBox[{
                    OverscriptBox["a", "."], "[", "t", "]"}], "2"]}], 
                RowBox[{"k", "+", 
                  RowBox[{"\[CapitalLambda]", " ", 
                    SuperscriptBox[
                    RowBox[{"a", "[", "t", "]"}], "2"]}]}]], "\" d\"", 
               SuperscriptBox["t", "2"]}, "RowDefault"]}, "RowDefault"], 
           "\" + \"", 
           TemplateBox[{
             FractionBox["2", 
              RowBox[{
                RowBox[{"-", "2"}], "+", 
                RowBox[{
                  SuperscriptBox["r", "2"], " ", "\[CapitalLambda]"}]}]], 
             "\" d\"", 
             SuperscriptBox["r", "2"]}, "RowDefault"]}, "RowDefault"], 
         "\" - \"", 
         TemplateBox[{
           SuperscriptBox["r", "2"], "\" d\"", 
           SuperscriptBox["\[Theta]", "2"]}, "RowDefault"]}, "RowDefault"], 
       "\" - \"", 
       TemplateBox[{
         RowBox[{
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "\" d\"", 
         SuperscriptBox["\[Phi]", "2"]}, "RowDefault"]}, "RowDefault"], 
     "\" - \"", 
     TemplateBox[{
       RowBox[{
         SuperscriptBox["p", "2"], " ", 
         SuperscriptBox[
          RowBox[{"a", "[", "t", "]"}], "2"]}], "\" d\"", 
       SuperscriptBox["\[Psi]", "2"]}, "RowDefault"]},
    "RowDefault"]}],
