        "\[Beta]"}], ")"}], "2"]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"t", " ", 
        SqrtBox["\[CapitalLambda]"]}]], " ", "\[Alpha]", " ", "\[Beta]", " ", 
      "\[CapitalLambda]"}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"t", " ", 
           SqrtBox["\[CapitalLambda]"]}]], " ", "\[Alpha]"}], "+", 
        "\[Beta]"}], ")"}], "2"]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[Beta]", "2"], " ", "\[CapitalLambda]"}], 
