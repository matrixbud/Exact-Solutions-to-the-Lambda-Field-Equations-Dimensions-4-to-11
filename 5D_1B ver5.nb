 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"0", "0"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], 
     RowBox[{"a", " ", "A"}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "."], " ", 
      OverscriptBox["A", "."]}], 
     RowBox[{"2", " ", "a", " ", 
      SuperscriptBox["A", "2"]}]], "-", 
    FractionBox[
     SuperscriptBox["A", "\[Prime]",
      MultilineFunction->None], 
     RowBox[{"A", " ", "r", " ", "\[CapitalBeta]"}]], "+", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox["A", "\[Prime]",
        MultilineFunction->None], ")"}], "2"], 
     RowBox[{"4", " ", 
      SuperscriptBox["A", "2"], " ", "\[CapitalBeta]"}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["A", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox["\[CapitalBeta]", "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{"4", " ", "A", " ", 
      SuperscriptBox["\[CapitalBeta]", "2"]}]], "-", 
    FractionBox[
     SuperscriptBox["A", "\[Prime]\[Prime]",
      MultilineFunction->None], 
     RowBox[{"2", " ", "A", " ", "\[CapitalBeta]"}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   "\[CapitalLambda]"}],
  SequenceForm[
