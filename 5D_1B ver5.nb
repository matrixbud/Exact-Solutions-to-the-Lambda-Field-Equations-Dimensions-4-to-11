      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"t", " ", 
           SqrtBox["\[CapitalLambda]"]}]], " ", "\[Alpha]"}], "+", 
        "\[Beta]"}], ")"}], "2"]]}], "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]",
    "\[CapitalLambda]"}],
