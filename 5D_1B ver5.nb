Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     B(t,r) = \"\>", "\[InvisibleSpace]", 
   RowBox[{"-", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", 
         RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], "+", 
        RowBox[{"r", " ", 
         RowBox[{
          SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
           MultilineFunction->None], "[", "r", "]"}]}]}], ")"}], "2"], 
     RowBox[{"2", " ", 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "2"}], "+", 
        RowBox[{
         SuperscriptBox["r", "2"], " ", "\[CapitalLambda]", " ", 
         RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}]}], ")"}]}]]}], 
   "\[InvisibleSpace]", "\<\",\"\>"}],
  SequenceForm[
  "     B(t,r) = ", 
   Rational[-1, 
     2] $CellContext`\[GothicCapitalC][$CellContext`r]^(-1) (-2 + \
