        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", 
       FractionBox["k", 
        SuperscriptBox["c", "2"]]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<We can solve the remaining equation for the last \
unknown, \[ScriptCapitalA]:\>\"", "]"}], "\[IndentingNewLine]", 
