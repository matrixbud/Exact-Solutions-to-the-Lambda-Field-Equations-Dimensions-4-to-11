                  RowBox[{"-", "1"}]}]}], ",", "\[IndentingNewLine]", 
                RowBox[{"plus", "=", "\"\< + \>\""}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"firstElem", "==", "1"}], ",", 
                RowBox[{
                 RowBox[{"firstElem", "=", "0"}], ";", 
                 RowBox[{"g\[Mu]\[Nu]", "=", 
