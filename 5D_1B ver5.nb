Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"4", "4"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], 
     RowBox[{"a", " ", "A"}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "."], " ", 
      OverscriptBox["A", "."]}], 
     RowBox[{"2", " ", "a", " ", 
      SuperscriptBox["A", "2"]}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "."], " ", 
      OverscriptBox["B", "."]}], 
     RowBox[{"2", " ", "a", " ", "A", " ", "B"}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "."], " ", 
      OverscriptBox["\[DoubleStruckCapitalC]", "."]}], 
     RowBox[{"a", " ", "A", " ", "\[DoubleStruckCapitalC]"}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   "\[CapitalLambda]"}],
  SequenceForm[
   Subscript["R", 
    Row[{4, 4}]], 
   ":  ", $CellContext`a^(-1) $CellContext`A^(-1) $CellContext`c^2 
    OverDot[$CellContext`a, 2] + 
   Rational[-1, 2] $CellContext`a^(-1) $CellContext`A^(-2) $CellContext`c^2 
    OverDot[$CellContext`a, 1] OverDot[$CellContext`A, 1] + 
   Rational[1, 
      2] $CellContext`a^(-1) $CellContext`A^(-1) $CellContext`B^(-1) \
$CellContext`c^2 OverDot[$CellContext`a, 1] 
    OverDot[$CellContext`B, 
      1] + $CellContext`a^(-1) $CellContext`A^(-1) $CellContext`c^2 \
$CellContext`\[DoubleStruckCapitalC]^(-1) OverDot[$CellContext`a, 1] 
    OverDot[$CellContext`\[DoubleStruckCapitalC], 1], 
   " = ", $CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
