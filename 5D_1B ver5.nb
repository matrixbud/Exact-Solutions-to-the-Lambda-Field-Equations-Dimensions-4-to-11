Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"    \\!\\(\\*SubscriptBox[\\(R\\), \
\\(11\\)]\\)-2\\!\\(\\*SubscriptBox[\\(R\\), \\(22\\)]\\)  \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["2", 
      RowBox[{
       SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]"}]]}], "+", 
    FractionBox["2", 
     RowBox[{
      SuperscriptBox["r", "2"], " ", "\[CapitalBeta]"}]], "+", 
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{"r", " ", "\[GothicCapitalC]", " ", "\[CapitalBeta]"}]], "+", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
        MultilineFunction->None], ")"}], "2"], 
     RowBox[{"2", " ", 
      SuperscriptBox["\[GothicCapitalC]", "2"], " ", "\[CapitalBeta]"}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   RowBox[{"-", "\[CapitalLambda]"}]}],
  SequenceForm[
  "    \!\(\*SubscriptBox[\(R\), \(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\
\)  ", (-2) $CellContext`r^(-2)/$CellContext`\[GothicCapitalC] + 
   2 $CellContext`r^(-2)/$CellContext`\[CapitalBeta] + 
   2 $CellContext`r^(-1) $CellContext`\[GothicCapitalC]^(-1) $CellContext`\
\[CapitalBeta]^(-1) Derivative[1][$CellContext`\[GothicCapitalC]] + 
   Rational[1, 
      2] $CellContext`\[GothicCapitalC]^(-2) $CellContext`\[CapitalBeta]^(-1) 
    Derivative[1][$CellContext`\[GothicCapitalC]]^2, 
   " = ", -$CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
