                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"plus", "==", "\"\< + \>\""}], ",", 
                   RowBox[{"plus", "=", "\"\<\>\""}]}], "]"}]}]}], "]"}], ";",
               "\[IndentingNewLine]", "\t", 
              RowBox[{"(*", " ", 
               RowBox[{"Suppress", " ", "+", " ", 
                RowBox[{
                "sign", " ", "on", " ", "a", " ", "first", " ", "term", " ", 
                 "that", " ", "is", " ", "positive"}]}], " ", "*)"}], "\n", 
              "\t", "\[IndentingNewLine]", 
              RowBox[{"nextTerm", "=", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"factor", " ", "g\[Mu]\[Nu]"}], ",", "\"\< \>\"", ",",
                   "dx\[Mu]", ",", "\"\< \>\"", ",", "dx\[Nu]"}], "}"}], 
                "]"}]}], ";", " ", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"(*", " ", 
               RowBox[{
                RowBox[{"Next", " ", "off"}], "-", 
                RowBox[{
                "diagonal", " ", "line", " ", "element", " ", "term"}]}], " ",
                "*)"}], "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"\[Mu]", "==", "\[Nu]"}], ",", 
                RowBox[{"nextTerm", "=", 
                 RowBox[{"Row", "[", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"factor", " ", "g\[Mu]\[Nu]"}], ",", "\"\< d\>\"",
                     ",", 
                    SuperscriptBox[
                    RowBox[{"\[ScriptX]", "[", "\[Mu]", "]"}], "2"]}], "}"}], 
                  "]"}]}]}], "]"}], ";", " ", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"(*", " ", 
               RowBox[{
               "Next", " ", "diagonal", " ", "line", " ", "element", " ", 
                "term"}], " ", "*)"}], "\[IndentingNewLine]", 
              "\[IndentingNewLine]", 
              RowBox[{"lineElem", "=", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"lineElem", ",", "plus", ",", "nextTerm"}], "}"}], 
                "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], "]"}]}], "]"}],
       ";", "\n", "lineElem"}]}], "]"}]}], " ", 
