Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\" \[Implies]   \[CapitalBeta](r) = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", "\[GothicCapitalC]"}], "+", 
       RowBox[{"r", " ", 
        SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
         MultilineFunction->None]}]}], ")"}], "2"], 
    RowBox[{"4", " ", "\[GothicCapitalC]"}]]}],
  SequenceForm[
  " \[Implies]   \[CapitalBeta](r) = ", 
   Rational[1, 4] $CellContext`\[GothicCapitalC]^(-1) (
     2 $CellContext`\[GothicCapitalC] + $CellContext`r 
      Derivative[1][$CellContext`\[GothicCapitalC]])^2],
  Editable->False]], "Print",
 CellChangeTimes->CompressedData["
