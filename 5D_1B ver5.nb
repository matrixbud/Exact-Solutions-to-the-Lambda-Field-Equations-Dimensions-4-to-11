Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"2", "2"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]"}]], "-", 
    FractionBox["1", 
     RowBox[{
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["r", "2"], " ", "\[CapitalBeta]"}]], "+", 
    FractionBox[
     RowBox[{"3", " ", 
      SuperscriptBox[
       OverscriptBox["a", "."], "2"]}], 
     SuperscriptBox["a", "2"]], "+", 
    FractionBox[
     OverscriptBox["a", "\[DoubleDot]"], "a"], "-", 
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "r", " ", "\[GothicCapitalC]", " ", 
      "\[CapitalBeta]"}]], "+", 
    FractionBox[
     SuperscriptBox["\[CapitalBeta]", "\[Prime]",
      MultilineFunction->None], 
     RowBox[{"2", " ", 
      SuperscriptBox["a", "2"], " ", "r", " ", 
      SuperscriptBox["\[CapitalBeta]", "2"]}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox["\[CapitalBeta]", "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{"4", " ", 
      SuperscriptBox["a", "2"], " ", "\[GothicCapitalC]", " ", 
      SuperscriptBox["\[CapitalBeta]", "2"]}]], "-", 
    FractionBox[
     SuperscriptBox["\[GothicCapitalC]", "\[Prime]\[Prime]",
      MultilineFunction->None], 
     RowBox[{"2", " ", 
      SuperscriptBox["a", "2"], " ", "\[GothicCapitalC]", " ", 
      "\[CapitalBeta]"}]]}], "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]",
    "\[CapitalLambda]"}],
  SequenceForm[
   Subscript["R", 
    Row[{2, 2}]], 
   ":  ", $CellContext`a^(-2) $CellContext`r^(-2)/$CellContext`\
\[GothicCapitalC] - $CellContext`a^(-2) $CellContext`r^(-2)/$CellContext`\
\[CapitalBeta] + 
   3 $CellContext`a^(-2) OverDot[$CellContext`a, 1]^2 + $CellContext`a^(-1) 
    OverDot[$CellContext`a, 2] - 
   2 $CellContext`a^(-2) $CellContext`r^(-1) \
$CellContext`\[GothicCapitalC]^(-1) $CellContext`\[CapitalBeta]^(-1) 
   Derivative[1][$CellContext`\[GothicCapitalC]] + 
   Rational[1, 
      2] $CellContext`a^(-2) $CellContext`r^(-1) \
$CellContext`\[CapitalBeta]^(-2) Derivative[1][$CellContext`\[CapitalBeta]] + 
   Rational[1, 
      4] $CellContext`a^(-2) $CellContext`\[GothicCapitalC]^(-1) \
$CellContext`\[CapitalBeta]^(-2) 
    Derivative[1][$CellContext`\[GothicCapitalC]] 
    Derivative[1][$CellContext`\[CapitalBeta]] + 
   Rational[-1, 
      2] $CellContext`a^(-2) $CellContext`\[GothicCapitalC]^(-1) \
$CellContext`\[CapitalBeta]^(-1) 
    Derivative[2][$CellContext`\[GothicCapitalC]], 
   " = ", $CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
 CellChangeTimes->CompressedData["
