    "Print", "[", "\"\<This eliminates \!\(\*SubscriptBox[\(R\), \(01\)]\), \
and the remaining equations become\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can rewrite \!\(\*SubscriptBox[\(R\), \(44\)]\) \
as\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<    \!\(\*SubscriptBox[\(R\), \(44\)]\):  \>\"", ",", 
      RowBox[{
       RowBox[{"Together", "[", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}], "]"}], "/.", "rulesDisp"}], 
      ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"4", ",", "4"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We observe on the LHS that there is an r term in the \
denominator but no r terms in the numerator to cancel it out, making the LHS \
a function of r, while the RHS is a constant, a contradiction.\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Alternatively, we could have solved \
\!\(\*SubscriptBox[\(R\), \(11\)]\) for \[CapitalBeta], plugged this back in \
and then solved \!\(\*SubscriptBox[\(R\), \(44\)]\) for \[ScriptCapitalA](t), \
and we would have discovered that the formula for \[ScriptCapitalA](t) has r \
terms that don't cancel out, also a contradiction.\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We conclude that this case has no possible solution.\>\
\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
