         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}]}], ",", 
        RowBox[{"A", "[", 
         RowBox[{"t", ",", "r"}], "]"}], ",", 
        RowBox[{"{", 
