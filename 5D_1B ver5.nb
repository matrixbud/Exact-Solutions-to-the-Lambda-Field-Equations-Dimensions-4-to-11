   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We solve Case a again, but with the extra condition \
that A(t,r)=\!\(\*SuperscriptBox[\(c\), \(2\)]\). While Case b has a solution \
containing A(t,r)=\!\(\*SuperscriptBox[\(c\), \(2\)]\), it is possible we may \
obtain an alternate solution by setting A(t,r)=\!\(\*SuperscriptBox[\(c\), \
\(2\)]\) \!\(\*StyleBox[\"before\",FontSlant->\"Italic\"]\) solving the ODEs.\
\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Starting fresh again, the field equations are:\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"R", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", 
               RowBox[{"\[CapitalLambda]", " ", 
                RowBox[{"g", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ")"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
              SubscriptBox["\"\<R\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
              ",", "\"\<:  \>\"", ",", 
              RowBox[{
               RowBox[{"lhs", "[", 
