Cell[BoxData["\<\"\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.981278886702029*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"9f1c8370-1465-43bc-ace4-0fc3cb470a39"],

Cell[BoxData["\<\"Sometime case I becomes \
A(t,r)=a(t\\!\\(\\*SuperscriptBox[\\()\\), \\(2\\)]\\)\[CapitalAlpha](r). \
This happens in cases where \
\\!\\(\\*SubscriptBox[\\(\[DoubleStruckCapitalD]\\), \\(k\\)]\\)(t,r), \
B(t,r), and \[DoubleStruckCapitalC](t,r) are not defined in terms of \
a(t\\!\\(\\*SuperscriptBox[\\()\\), \\(2\\)]\\). That is, if a(t) is not used \
by any of the other unknowns, then it is just as general to write \
A(t,r)=a(t\\!\\(\\*SuperscriptBox[\\()\\), \\(2\\)]\\)\[CapitalAlpha](r) as \
it is to write  A(t,r)=\[ScriptCapitalA](t)\[CapitalAlpha](r). This also \
applies to case I\[Alpha] where we may define \
A(t,r)=a(t\\!\\(\\*SuperscriptBox[\\()\\), \\(2\\)]\\).\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.981278886702394*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"e553fabc-022c-480f-8044-20f810270894"],

Cell[BoxData["\<\"\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.981278886703022*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"f69a7c5e-362e-4cfc-9022-a4a85e94925a"],

Cell[BoxData["\<\"From here, we do a methodical development of exact \
solutions to the equations. We do this by proceeding through the 6D notebooks \
1A-1E and 2A-2E, then 7D 1A-1E and 2A-2E, 8D 1A-1E, 2A-2E, and 3A-3E, and so \
on until 11D. The 5D notebooks have already been completed.\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.981278886703364*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"6b5801f9-71ea-4127-83ed-d27e5365d427"],

Cell[BoxData["\<\"\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.9812788867038097`*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"271e3c36-a47d-45a7-a6e6-a09313933cbb"],

Cell[BoxData["\<\"When we write labels like 1A, 2A, 3A, and 6A, the numbers \
have the following meanings:\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.98127888670415*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"f89edfc1-e8c8-40db-b7af-8e614d1183ee"],

Cell[BoxData["\<\"1: Curled space(s) are circles\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.9812788867045107`*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"db7779eb-54dc-416d-b7e2-341feb65d5b1"],

Cell[BoxData["\<\"2: Curled space(s) are 2-spheres (plus a circle if \
dimension is odd)\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.981278886704854*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"13fefab8-0235-46bb-a1fe-3c2678c7f8e3"],

Cell[BoxData["\<\"3: Curled space(s) are 3 spheres\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.981278886705225*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"ccaebe7f-a76d-4bd4-805f-368dcecd079b"],

Cell[BoxData["\<\"6: Curled space is a 6-sphere\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.9812788867055693`*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"0c384a34-f52e-4d8d-8d51-8d859dbbe389"],

Cell[BoxData["\<\"\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.9812788867059183`*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"1027e259-2f89-4477-805b-a6c357bce455"],

Cell[BoxData["\<\"If time permits, I may examine a 4-sphere (in 8D or 9D) or \
a 5-sphere (in 9D or 10D).\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.981278886706252*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"258e002c-6dd8-4e14-b82a-fba9782b4d00"],

Cell[BoxData["\<\"\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.981278886706625*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"11f284e7-e0d2-4636-8b81-3a73fc3413a5"],

Cell[BoxData["\<\"Within each notebook are the subcases a-d and I-II, and \
often many sub-subcases as well.\"\>"], "Print",
 CellChangeTimes->{3.978951926785626*^9, 3.981278886706972*^9},
 CellLabel->
  "During evaluation of \
In[1882]:=",ExpressionUUID->"989588c0-83f3-46f1-9364-9aa6475ba815"]
