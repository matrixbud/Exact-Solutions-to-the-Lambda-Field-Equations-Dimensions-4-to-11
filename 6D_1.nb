Cell[BoxData["\<\"The Lambda vacuum field equations can be represented as \\!\
\\(\\*FractionBox[SubscriptBox[\\(R\\), \\(\[Mu]\[Nu]\\)], \
SubscriptBox[\\(g\\), \\(\[Mu]\[Nu]\\)]]\\) = \[CapitalLambda],\"\>"], "Print",\

