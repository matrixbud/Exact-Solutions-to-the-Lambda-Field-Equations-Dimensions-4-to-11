Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\" \[Implies]   \[CapitalBeta](r) = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{
     SuperscriptBox["r", "6"], " ", 
     SuperscriptBox["\[Beta]", "2"]}], 
    RowBox[{"\[Alpha]", "-", 
     TemplateBox[{
       RowBox[{
         RowBox[{"-", 
           FractionBox["1", "2"]}], " ", "\[Beta]", " ", 
         SuperscriptBox["\[Rho]", "5"], " ", 
         RowBox[{"(", 
           RowBox[{"\[Kappa]", "-", 
             RowBox[{"4", " ", "\[Beta]", " ", "\[CapitalLambda]", " ", 
               SuperscriptBox["\[Rho]", "2"]}]}], ")"}]}], "\[Rho]", "1", "r"},
      "InactiveIntegrate",
      DisplayFunction->(RowBox[{
         SubsuperscriptBox[
          StyleBox["\[Integral]", "Inactive"], #3, #4], 
         RowBox[{#, 
           RowBox[{
             StyleBox["\[DifferentialD]", "Inactive"], #2}]}]}]& ),
      InterpretationFunction->(RowBox[{
         RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
         RowBox[{#, ",", 
           RowBox[{"{", 
             RowBox[{#2, ",", #3, ",", #4}], "}"}]}], "]"}]& )]}]], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   RowBox[{"-", 
