   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     Since \!\(\*SuperscriptBox[\(Csch\), \
\(2\)]\)(t)>0 for all t, we must have\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
