        MultilineFunction->None], ")"}], "2"], 
     RowBox[{"2", " ", 
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["\[GothicCapitalC]", "2"], " ", "\[CapitalBeta]"}]], "+", 
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["\[GothicCapitalD]", "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "r", " ", "\[GothicCapitalD]", " ", 
      "\[CapitalBeta]"}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox["\[GothicCapitalD]", "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "\[GothicCapitalC]", " ", 
      "\[GothicCapitalD]", " ", "\[CapitalBeta]"}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", "2"}], " ", "\[CapitalLambda]"}]}],
  SequenceForm[
  "     \!\(\*SubscriptBox[\(R\), \(11\)]\)-2\!\(\*SubscriptBox[\(R\), \
\(22\)]\)-\!\(\*SubscriptBox[\(R\), \(44\)]\):  ", (-2) $CellContext`a^(-2) \
$CellContext`r^(-2)/$CellContext`\[GothicCapitalC] + 
   2 $CellContext`a^(-2) $CellContext`r^(-2)/$CellContext`\[CapitalBeta] - 
