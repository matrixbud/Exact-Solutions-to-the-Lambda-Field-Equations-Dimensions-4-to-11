 InterpretationBox[
  RowBox[{
   RowBox[{"\<\"     \\!\\(\\*FractionBox[\\(Denominator\\), \\(r\\\\ \
\\*SuperscriptBox[\\(\[CapitalBeta]\\), \\(2\\)]\\)]\\) = \[ScriptF](t):  \
\"\>", "\[InvisibleSpace]", 
    RowBox[{"4", " ", 
     SuperscriptBox["a", "2"], " ", "\[GothicCapitalD]", " ", 
     "\[CapitalLambda]"}]}], "+", 
   RowBox[{"4", " ", 
    SuperscriptBox["c", "2"], " ", 
    TemplateBox[{"1"},
     "C"]}], "+", 
   FractionBox[
    RowBox[{"4", " ", 
     SuperscriptBox["a", "2"], " ", 
