          RowBox[{"0", ",", "0"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], ",", 
        RowBox[{"a", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}], ",", 
        RowBox[{
         RowBox[{"C", "[", "2", "]"}], "->", "\[Beta]"}]}], "}"}]}]}], ";"}], 
