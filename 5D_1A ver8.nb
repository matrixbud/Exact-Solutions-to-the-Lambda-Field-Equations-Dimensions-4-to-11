Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     a(t) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      FractionBox[
       RowBox[{"t", " ", 
        SqrtBox["\[CapitalLambda]"]}], "2"]], " ", "\[Alpha]"}], "+", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"t", " ", 
         SqrtBox["\[CapitalLambda]"]}], "2"]}]], " ", "\[Beta]"}]}], 
   "\[InvisibleSpace]", "\<\"  where \[Alpha] and \[Beta] are constants of \
integration.\"\>"}],
  SequenceForm[
  "     a(t) = ", 
   E^(Rational[1, 2] $CellContext`t $CellContext`\[CapitalLambda]^
       Rational[1, 2]) $CellContext`\[Alpha] + 
   E^(Rational[-1, 2] $CellContext`t $CellContext`\[CapitalLambda]^
       Rational[1, 2]) $CellContext`\[Beta], 
   "  where \[Alpha] and \[Beta] are constants of integration."],
  Editable->False]], "Print",
 CellChangeTimes->{3.980535109986506*^9},
