   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Following the Case b methodology, but using this \
simpler value of \[GothicCapitalC](r), starting from scratch, the field \
equations become:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"R", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", 
               RowBox[{"\[CapitalLambda]", " ", 
                RowBox[{"g", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ")"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
              SubscriptBox["\"\<R\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
              ",", "\"\<:  \>\"", ",", 
              RowBox[{
               RowBox[{"lhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
              ",", "\"\< = \>\"", ",", 
              RowBox[{"rhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}]}], ",", 
        RowBox[{"A", "[", 
         RowBox[{"t", ",", "r"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "r"}], "}"}]}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[ScriptCapitalA]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<As in Case b, we solve \!\(\*SubscriptBox[\(R\), \
\(01\)]\):\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     A(t,r) = \>\"", ",", 
      RowBox[{"A", "[", 
       RowBox[{"t", ",", "r"}], "]"}], 
      ",", "\"\<  where \[ScriptCapitalA](t) is a new unknown.\>\""}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<Plugging back in:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ls", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"0", ",", "0"}], "]"}]}], "-", 
       RowBox[{"lhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "+", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rs", "=", 
     RowBox[{
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}]}], "-", 
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], "+", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     RowBox[{"DSolveValue", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"0", ",", "0"}], "]"}], "==", 
        RowBox[{"rhs", "[", 
         RowBox[{"0", ",", "0"}], "]"}]}], ",", 
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "t"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(44\)]\) has become \
redundant, the same as \!\(\*SubscriptBox[\(R\), \(00\)]\).\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(00\)]\) for \
\[ScriptCapitalA]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptCapitalA](t) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesDisp"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<          where \>\"", ",", 
      RowBox[{"C", "[", "1", "]"}], 
      ",", "\"\< is a constant of integration.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"den", "=", 
     RowBox[{"xS", "[", 
      FractionBox[
       RowBox[{"Denominator", "[", 
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "]"}], 
       RowBox[{"r", " ", 
        SuperscriptBox[
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "2"]}]], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<The numerator divided by r \!\(\*SuperscriptBox[\(\
\[CapitalBeta]\), \(2\)]\) is strictly a function of t, ever so slightly \
different than Case b. In order for the whole expression to be strictly a \
function of t, the denominator divided by r \!\(\*SuperscriptBox[\(\
\[CapitalBeta]\), \(2\)]\) must equal some function of t, say \
\[ScriptF](t).\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*FractionBox[\(Denominator\), \(r\\\ \
\*SuperscriptBox[\(\[CapitalBeta]\), \(2\)]\)]\) = \[ScriptF](t):  \>\"", ",", 
      RowBox[{"den", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"\[ScriptF]", "[", "t", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"Simplify", "[", 
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"den", "==", 
          RowBox[{"\[ScriptF]", "[", "t", "]"}]}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", "r"}], "]"}], "]"}], 
      "/.", 
      RowBox[{
       RowBox[{"C", "[", "2", "]"}], "->", "\[Alpha]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can solve this equation for \[CapitalBeta](r), \
getting the same result as in Case b:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[CapitalBeta][r] = \>\"", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesKr"}], "/.", 
       "rulesDisp"}], ",", "\"\<    where \[Alpha] and \>\"", ",", 
      RowBox[{"C", "[", "1", "]"}], 
      ",", "\"\< are constants of integration.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     RowBox[{"xS", "[", 
      RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[ScriptCapitalA]hold", "=", 
     RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<This formula for \[CapitalBeta](r) shows that the \
equation\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \!\(\*FractionBox[\(Denominator\), \(r\\\ \
\*SuperscriptBox[\(\[CapitalBeta]\), \(2\)]\)]\) = \[ScriptF](t)\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<is solvable, meaning that \[ScriptCapitalA](t) can \
(again) be compactly expressed as\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptCapitalA](t) = \
\!\(\*FractionBox[\(Numerator\), \(Denominator\)]\) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesDisp"}], 
      ",", "\"\<.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Plugging \[ScriptCapitalA] and \[CapitalBeta] back \
into the equations is unwieldy because of \[CapitalBeta], but we are not \
interested in the formula for \[CapitalBeta] just now. Rather, we are focused \
on just using the above simple expression for \[ScriptCapitalA](t).\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", 
    RowBox[{"\[CapitalBeta]", ",", "\[ScriptCapitalA]"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     "\[ScriptCapitalA]hold"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Plugging just \[ScriptCapitalA](t) back into the \
equations should make \!\(\*SubscriptBox[\(R\), \(00\)]\) into the identity, \
0=0, but it doesn't because we have suppessed the formula for \[CapitalBeta]:\
\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \(00\)]\):  \>\"", ",", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "/.", "rulesDisp"}], 
      ",", "\"\<.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptF]", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"\[ScriptF]", "'"}], "[", "t", "]"}], "==", 
         RowBox[{"\[Kappa]", " ", 
          RowBox[{"a", "[", "t", "]"}], 
          RowBox[{
           RowBox[{"a", "'"}], "[", "t", "]"}]}]}], ",", 
        RowBox[{"\[ScriptF]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[Zeta]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<As in Case b, we can make \!\(\*SubscriptBox[\(R\), \
\(00\)]\) an identity by eliminating the t terms, i.e., solving\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \!\(\*OverscriptBox[\(\[ScriptF]\), \(.\)]\) = \
\[Kappa] a \!\(\*OverscriptBox[\(a\), \(.\)]\) where \[Kappa] is a \
proportionality constant,\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<and then re-solving \!\(\*SubscriptBox[\(R\), \
\(00\)]\) for \[CapitalBeta].\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Solving the ODE, above, for \[ScriptF] yields:\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptF](t) = \>\"", ",", 
      RowBox[{"\[ScriptF]", "[", "t", "]"}], 
      ",", "\"\<  where \[Zeta] is a constant of integration.\>\""}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<\[ScriptCapitalA](t) then becomes\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptCapitalA](t) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesLE"}], 
      ",", "\"\<,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<and \!\(\*SubscriptBox[\(R\), \(00\)]\) becomes\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(00\)]\):  \>\"", ",", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "/.", "rulesDisp"}], 
      ",", "\"\<.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"Simplify", "[", 
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}]}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", "r"}], "]"}], "]"}], 
      "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<When we re-solve \!\(\*SubscriptBox[\(R\), \(00\)]\) \
for \[CapitalBeta](r), we obtain a simplified version of the \
\[CapitalBeta](r) formula, above, that has constant \[Kappa] instead of the \
\[ScriptF](t) function:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[CapitalBeta][r] = \>\"", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesKr"}], "/.", 
       "rulesDisp"}], ",", "\"\<  where \[Alpha] and \>\"", ",", "\[Kappa]", 
      ",", "\"\< are constants of integration.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Plugging this simplified version of \[CapitalBeta] \
into the equations shows that \!\(\*SubscriptBox[\(R\), \(00\)]\) is indeed \
an identity and, in fact, so is \!\(\*SubscriptBox[\(R\), \(44\)]\).\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Mu]", "<", "1"}], "||", 
         RowBox[{"\[Mu]", ">", "3"}]}], ",", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(11\)]\) and \
\!\(\*SubscriptBox[\(R\), \(22\)]\), however, are rather messy. The simpler \
of the two is \!\(\*SubscriptBox[\(R\), \(22\)]\):\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}], "/.", "rulesKr"}], "/.", 
       "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"2", ",", "2"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<I am unable solve these equations or any combination \
of them using standard methods. The simplest combination is \
\!\(\*SubscriptBox[\(R\), \(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\) but \
it is still quite complex.\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<However, using a hunch, I am able to magically find a \
solution by making the denominators of the three terms that contain the \
integral proportional to each other. That is, the first two denominators are \
\!\(\*SuperscriptBox[\(r\), \
\(5\)]\)\!\(\*SuperscriptBox[\"\[GothicCapitalD]\", FormBox[StyleBox[\"\
\[Prime]\",FontSize->13,FontWeight->\"Regular\",FontSlant->\"Plain\"],\
TraditionalForm]]\)[r\!\(\*SuperscriptBox[\(]\), \(3\)]\) and \
\!\(\*SuperscriptBox[\(r\), \
\(6\)]\)\!\(\*SuperscriptBox[\"\[GothicCapitalD]\", FormBox[StyleBox[\"\
\[Prime]\",FontSize->13,FontWeight->\"Regular\",FontSlant->\"Plain\"],\
TraditionalForm]]\)[r\!\(\*SuperscriptBox[\(]\), \(2\)]\), so we want \
\!\(\*SuperscriptBox[\(r\), \
\(5\)]\)\!\(\*SuperscriptBox[\"\[GothicCapitalD]\", FormBox[StyleBox[\"\
\[Prime]\",FontSize->13,FontWeight->\"Regular\",FontSlant->\"Plain\"],\
TraditionalForm]]\)[r\!\(\*SuperscriptBox[\(]\), \(3\)]\) = \[Beta] \
\!\(\*SuperscriptBox[\(r\), \(6\)]\) \!\(\*SuperscriptBox[\"\[GothicCapitalD]\
\", FormBox[StyleBox[\"\[Prime]\",FontSize->13,FontWeight->\"Regular\",\
FontSlant->\"Plain\"],TraditionalForm]]\)[r\!\(\*SuperscriptBox[\(]\), \(2\)]\
\) for some proportionality constant \[Beta], or \!\(\*SuperscriptBox[\(\
\[GothicCapitalD]\), \(\[Prime]\)]\)(r) = \[Beta] r  \[Implies]  \
\[GothicCapitalD](r) = \!\(\*FractionBox[\(\[Beta]\), \
\(2\)]\)\!\(\*SuperscriptBox[\(r\), \(2\)]\) + \[CapitalKappa]  where \
\[CapitalKappa] is a constant of integration. \>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Similarly, the 3rd denominator is \
\!\(\*SuperscriptBox[\(r\), \(5\)]\)\[GothicCapitalD](r)\!\(\*SuperscriptBox[\
\"\[GothicCapitalD]\", \
FormBox[StyleBox[\"\[Prime]\",FontSize->13,FontWeight->\"Regular\",FontSlant->\
\"Plain\"],TraditionalForm]]\)(r) and we want \!\(\*SuperscriptBox[\(\[Beta]r\
\), \(6\)]\)\!\(\*SuperscriptBox[\"\[GothicCapitalD]\", FormBox[StyleBox[\"\
\[Prime]\",FontSize->13,FontWeight->\"Regular\",FontSlant->\"Plain\"],\
TraditionalForm]]\)(r\!\(\*SuperscriptBox[\()\), \(2\)]\) = \
\!\(\*SuperscriptBox[\(\[Gamma]r\), \
\(5\)]\)\[GothicCapitalD](r)\!\(\*SuperscriptBox[\"\[GothicCapitalD]\", \
FormBox[StyleBox[\"\[Prime]\",FontSize->13,FontWeight->\"Regular\",FontSlant->\
\"Plain\"],TraditionalForm]]\)(r) for some proportionality constant \[Gamma]. \
Combining these, it is straightforward to show that \[CapitalKappa] = 0, so \
that\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[GothicCapitalD](r) = \
\!\(\*FractionBox[\(\[Beta]\), \(2\)]\)\!\(\*SuperscriptBox[\(r\), \(2\)]\)\>\
\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
