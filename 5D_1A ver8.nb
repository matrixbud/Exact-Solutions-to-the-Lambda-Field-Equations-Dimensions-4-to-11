    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<\!\(\*StyleBox[\"a_II\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\":\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"  \",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, 1]]\
\)\!\(\*StyleBox[\"B\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, 1]]\)\!\
\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\",\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"=\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"a\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[SuperscriptBox[\")\", \
\"2\"],FontWeight->\"Bold\",FontColor->RGBColor[1, 0, 1]]\)\!\(\*StyleBox[\"\
\[CapitalBeta]\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\",\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"  \",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, 1]]\
\)\!\(\*StyleBox[\"\[DoubleStruckCapitalC]\",FontWeight->\"Bold\",FontColor->\
RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\",\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"=\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"a\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[SuperscriptBox[\")\", \
\"2\"],FontWeight->\"Bold\",FontColor->RGBColor[1, 0, 1]]\)\!\(\*StyleBox[\"\
\[GothicCapitalC]\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\",\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"  \",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, 1]]\
\)\!\(\*StyleBox[\"A\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, 1]]\)\!\
\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\",\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"=\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*SuperscriptBox[StyleBox[\"c\",FontWeight->\"Bold\",FontColor->\
RGBColor[1, 0, 1]], \
StyleBox[\"2\",FontWeight->\"Bold\",FontColor->RGBColor[0.9855344472419318, \
0.00946059357595178, 0.9991760128175784]]]\)\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     SuperscriptBox["c", "2"]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"B", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"], 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[DoubleStruckCapitalC]", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"], 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We solve Case a again, but with the extra condition \
that A(t,r)=\!\(\*SuperscriptBox[\(c\), \(2\)]\). While Case a has a solution \
containing A(t,r)=\!\(\*SuperscriptBox[\(c\), \(2\)]\), it is possible we may \
obtain an alternate solution by setting A(t,r)=\!\(\*SuperscriptBox[\(c\), \
\(2\)]\) \!\(\*StyleBox[\"before\",FontSlant->\"Italic\"]\) solving the ODEs.\
\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<The field equations become\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"R", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], "&&", 
               RowBox[{
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "===", "0"}]}], 
              ")"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
              SubscriptBox["\"\<R\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
              ",", "\"\<:  \>\"", ",", 
              RowBox[{
               RowBox[{"lhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
              ",", "\"\< = \>\"", ",", 
              RowBox[{"rhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], ",", 
        RowBox[{"a", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}], ",", 
        RowBox[{
         RowBox[{"C", "[", "2", "]"}], "->", "\[Beta]"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"aSave", "=", 
     RowBox[{"a", "[", "t", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Solving \!\(\*SubscriptBox[\(R\), \(00\)]\) yields\>\"",
      "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \>\"", ",", 
      RowBox[{"a", "[", "t", "]"}], 
      ",", "\"\<  where \[Alpha] and \[Beta] are constants of \
integration.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "a", "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs124", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}], "-", 
       RowBox[{"lhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs124", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], "-", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}], "-", 
      RowBox[{"rhs", "[", 
       RowBox[{"4", ",", "4"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can also \
\!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) solve \
\!\(\*SubscriptBox[\(R\), \(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\
\*SubscriptBox[\(R\), \(44\)]\) for \[CapitalBeta](r):\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \(44\
\)]\):  \>\"", ",", 
      RowBox[{"lhs124", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      "rhs124"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", 
      RowBox[{"Last", "[", 
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"lhs124", "==", "rhs124"}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], "]"}]}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesDisp"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"p", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"Denominator", "[", 
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"4", 
         RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], 
         RowBox[{"\[GothicCapitalD]", "[", "r", "]"}]}], ")"}]}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<In order for \[CapitalBeta](r) to strictly be a \
function of r, the t terms in the denominator must disappear. There are no \
terms in the numerator to cancel them out, so the denominator terms must be \
self-canceling. It turns out they are. Call the denominator expression in the \
parentheses p(t,r):\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     p(t,r) = \>\"", ",", 
      RowBox[{
       RowBox[{"p", "[", 
        RowBox[{"t", ",", "r"}], "]"}], "/.", "rulesDisp"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "t_", "]"}], "=", "aSave"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"p", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"Expand", "[", 
      RowBox[{"p", "[", 
       RowBox[{"t", ",", "r"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     FractionBox[
      RowBox[{"Numerator", "[", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "]"}], 
      RowBox[{"4", 
       RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], 
       RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], 
       RowBox[{"p", "[", 
        RowBox[{"t", ",", "r"}], "]"}]}]]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<When we plug in the formula above for a(t), this \
simplifies to\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     p(t,r) = \>\"", ",", 
      RowBox[{"p", "[", 
       RowBox[{"t", ",", "r"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\< \[Implies]   B(r) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesDisp"}], 
      ",", "\"\<, strictly a function of r.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs14", "=", 
     RowBox[{"xS", "[", 
      RowBox[{"Numerator", "[", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"1", ",", "1"}], "]"}], "-", 
         RowBox[{"lhs", "[", 
          RowBox[{"4", ",", "4"}], "]"}]}], "]"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs14", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], "-", 
      RowBox[{"rhs", "[", 
       RowBox[{"4", ",", "4"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<When we plug \[CapitalBeta](r) into the remaining \
equations, they are each a page long and I can't find an algebraic \
combination that simplifies them. However, the terms on the LHS of \
\!\(\*SubscriptBox[\(R\), \(11\)]\)-\!\(\*SubscriptBox[\(R\), \(44\)]\) all \
have the same denominator, and the RHS is zero. So, we can ignore the \
denominators:\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"lhs14", "/.", "rulesDisp"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<= \>\"", ",", "rhs14"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Beta]", "=", "0"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<This equation is still too difficult for me to solve, \
so I simplify it by setting the product \[Alpha]\[Beta]=0:\>\"", "]"}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"lhs14", "/.", "rulesDisp"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<= \>\"", ",", "rhs14"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[GothicCapitalC]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"Simplify", "[", 
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"lhs14", "==", "rhs14"}], ",", 
         RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], ",", "r"}], "]"}], 
       "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"C", "[", "1", "]"}], "->", "k"}], ",", 
        RowBox[{
         RowBox[{"C", "[", "2", "]"}], "->", "\[CapitalKappa]"}]}], "}"}]}]}],
     ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\< \[Implies]   \[GothicCapitalC](r) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], "/.", "rulesDisp"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<Plugging this back in, the remaining equations are \
satisfied:\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "1"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<As hoped, we have found a different exact solution to \
the \[CapitalLambda] field equations than that found in Case a:\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \>\"", ",", 
      RowBox[{"a", "[", "t", "]"}], 
      ",", "\"\<  where \[Alpha] is a free constant,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     A(t,r) = \>\"", ",", 
      RowBox[{"A", "[", 
       RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     B(t,r) = a(t\!\(\*SuperscriptBox[\()\), \(2\)]\)\
\[CapitalBeta](r) = \[InvisibleSpace]a(t\!\(\*SuperscriptBox[\()\), \
\(2\)]\)\>\"", ",", 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}], 
      ",", "\"\<  where k and \[CapitalKappa] are free constants,\>\""}], 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[DoubleStruckCapitalC](t,r) = \>\"", ",", 
      RowBox[{"\[DoubleStruckCapitalC]", "[", 
       RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[DoubleStruckCapitalD](t,r) = \
a(t\!\(\*SuperscriptBox[\()\), \(2\)]\)\[GothicCapitalD](r)  where \
\[GothicCapitalD](r) is a free parameter,\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<and line element\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \>\"", ",", 
      RowBox[{"lineElem", "/.", "rulesLE"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We obtained this solution by arbitrarily setting the \
product \[Alpha]\[Beta]=0. We can possibly obtain other exact solutions. \
Another natural choice was to use is \
\[Alpha]=-\[Beta]=\!\(\*FractionBox[\(1\), \(2\)]\), but that did not lead to \
a solvable equation.\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"a", "[", "t_", "]"}], "=", "aSave"}], ";", 
