Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \[CapitalBeta][r] = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{
     SuperscriptBox["r", "4"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox["\[GothicCapitalD]", "\[Prime]",
        MultilineFunction->None], ")"}], "2"]}], 
    RowBox[{"\[Alpha]", "-", 
     TemplateBox[{
       FractionBox[
        RowBox[{
          SuperscriptBox["\[Rho]", "4"], " ", 
          RowBox[{"(", 
            RowBox[{
              RowBox[{"-", "\[ScriptF]"}], "+", 
              RowBox[{"4", " ", 
                SuperscriptBox["a", "2"], " ", "\[GothicCapitalD]", " ", 
                "\[CapitalLambda]"}], "+", 
              RowBox[{"4", " ", 
                SuperscriptBox["c", "2"], " ", 
                TemplateBox[{"1"}, "C"]}]}], ")"}], " ", 
          SuperscriptBox[
          "\[GothicCapitalD]", "\[Prime]", MultilineFunction -> None]}], 
        SuperscriptBox["a", "2"]], "\[Rho]", "1", "r"},
      "InactiveIntegrate",
      DisplayFunction->(RowBox[{
         SubsuperscriptBox[
          StyleBox["\[Integral]", "Inactive"], #3, #4], 
         RowBox[{#, 
           RowBox[{
             StyleBox["\[DifferentialD]", "Inactive"], #2}]}]}]& ),
      InterpretationFunction->(RowBox[{
         RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
         RowBox[{#, ",", 
           RowBox[{"{", 
             RowBox[{#2, ",", #3, ",", #4}], "}"}]}], "]"}]& )]}]], 
   "\[InvisibleSpace]", "\<\"    where \[Alpha] and \"\>", "\[InvisibleSpace]", 
   TemplateBox[{"1"},
    "C"], "\[InvisibleSpace]", "\<\" are constants of integration.\"\>"}],
  SequenceForm[
  "     \[CapitalBeta][r] = ", $CellContext`r^4 
   Derivative[1][$CellContext`\[GothicCapitalD]]^2/($CellContext`\[Alpha] - 
   Inactive[Integrate][$CellContext`a^(-2) $CellContext`\[Rho]^4 \
(-$CellContext`\[ScriptF] + 
     4 $CellContext`a^2 $CellContext`\[GothicCapitalD] $CellContext`\
\[CapitalLambda] + 4 $CellContext`c^2 C[1]) 
    Derivative[1][$CellContext`\[GothicCapitalD]], {$CellContext`\[Rho], 
     1, $CellContext`r}]), "    where \[Alpha] and ", 
   C[1], " are constants of integration."],
  Editable->False]], "Print",
 CellChangeTimes->{3.980535125020329*^9},
 CellLabel->
  "During evaluation of \
In[16561]:=",ExpressionUUID->"16fbb2c2-127d-4e7d-a63a-e2da96cd3c1f"],

