    "Print", "[", "\"\<The solution to \!\(\*SubscriptBox[\(R\), \(00\)]\) is\
\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \>\"", ",", 
      RowBox[{"a", "[", "t", "]"}], 
      ",", "\"\<  where \[Alpha] and \[Beta] are constants of \
integration.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[GothicCapitalD]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}]}], ",", 
        RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], ",", "r"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[CapitalKappa]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Since the denominator of \!\(\*SubscriptBox[\(R\), \
\(01\)]\) can be ignored and since a \[NotEqual] constant, then \
\!\(\*OverscriptBox[\(a\), \(.\)]\) \[NotEqual] 0, and we get that\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[GothicCapitalD](r) = \>\"", ",", 
      RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], 
      ",", "\"\<, a constant.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalKappa]", "=", "1"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
