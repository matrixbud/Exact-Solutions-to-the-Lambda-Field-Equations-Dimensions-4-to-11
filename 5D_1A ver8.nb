Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"      a(t) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      FractionBox[
       RowBox[{"t", " ", 
        SqrtBox["\[CapitalLambda]"]}], 
       SqrtBox["2"]]], " ", "\[Alpha]"}], "+", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"t", " ", 
         SqrtBox["\[CapitalLambda]"]}], 
        SqrtBox["2"]]}]], " ", "\[Beta]"}]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      FractionBox["1", "2"]}], " ", 
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"t", " ", 
         SqrtBox["\[CapitalLambda]"]}], 
        SqrtBox["2"]]}]]}], "+", 
    RowBox[{
     FractionBox["1", "2"], " ", 
     SuperscriptBox["\[ExponentialE]", 
      FractionBox[
       RowBox[{"t", " ", 
        SqrtBox["\[CapitalLambda]"]}], 
       SqrtBox["2"]]]}]}], "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   RowBox[{"Sinh", "[", 
    FractionBox[
     RowBox[{"t", " ", 
      SqrtBox["\[CapitalLambda]"]}], 
     SqrtBox["2"]], "]"}], "\[InvisibleSpace]", "\<\",\"\>"}],
  SequenceForm[
  "      a(t) = ", 
   E^(2^Rational[-1, 2] $CellContext`t $CellContext`\[CapitalLambda]^
       Rational[1, 2]) $CellContext`\[Alpha] + 
   E^(-2^Rational[-1, 2] $CellContext`t $CellContext`\[CapitalLambda]^
       Rational[1, 2]) $CellContext`\[Beta], " = ", 
   Rational[-1, 2] 
    E^(-2^Rational[-1, 2] $CellContext`t $CellContext`\[CapitalLambda]^
       Rational[1, 2]) + 
   Rational[1, 2] 
    E^(2^Rational[-1, 2] $CellContext`t $CellContext`\[CapitalLambda]^
       Rational[1, 2]), " = ", 
   Sinh[2^Rational[-1, 2] $CellContext`t $CellContext`\[CapitalLambda]^
     Rational[1, 2]], ","],
  Editable->False]], "Print",
 CellChangeTimes->{3.980535135437374*^9},
 CellLabel->
  "During evaluation of \
In[16561]:=",ExpressionUUID->"47315046-d4b8-4ba8-adec-f6884d1972a1"],

