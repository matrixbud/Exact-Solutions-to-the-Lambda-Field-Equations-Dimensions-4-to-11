 "\"  or else expressions like ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["k", "1"], "'"}], 
    SubscriptBox["k", "1"]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "10ee3da3-6518-498c-8927-28d60dbe7e4d"],
 " cause a mess \n\tI avoid this need for quotes: \n\t     For example,  \
instead of using ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["k", "1"], "'"}], "[", "r", "]"}], TraditionalForm]],
  ExpressionUUID->"690c5a0f-8914-4882-86d0-509599793b4e"],
 " in rulesDisp, I use  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"x_", "'"}], "[", "r", "]"}], "\[RuleDelayed]", 
    SuperscriptBox["x", 
     StyleBox["\[Prime]",
      FontSize->13,
      FontWeight->"Regular",
      FontSlant->"Plain"]]}], TraditionalForm]],ExpressionUUID->
  "7e016baf-6406-4124-8773-66759cdf0a70"],
 "  \n\t     where x_ stands for any parameter\n\n",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Clear", "[", "K", "]"}], " ", "works", " ", "but", " ", 
   RowBox[{"Clear", "[", 
    SubscriptBox["K", "1"], "]"}], " ", "gives", " ", "an", " ", "error", " ",
    "message", " ", "that", " ", 
   SubscriptBox["K", "1"], " ", "is", " ", "not", " ", "a", " ", 
   "variable"}]], "Text",
