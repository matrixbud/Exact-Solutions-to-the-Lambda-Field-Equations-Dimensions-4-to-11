     RowBox[{"12", " ", 
      SuperscriptBox["r", "6"], " ", 
      SuperscriptBox["\[Beta]", "2"]}], 
     RowBox[{
      RowBox[{
       RowBox[{"-", "12"}], " ", "\[Alpha]"}], "+", 
      RowBox[{"\[Beta]", " ", 
       RowBox[{"(", 
        RowBox[{"\[Kappa]", "-", 
         RowBox[{
          SuperscriptBox["r", "6"], " ", "\[Kappa]"}], "+", 
         RowBox[{"3", " ", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"-", "1"}], "+", 
            SuperscriptBox["r", "8"]}], ")"}], " ", "\[Beta]", " ", 
          "\[CapitalLambda]"}]}], ")"}]}]}]]}], 
   "\[InvisibleSpace]", "\<\".\"\>"}],
  SequenceForm[
  " \[Implies]   \[CapitalBeta](r) = ", $CellContext`r^6 \
$CellContext`\[Beta]^2/($CellContext`\[Alpha] - Inactive[Integrate][
   Rational[-1, 
      2] $CellContext`\[Beta] $CellContext`\[Rho]^5 ($CellContext`\[Kappa] - 
     4 $CellContext`\[Beta] $CellContext`\[CapitalLambda] \
$CellContext`\[Rho]^2), {$CellContext`\[Rho], 1, $CellContext`r}]), 
   " = ", (-12) $CellContext`r^6 $CellContext`\[Beta]^2/((-12) $CellContext`\
\[Alpha] + $CellContext`\[Beta] ($CellContext`\[Kappa] - $CellContext`r^6 \
$CellContext`\[Kappa] + 
     3 (-1 + $CellContext`r^8) $CellContext`\[Beta] $CellContext`\
\[CapitalLambda])), "."],
  Editable->False]], "Print",
