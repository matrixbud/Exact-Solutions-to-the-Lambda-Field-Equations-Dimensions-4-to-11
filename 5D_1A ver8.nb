  RowBox[{"\<\"     \\!\\(\\*SubscriptBox[\\(R\\), \
\\(11\\)]\\)-2\\!\\(\\*SubscriptBox[\\(R\\), \
\\(22\\)]\\)-\\!\\(\\*SubscriptBox[\\(R\\), \\(44\\)]\\):  \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["2", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]"}]]}], "+", 
    FractionBox["2", 
     RowBox[{
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["r", "2"], " ", "\[CapitalBeta]"}]], "-", 
    FractionBox[
     RowBox[{"6", " ", 
      SuperscriptBox[
       OverscriptBox["a", "."], "2"]}], 
     SuperscriptBox["a", "2"]], "-", 
    FractionBox[
     RowBox[{"2", " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], "a"], "+", 
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
