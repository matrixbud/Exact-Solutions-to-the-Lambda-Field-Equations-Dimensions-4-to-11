   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "1"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{
        SubscriptBox["\"\<R\>\"", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
         ",", 
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesKr"}], 
