Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \[GothicCapitalD](r) = Exp[\\!\\(\\*SubsuperscriptBox[\\(\
\[Integral]\\), \\(1\\), \\(r\\)]\\)(\"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"2", " ", 
       RowBox[{"\[GothicCapitalC]", "[", "\[Rho]", "]"}]}], 
      RowBox[{"\[Rho]", " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"2", " ", 
          RowBox[{"\[GothicCapitalC]", "[", "\[Rho]", "]"}]}], "+", 
         RowBox[{"\[Rho]", " ", 
          RowBox[{
           SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
            MultilineFunction->None], "[", "\[Rho]", "]"}]}]}], ")"}]}]]}], "-", 
    FractionBox[
     RowBox[{"2", " ", 
      RowBox[{
       SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
        MultilineFunction->None], "[", "\[Rho]", "]"}]}], 
     RowBox[{
      RowBox[{"2", " ", 
       RowBox[{"\[GothicCapitalC]", "[", "\[Rho]", "]"}]}], "+", 
      RowBox[{"\[Rho]", " ", 
       RowBox[{
        SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
         MultilineFunction->None], "[", "\[Rho]", "]"}]}]}]], "-", 
    FractionBox[
     RowBox[{"\[Rho]", " ", 
      SuperscriptBox[
       RowBox[{
        SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
         MultilineFunction->None], "[", "\[Rho]", "]"}], "2"]}], 
     RowBox[{"2", " ", 
      RowBox[{"\[GothicCapitalC]", "[", "\[Rho]", "]"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"2", " ", 
         RowBox[{"\[GothicCapitalC]", "[", "\[Rho]", "]"}]}], "+", 
        RowBox[{"\[Rho]", " ", 
         RowBox[{
          SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
           MultilineFunction->None], "[", "\[Rho]", "]"}]}]}], ")"}]}]]}], 
   "\[InvisibleSpace]", "\<\")\[DifferentialD]\[Rho]\"\>"}],
  SequenceForm[
  "     \[GothicCapitalD](r) = Exp[\!\(\*SubsuperscriptBox[\(\[Integral]\), \
\(1\), \(r\)]\)(", (-2) $CellContext`\[Rho]^(-1) $CellContext`\
\[GothicCapitalC][$CellContext`\[Rho]]/(
    2 $CellContext`\[GothicCapitalC][$CellContext`\[Rho]] + $CellContext`\
\[Rho] Derivative[1][$CellContext`\[GothicCapitalC]][$CellContext`\[Rho]]) - 
