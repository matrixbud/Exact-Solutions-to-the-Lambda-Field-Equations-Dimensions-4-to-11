Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Mu]", "=."}], ";", 
  RowBox[{"\[Nu]", "=."}], ";", 
  RowBox[{"\[Sigma]", "=."}], ";"}], "\n", 
 RowBox[{
  RowBox[{
  "Print", "[", "\"\<Geodesic Equations for a free particle with mass in the \
rotating frame K:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{"\"\<     \>\"", ",", 
     RowBox[{"Style", "[", 
      RowBox[{
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          
          SuperscriptBox["\"\<\!\(\*OverscriptBox[\(x\), \(\[DoubleDot]\)]\)\
\[InvisibleSpace]\>\"", "\[Mu]"], ",", "\"\< + \>\"", ",", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{
             SubsuperscriptBox["\[CapitalGamma]", 
              RowBox[{"Row", "[", 
               RowBox[{"{", 
                RowBox[{"\[Nu]", ",", "\[Sigma]"}], "}"}], "]"}], "\[Mu]"], ",", 
             
             SuperscriptBox["\"\<\!\(\*OverscriptBox[\(x\), \(.\)]\)\>\"", 
              "\[Nu]"], ",", 
             SuperscriptBox[
              OverscriptBox["\"\<x\>\"", "."], "\[Sigma]"]}], "}"}], "]"}], ",",
           "\n", "\"\< = 0\>\""}], "}"}], "]"}], ",", "Bold", ",", "Blue"}], 
      "]"}]}], "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
   "Print", "[", "\"\<where \!\(\*OverscriptBox[\(x\), \
\(\[DoubleDot]\)]\)\!\(\*SuperscriptBox[\(\[InvisibleSpace]\), \(\[Mu]\)]\), \
\!\(\*SuperscriptBox[OverscriptBox[\"x\", \".\"], \
FormBox[StyleBox[\"\[Nu]\",FontFamily->\"Symbol\",FontWeight->\"Regular\"],\
TraditionalForm]]\) and \!\(\*SuperscriptBox[OverscriptBox[\(x\), \(.\)], \(\
\[Sigma]\)]\) are differentiation wrt proper time \[Tau] and \
\!\(\*SuperscriptBox[StyleBox[\"A\",FontSize->12], StyleBox[FormBox[StyleBox[\
\"\[Prime]\",FontSize->14,FontWeight->\"Regular\",FontSlant->\"Plain\"],\
TraditionalForm],FontSize->2]]\) and \
\!\(\*SuperscriptBox[StyleBox[\"B\",FontSize->12], StyleBox[FormBox[StyleBox[\
\"\[Prime]\",FontSize->14,FontWeight->\"Regular\",FontSlant->\"Plain\"],\
TraditionalForm],FontSize->2]]\) are \ndifferentiation wrt r. \>\"", "]"}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[CapitalGamma]dd", "[", 
     RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"\[CapitalGamma]", "[", 
        RowBox[{"\[Mu]", ",", "\[Nu]", ",", "\[Gamma]"}], "]"}], " ", 
       RowBox[{
        SuperscriptBox["\[ScriptX]", "\[Prime]",
         MultilineFunction->None], "[", "\[Nu]", "]"}], " ", 
       RowBox[{
        SuperscriptBox["\[ScriptX]", "\[Prime]",
         MultilineFunction->None], "[", "\[Gamma]", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Gamma]", ",", "dimL", ",", "dimH"}], "}"}]}], "]"}]}], 
   ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gammadd", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"\[CapitalGamma]dd", "[", 
       RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Mu]", ",", "dimL", ",", "dimH"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Nu]", ",", "dimL", ",", "dimH"}], "}"}]}], "]"}]}], ";"}], 
  " ", "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"eqGeo", "[", "\[Mu]_", "]"}], ":=", " ", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{"\[CapitalGamma]dd", "[", 
      RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Nu]", ",", "dimL", ",", "dimH"}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"\[Mu]", "=", " ", "dimL"}], ",", 
   RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
   RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<(\>\"", ",", "index1", ",", "\"\<=\>\"", ",", "\[Mu]", 
     ",", "\"\<): \>\"", ",", " ", "\n", 
     RowBox[{
      RowBox[{"Text", "[", 
       RowBox[{
        SuperscriptBox["\[ScriptX]", "\[Prime]\[Prime]"], "[", "\[Mu]", "]"}],
        "]"}], "//.", "rulesCoord"}], ",", "\"\< + \>\"", ",", 
     RowBox[{
      RowBox[{
       RowBox[{"xS", "[", 
        RowBox[{"eqGeo", "[", "\[Mu]", "]"}], "]"}], "//.", "rulesCoord"}], 
      "\n", "/.", "rulesDisp"}], ",", "\"\< = 0\>\""}], "]"}]}], 
  "]"}]}], "Input",
 InitializationCell->False,
 CellChangeTimes->{
