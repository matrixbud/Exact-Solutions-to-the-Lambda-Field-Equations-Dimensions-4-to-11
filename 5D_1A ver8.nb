         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ls01", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"a", "[", "t", "]"}], 
        RowBox[{
         RowBox[{"a", "'"}], "[", "t", "]"}]], 
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "1"}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Since a(t) is not allowed to be constant in Case 1A, \
\!\(\*FractionBox[OverscriptBox[\(a\), \(.\)], \(a\)]\) can be factored out, \
simplifying \!\(\*SubscriptBox[\(R\), \(01\)]\), which can then be \
solved:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(01\)]\):  \>\"", ",", 
      RowBox[{"ls01", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"0", ",", "1"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{"ls01", "==", "0"}], ",", 
        RowBox[{"A", "[", 
         RowBox[{"t", ",", "r"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "r"}], "}"}]}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[ScriptCapitalA]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     A[t,r] = \>\"", ",", 
      RowBox[{"A", "[", 
       RowBox[{"t", ",", "r"}], "]"}], 
      ",", "\"\<  where \[ScriptCapitalA](t) is a new unknown.\>\""}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<This eliminates \!\(\*SubscriptBox[\(R\), \(01\)]\), \
and the remaining equations become\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";", 
    RowBox[{
    "Print", "[", "\"\<I found that I could \
\!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) solve \
4\!\(\*SubscriptBox[\(R\), \(00\)]\)-\!\(\*SubscriptBox[\(R\), \(11\)]\) for \
\[CapitalBeta], \!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) \
solve either \!\(\*SubscriptBox[\(R\), \(00\)]\)-3\!\(\*SubscriptBox[\(R\), \
\(22\)]\), \!\(\*SubscriptBox[\(R\), \(00\)]\)-3\!\(\*SubscriptBox[\(R\), \
\(44\)]\), or 4\!\(\*SubscriptBox[\(R\), \(00\)]\)-\!\(\*SubscriptBox[\(R\), \
\(11\)]\)-12\!\(\*SubscriptBox[\(R\), \(44\)]\) for \[ScriptCapitalA], Dsolve \
\!\(\*SubscriptBox[\(R\), \(11\)]\) or \!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\
\(\*SubscriptBox[\(R\), \(44\)]\) for \[CapitalBeta], or DSolve \
3\!\(\*SubscriptBox[\(R\), \(11\)]\)+4\!\(\*SubscriptBox[\(R\), \(22\)]\)-4\!\
\(\*SubscriptBox[\(R\), \(44\)]\) for either \[CapitalBeta] or \
\[GothicCapitalD], but all these attempts failed to generate useful \
equations.\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs024", "=", 
     RowBox[{"Expand", "[", 
