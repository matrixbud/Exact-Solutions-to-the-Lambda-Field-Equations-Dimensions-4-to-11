    SuperscriptBox["\[CapitalBeta]", "2"]], "+", 
   RowBox[{
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["\[GothicCapitalD]", "\[Prime]\[Prime]",
