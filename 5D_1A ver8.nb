               RowBox[{
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "===", "0"}]}], 
              ")"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
              SubscriptBox["\"\<R\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
              ",", "\"\<:  \>\"", ",", 
              RowBox[{
               RowBox[{"lhs", "[", 
