 InterpretationBox[
  RowBox[{"\<\"     \[CapitalBeta][r] = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{
     SuperscriptBox["r", "4"], " ", 
     SuperscriptBox["\[GothicCapitalC]", "2"], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox["\[GothicCapitalD]", "\[Prime]",
        MultilineFunction->None], ")"}], "2"]}], 
    RowBox[{"\[Alpha]", "-", 
     TemplateBox[{
       RowBox[{
         RowBox[{"-", 
           FractionBox["1", "2"]}], " ", 
         SuperscriptBox["\[GothicCapitalC]", "2"], " ", 
         RowBox[{"(", 
           RowBox[{"\[Kappa]", "-", 
             
             RowBox[{"8", " ", "\[GothicCapitalD]", " ", 
