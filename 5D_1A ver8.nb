   RowBox[{
    RowBox[{"lhs024", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"3", 
        RowBox[{"lhs", "[", 
         RowBox[{"0", ",", "0"}], "]"}]}], "-", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}], "-", 
       RowBox[{"lhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs024", "=", 
     RowBox[{
      RowBox[{"3", 
       RowBox[{"rhs", "[", 
