   RowBox[{
    RowBox[{
     RowBox[{"B", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[DoubleStruckCapitalC]", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<I am able below to solve (with difficulty) for A and B \
and reduce the field equations down to 2 equations in 2 unknowns, but I \
couldn't proceed any further. The reader may wish to skip to the next \
section.\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<The field equations begin with:\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"R", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", 
               RowBox[{"\[CapitalLambda]", " ", 
                RowBox[{"g", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ")"}]}], ",", 
            "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
              SubscriptBox["\"\<R\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
              ",", "\"\<:  \>\"", ",", 
              RowBox[{
               RowBox[{"lhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
              ",", "\"\< = \>\"", ",", 
              RowBox[{"rhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ls01", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         RowBox[{"2", 
          RowBox[{"a", "[", "t", "]"}]}], 
         RowBox[{
          RowBox[{"a", "'"}], "[", "t", "]"}]]}], 
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "1"}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(01\)]\) can be simplified \
and then solved for A:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(01\)]\):  \>\"", ",", 
      RowBox[{"ls01", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"0", ",", "1"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}]}], ",", 
        RowBox[{"A", "[", 
         RowBox[{"t", ",", "r"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "r"}], "}"}]}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[ScriptCapitalA]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     A(t,r) = \>\"", ",", 
      RowBox[{"A", "[", 
       RowBox[{"t", ",", "r"}], "]"}], 
      ",", "\"\<  where \[ScriptCapitalA](t) is a new unknown.\>\""}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<The equations now become\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ls", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"0", ",", "0"}], "]"}]}], "-", 
       RowBox[{"lhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "+", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rs", "=", 
     RowBox[{
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}]}], "-", 
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], "+", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(44\)]\) has become \
redundant, the same as \!\(\*SubscriptBox[\(R\), \(00\)]\).\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<2\!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(11\)]\)+2\!\(\*SubscriptBox[\(R\), \(22\
\)]\) can be \!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) solved \
for \[CapitalBeta]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     2\!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(11\)]\)+2\!\(\*SubscriptBox[\(R\), \(22\
\)]\):  \>\"", ",", 
      RowBox[{"ls", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", "rs"}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Unfortunately, the formula for \[CapitalBeta](r) is \
lengthy and makes the equations much worse when plugging back in, so we try a \
different approach.\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "\[CapitalBeta]", "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], ",", 
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[Gamma]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Instead of solving 2\!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(11\)]\)+2\!\(\*SubscriptBox[\(R\), \(22\
\)]\), we can solve \!\(\*SubscriptBox[\(R\), \(00\)]\) for \[ScriptCapitalA] \
or \[CapitalBeta] (but not \[GothicCapitalD]). Solving for \[CapitalBeta] \
results in unsolvable equations. However, solving for \[ScriptCapitalA] is \
more productive:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptCapitalA](t) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesDisp"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<            where \[Gamma] is a constant of \
integration\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"den", "=", 
     RowBox[{"xS", "[", 
      FractionBox[
       RowBox[{"Denominator", "[", 
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "]"}], 
       RowBox[{"r", " ", 
        RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], 
        SuperscriptBox[
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "2"]}]], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Observe that the numerator divided by r \
\[GothicCapitalC] \!\(\*SuperscriptBox[\(\[CapitalBeta]\), \(2\)]\) is \
strictly a function of t. In order for the whole expression to be strictly a \
function of t, the denominator divided by r \[GothicCapitalC] \
\!\(\*SuperscriptBox[\(\[CapitalBeta]\), \(2\)]\) must also equal some \
function of t, say \[ScriptF](t).\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*FractionBox[\(Denominator\), \(r\\\ \
\[GothicCapitalC]\\\ \*SuperscriptBox[\(\[CapitalBeta]\), \(2\)]\)]\) = \
\[ScriptF](t):  \>\"", ",", 
      RowBox[{"den", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"\[ScriptF]", "[", "t", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"Simplify", "[", 
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"den", "==", 
          RowBox[{"\[ScriptF]", "[", "t", "]"}]}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", "r"}], "]"}], "]"}], 
      "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can solve this equation for \[CapitalBeta](r):\>\"",
      "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[CapitalBeta][r] = \>\"", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesKr"}], "/.", 
       "rulesDisp"}], 
      ",", "\"\<    where \[Alpha] is a constant of integration.\>\""}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     RowBox[{"xS", "[", 
      RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[ScriptCapitalA]hold", "=", 
     RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<This formula for \[CapitalBeta](r) makes the equations \
unwieldy when it is plugged back in, so we don't use it. It's existence is \
sufficient to show that the equation\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \!\(\*FractionBox[\(Denominator\), \(r\\\ \
\[GothicCapitalC]\\\ \*SuperscriptBox[\(\[CapitalBeta]\), \(2\)]\)]\) = \
\[ScriptF](t)\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<is solvable. This means that \[ScriptCapitalA](t) can \
(again) be compactly expressed as\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptCapitalA](t) = \
\!\(\*FractionBox[\(Numerator\), \(Denominator\)]\) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesDisp"}], 
      ",", "\"\<.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", 
    RowBox[{"\[CapitalBeta]", ",", "\[ScriptCapitalA]"}], "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     "\[ScriptCapitalA]hold"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Plugging \[ScriptCapitalA] back into the equations \
should make \!\(\*SubscriptBox[\(R\), \(00\)]\) into the identity, 0=0, but \
it doesn't because we have suppessed the formula for \[CapitalBeta]:\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(00\)]\):  \>\"", ",", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "/.", "rulesDisp"}], 
      ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"0", ",", "0"}], "]"}], ",", "\"\<.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptF]", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"\[ScriptF]", "'"}], "[", "t", "]"}], "==", 
         RowBox[{"\[Kappa]", " ", 
          RowBox[{"a", "[", "t", "]"}], 
          RowBox[{
           RowBox[{"a", "'"}], "[", "t", "]"}]}]}], ",", 
        RowBox[{"\[ScriptF]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[Zeta]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can restore \!\(\*SubscriptBox[\(R\), \(00\)]\) as \
an identity if we eliminate t from \!\(\*SubscriptBox[\(R\), \(00\)]\) and \
then re-solve for \[CapitalBeta](r). We eliminate t by solving \
\!\(\*OverscriptBox[\(\[ScriptF]\), \(.\)]\) = \[Kappa] a \
\!\(\*OverscriptBox[\(a\), \(.\)]\), where \[Kappa] is a proportionality \
constant:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptF](t) = \>\"", ",", 
      RowBox[{"\[ScriptF]", "[", "t", "]"}], 
      ",", "\"\<  where \[Zeta] is a constant of integration.\>\""}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\[ScriptCapitalA](t) is now clearly seen to be a \
strict function of t,\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptCapitalA](t) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesLE"}], 
      ",", "\"\<,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<and \!\(\*SubscriptBox[\(R\), \(00\)]\) becomes\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(00\)]\):  \>\"", ",", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "/.", "rulesDisp"}], 
      ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"0", ",", "0"}], "]"}], ",", "\"\<.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"Simplify", "[", 
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}]}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", "r"}], "]"}], "]"}], 
      "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<When we re-solve \!\(\*SubscriptBox[\(R\), \(00\)]\) \
for \[CapitalBeta](r), we obtain the desired simplified \[CapitalBeta](r) \
formula, one that has constant \[Kappa] instead of the \[ScriptF](t) \
function:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[CapitalBeta][r] = \>\"", ",", 
      RowBox[{
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesKr"}], "/.", 
       "rulesDisp"}], ",", "\"\<  where \[Alpha] and \>\"", ",", "\[Kappa]", 
      ",", "\"\< are constants of integration.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Plugging this simplified version of \[CapitalBeta] \
into the equations shows that \!\(\*SubscriptBox[\(R\), \(00\)]\) is indeed \
an identity and, in fact, so is \!\(\*SubscriptBox[\(R\), \(44\)]\).\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"\[Mu]", "<", "1"}], "||", 
         RowBox[{"\[Mu]", ">", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<However, \!\(\*SubscriptBox[\(R\), \(11\)]\) and \
\!\(\*SubscriptBox[\(R\), \(22\)]\) have many terms and also include the \
\[CapitalBeta](r) integral. The simplest combination of the equations is \!\(\
\*SubscriptBox[\(R\), \(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\) and even \
it has 6 terms involving the integral plus 8 more terms.\>\"", "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<I reduced this to 2 equations in 2 unknowns but was \
unable to solve the case. In order to solve \!\(\*SubscriptBox[\(R\), \(11\)]\
\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\), I require one more simplification, \
\[GothicCapitalC](r)=1, which is Case bi, analyzed below after Case b_II, and \
it is solved starting from scratch.\>\"", "]"}], ";"}], "\[IndentingNewLine]",
    "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", 
    RowBox[{
    "A", ",", "\[ScriptCapitalA]", ",", "B", ",", "\[CapitalBeta]", ",", 
