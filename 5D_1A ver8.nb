   RowBox[{
    RowBox[{"integ", "=", 
     RowBox[{"Activate", "[", 
      TemplateBox[{
        RowBox[{
          FractionBox["1", "2"], " ", 
          SuperscriptBox["\[Rho]", "3"], " ", 
          RowBox[{"(", 
