   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     SuperscriptBox[
      RowBox[{"a", "[", "t", "]"}], "2"]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"B", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[DoubleStruckCapitalC]", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Restarting Case b from scratch using these \
constraints, the field equations become:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", " ", 
           RowBox[{
            RowBox[{"x_", "[", "s_", "]"}], "->", "x"}]}], ",", "\"\< = \>\"",
           ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", " ", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solA", "=", 
     RowBox[{
      RowBox[{"DSolve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], ",", 
        RowBox[{"a", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         SqrtBox[
          RowBox[{"C", "[", "1", "]"}]], "->", "\[CapitalKappa]"}], ",", 
        RowBox[{
         RowBox[{"C", "[", "2", "]"}], "->", 
         RowBox[{"\[Zeta]", "/", "\[CapitalKappa]"}]}]}], "}"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"a", "[", "t", "]"}], "/.", 
      RowBox[{"Last", "[", 
       RowBox[{"PowerExpand", "[", 
        RowBox[{"Simplify", "[", "solA", "]"}], "]"}], "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(01\)]\) does not appear \
because we have assumed B(t,r) = \[CapitalBeta](r), which is the solution to \
\!\(\*SubscriptBox[\(R\), \(01\)]\).\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(00\)]\) for \
a(t):\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \[PlusMinus]\>\"", ",", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{"Simplify", "[", 
        RowBox[{"a", "[", "t", "]"}], "]"}], "]"}], 
      ",", "\"\<  where \[CapitalKappa] and \[Zeta] are constants of \
integration.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<This changes the first term of \
\!\(\*SubscriptBox[\(R\), \(44\)]\) so that we can easily solve it for \
\[CapitalBeta]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     lhs[4,4] = \>\"", ",", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}], "/.", "rulesDisp"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"solB", "=", 
     RowBox[{"DSolve", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}], "==", 
        RowBox[{"rhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}], ",", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", "r"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{
