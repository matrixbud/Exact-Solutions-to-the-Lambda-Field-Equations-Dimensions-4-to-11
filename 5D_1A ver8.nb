Cell[BoxData["\<\"\[ScriptCapitalA](t) is now clearly seen to be a strict \
function of t,\"\>"], "Print",
 CellChangeTimes->{3.980535116151064*^9},
 CellLabel->
  "During evaluation of \
In[16561]:=",ExpressionUUID->"ad4e6ea0-91ef-44c9-b469-2f3e617fae31"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \[ScriptCapitalA](t) = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"4", " ", 
     SuperscriptBox["c", "2"], " ", 
     SuperscriptBox[
      RowBox[{
       OverscriptBox["a", "."], "[", "t", "]"}], "2"]}], 
    RowBox[{"\[Zeta]", "+", 
     RowBox[{
      FractionBox["1", "2"], " ", "\[Kappa]", " ", 
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"]}]}]], 
   "\[InvisibleSpace]", "\<\",\"\>"}],
  SequenceForm[
  "     \[ScriptCapitalA](t) = ", 
   4 $CellContext`c^2 ($CellContext`\[Zeta] + 
     Rational[1, 
        2] $CellContext`\[Kappa] $CellContext`a[$CellContext`t]^2)^(-1) 
   OverDot[$CellContext`a, 1][$CellContext`t]^2, ","],
  Editable->False]], "Print",
 CellChangeTimes->{3.980535116151662*^9},
 CellLabel->
