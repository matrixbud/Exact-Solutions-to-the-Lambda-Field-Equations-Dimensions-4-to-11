      RowBox[{"a", "[", "t", "]"}], "2"]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We try to solve Case c again, but with the stronger \
extra condition that A(t,r)=\!\(\*SuperscriptBox[\(c\), \(2\)]\).\>\"", "]"}],
     ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Starting again from scratch, the field equations \
become\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"R", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], "&&", 
               RowBox[{
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "===", "0"}]}], 
              ")"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
              SubscriptBox["\"\<R\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
              ",", "\"\<:  \>\"", ",", 
              RowBox[{
               RowBox[{"lhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
              ",", "\"\< = \>\"", ",", 
              RowBox[{"rhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], ",", 
        RowBox[{"a", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}], ",", 
        RowBox[{
         RowBox[{"C", "[", "2", "]"}], "->", "\[Beta]"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"aSave", "=", 
     RowBox[{"a", "[", "t", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Solving \!\(\*SubscriptBox[\(R\), \(00\)]\) yields\>\"",
      "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \>\"", ",", 
      RowBox[{"a", "[", "t", "]"}], 
      ",", "\"\<  where \[Alpha] and \[Beta] are constants of \
integration.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "a", "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<It is easier for now to work with a(t) rather than its \
fomula, noting just that \!\(\*SubscriptBox[\(R\), \(00\)]\) is an identity \
and can be ignored.\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ls01", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         RowBox[{"2", 
          RowBox[{"a", "[", "t", "]"}]}], 
         RowBox[{
          RowBox[{"a", "'"}], "[", "t", "]"}]]}], 
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "1"}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(01\)]\) can be simplified \
and then solved for \[GothicCapitalD]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(01\)]\):  \>\"", ",", 
      RowBox[{"ls01", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"0", ",", "1"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[GothicCapitalD]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}]}], ",", 
        RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], ",", "r"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "k"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[GothicCapitalD](r) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], "/.", "rulesDisp"}], 
      ",", "\"\<  where k is a constant of integration.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(01\)]\) is now also an \
identity. Plugging in \[GothicCapitalD](r), the remaining equations \
become\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "1"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
