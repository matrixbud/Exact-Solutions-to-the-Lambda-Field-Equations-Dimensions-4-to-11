       RowBox[{"\[CapitalAlpha]", "[", "r", "]"}], "/.", "rulesLE"}]}], "]"}],
     ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "t_", "]"}], "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"a", "[", "t", "]"}], "/.", 
        RowBox[{"First", "[", 
         RowBox[{"DSolve", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
