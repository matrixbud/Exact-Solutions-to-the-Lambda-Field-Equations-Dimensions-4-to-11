     SuperscriptBox["\[CapitalBeta]", "2"], " ", 
     SuperscriptBox[
      OverscriptBox["a", "."], "2"]}], 
    RowBox[{
     RowBox[{"4", " ", 
      SuperscriptBox["a", "2"], " ", "r", " ", "\[GothicCapitalD]", " ", 
      SuperscriptBox["\[CapitalBeta]", "2"], " ", "\[CapitalLambda]"}], "+", 
     RowBox[{"4", " ", 
      SuperscriptBox["c", "2"], " ", "r", " ", 
