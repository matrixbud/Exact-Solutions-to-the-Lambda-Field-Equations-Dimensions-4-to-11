    "Print", "[", "\"\<Now we can \
\!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) solve for \
\[CapitalAlpha]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     3\!\(\*SubscriptBox[\(R\), \
\(00\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \(44\
\)]\):  \>\"", ",", 
      RowBox[{"lhs024", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      "rhs024"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalAlpha]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"\[CapitalAlpha]", "[", "r", "]"}], "/.", 
      RowBox[{"Last", "[", 
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"lhs024", "==", "rhs024"}], ",", 
         RowBox[{"\[CapitalAlpha]", "[", "r", "]"}]}], "]"}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\< \[Implies]  \[CapitalAlpha](r) = \>\"", ",", 
