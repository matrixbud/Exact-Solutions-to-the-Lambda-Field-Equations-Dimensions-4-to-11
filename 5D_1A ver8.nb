Cell[BoxData["\<\"In order for \[CapitalBeta](r) to strictly be a function of \
r, the t terms in the denominator must disappear. There are no terms in the \
numerator to cancel them out, so the denominator terms must be \
self-canceling. It turns out they are. Call the denominator expression in the \
parentheses p(t,r):\"\>"], "Print",
 CellChangeTimes->{3.980535110220171*^9},
 CellLabel->
  "During evaluation of \
In[16561]:=",ExpressionUUID->"057ef0fd-542c-4dfe-95c4-e04aa216467d"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     p(t,r) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", "1"}], "+", 
    RowBox[{
     SuperscriptBox["a", "2"], " ", 
     SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]", " ", 
     "\[CapitalLambda]"}], "-", 
    RowBox[{"3", " ", 
     SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]", " ", 
     SuperscriptBox[
      OverscriptBox["a", "."], "2"]}], "-", 
    RowBox[{"a", " ", 
     SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]", " ", 
     OverscriptBox["a", "\[DoubleDot]"]}]}]}],
  SequenceForm[
  "     p(t,r) = ", -1 + $CellContext`a^2 $CellContext`r^2 $CellContext`\
\[GothicCapitalC] $CellContext`\[CapitalLambda] - 
   3 $CellContext`r^2 $CellContext`\[GothicCapitalC] 
   OverDot[$CellContext`a, 
      1]^2 - $CellContext`a $CellContext`r^2 $CellContext`\[GothicCapitalC] 
   OverDot[$CellContext`a, 2]],
  Editable->False]], "Print",
