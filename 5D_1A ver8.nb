    "Print", "[", "\"\<\[Bullet] A(t,r), B(t,r) and \
\[DoubleStruckCapitalC](t,r): Both solutions use the same formulas \
\[Checkmark]\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
