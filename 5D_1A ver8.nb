   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<What works is to solve 3\!\(\*SubscriptBox[\(R\), \(00\
\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \
\(44\)]\) for \[ScriptCapitalA]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     3\!\(\*SubscriptBox[\(R\), \
\(00\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \(44\
\)]\):  \>\"", ",", 
      RowBox[{"lhs024", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      "rhs024"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{"lhs024", "==", "rhs024"}], ",", 
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "k"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptCapitalA](t) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesDisp"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<In order for \[ScriptCapitalA](t) to be strictly a \
function of t, \!\(\*SuperscriptBox[\(\[GothicCapitalD]\), \(1/3\)]\) \
\[Proportional] \!\(\*SuperscriptBox[\(r\), \(2/3\)]\); that is\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[GothicCapitalD](r) = \!\(\*SuperscriptBox[\(\
\[CapitalKappa]\), \(3\)]\) \!\(\*SuperscriptBox[\(r\), \(2\)]\) for some \
proportionality constant \[CapitalKappa].\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[GothicCapitalD]", "[", "r_", "]"}], "=", 
     RowBox[{
      SuperscriptBox["\[CapitalKappa]", "3"], " ", 
      SuperscriptBox["r", "2"]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     RowBox[{"Simplify", "[", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "]"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Using this formula, \[ScriptCapitalA](t) clearly \
becomes a strict function of t:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptCapitalA](t) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesLE"}]}], 
