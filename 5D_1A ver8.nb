               RowBox[{"a", "''"}], "[", "t", "]"}]}]}], "==", "K"}], ",", 
           RowBox[{"a", "[", "t", "]"}], ",", "t"}], "]"}], "]"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"C", "[", "1", "]"}], "->", 
