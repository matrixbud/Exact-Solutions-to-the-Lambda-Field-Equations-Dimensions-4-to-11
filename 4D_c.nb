             SuperscriptBox["r", "2"], " ", 
             SuperscriptBox[
              RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], 
            RowBox[{"2", " ", "\[CapitalBeta]"}]], "+", 
           FractionBox[
            RowBox[{"\[CapitalPhi]", " ", 
             SuperscriptBox[
              RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], 
            "\[CapitalBeta]"], "-", 
           FractionBox[
            RowBox[{"2", " ", 
             SuperscriptBox["c", "2"], " ", 
             SuperscriptBox["r", "2"], " ", "\[CapitalPhi]", " ", 
             SuperscriptBox[
              OverscriptBox["a", "."], "2"], " ", 
             SuperscriptBox[
              RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "A"], "+", 
           FractionBox[
            RowBox[{"a", " ", 
             SuperscriptBox["c", "2"], " ", 
             SuperscriptBox["r", "2"], " ", "\[CapitalPhi]", " ", 
             OverscriptBox["a", "."], " ", 
             OverscriptBox["A", "."], " ", 
             SuperscriptBox[
              RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], 
            RowBox[{"2", " ", 
             SuperscriptBox["A", "2"]}]], "-", 
           FractionBox[
            RowBox[{"a", " ", 
             SuperscriptBox["c", "2"], " ", 
             SuperscriptBox["r", "2"], " ", "\[CapitalPhi]", " ", 
             OverscriptBox["a", "\[DoubleDot]"], " ", 
             SuperscriptBox[
              RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "A"], "+", 
           FractionBox[
            RowBox[{"r", " ", "\[CapitalPhi]", " ", 
             SuperscriptBox[
              RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
             SuperscriptBox["A", "\[Prime]",
              MultilineFunction->None]}], 
            RowBox[{"2", " ", "A", " ", "\[CapitalBeta]"}]], "-", 
           FractionBox[
            RowBox[{"r", " ", "\[CapitalPhi]", " ", 
             SuperscriptBox[
              RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
             SuperscriptBox["\[CapitalBeta]", "\[Prime]",
              MultilineFunction->None]}], 
            RowBox[{"2", " ", 
             SuperscriptBox["\[CapitalBeta]", "2"]}]], "+", 
           FractionBox[
            RowBox[{"2", " ", "r", " ", 
             SuperscriptBox[
              RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
             SuperscriptBox["\[CapitalPhi]", "\[Prime]",
              MultilineFunction->None]}], "\[CapitalBeta]"], "+", 
           FractionBox[
            RowBox[{
             SuperscriptBox["r", "2"], " ", 
             SuperscriptBox[
              RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
             SuperscriptBox["A", "\[Prime]",
              MultilineFunction->None], " ", 
             SuperscriptBox["\[CapitalPhi]", "\[Prime]",
              MultilineFunction->None]}], 
            RowBox[{"4", " ", "A", " ", "\[CapitalBeta]"}]], "-", 
           FractionBox[
            RowBox[{
             SuperscriptBox["r", "2"], " ", 
             SuperscriptBox[
              RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
             SuperscriptBox["\[CapitalBeta]", "\[Prime]",
              MultilineFunction->None], " ", 
             SuperscriptBox["\[CapitalPhi]", "\[Prime]",
              MultilineFunction->None]}], 
            RowBox[{"4", " ", 
             SuperscriptBox["\[CapitalBeta]", "2"]}]]}]}
