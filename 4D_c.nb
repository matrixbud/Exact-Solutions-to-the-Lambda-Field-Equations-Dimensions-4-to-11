Cell[BoxData[{
 RowBox[{
  RowBox[{"lineElem", ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "firstElem", ",", "g\[Mu]\[Nu]", ",", "gzero", ",", "x\[Mu]", ",", 
       "x\[Nu]", ",", "dx\[Mu]", ",", "dx\[Nu]", ",", "negSign", ",", 
       "factor", ",", "\n", "plus", ",", "nextTerm", ",", "lineElem"}], "}"}],
      ",", "\n", "\n", 
     RowBox[{
      RowBox[{
      "lineElem", "=", "\"\<\!\(\*SuperscriptBox[\(ds\), \(2\)]\) = \>\""}], ";",
       "\n", 
      RowBox[{"firstElem", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"\[Mu]", "=", "dimL"}], ",", 
        RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
        RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "dimL"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"g", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], ",", 
             RowBox[{"gzero", "=", "0"}], ",", 
             RowBox[{"gzero", "=", "1"}], ",", 
             RowBox[{"gzero", "=", "1"}]}], "]"}], ";", " ", 
           RowBox[{"(*", " ", 
            RowBox[{
             RowBox[{"1", " ", "means", " ", 
              SubscriptBox["g", "\[Mu]\[Nu]"]}], "\[NotEqual]", "0"}], " ", 
            "*)"}], "\n", "\n", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"gzero", "==", "1"}], ",", "  ", 
             RowBox[{"(*", " ", 
              RowBox[{
               RowBox[{"If", " ", "there", " ", "is", " ", "a", " ", "non"}], 
               "-", 
               RowBox[{"zero", " ", 
                SubscriptBox["g", "\[Mu]\[Nu]"], " ", "term", " ", "to", " ", 
                "print"}]}], " ", "*)"}], "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"g\[Mu]\[Nu]", "=", 
               RowBox[{"g", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"x\[Mu]", "=", 
               RowBox[{"ToString", "[", 
                RowBox[{"\[ScriptX]", "[", "\[Mu]", "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"x\[Nu]", "=", 
               RowBox[{"ToString", "[", 
                RowBox[{"\[ScriptX]", "[", "\[Nu]", "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"dx\[Mu]", "=", 
               RowBox[{"\"\<d\>\"", "<>", "x\[Mu]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"dx\[Nu]", "=", 
               RowBox[{"\"\<d\>\"", "<>", "x\[Nu]"}]}], ";", 
              "\[IndentingNewLine]", "\n", 
              RowBox[{"negSign", "=", 
               RowBox[{"g\[Mu]\[Nu]", "/.", " ", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Times", "[", 
                    RowBox[{
                    RowBox[{"c_", "?", "NumericQ"}], ",", "___"}], "]"}], ":>", 
                   RowBox[{"c", "<", "0"}]}], ",", 
                  RowBox[{"_Times", ":>", "False"}]}], "}"}]}]}], ";", " ", 
              "\n", "\t", 
              RowBox[{"(*", " ", 
               RowBox[{
                RowBox[{"=", " ", 
                 RowBox[{
                 "True", " ", "if", " ", "g\[Mu]\[Nu]", " ", "starts", " ", 
                  "with", " ", "neg", " ", "sign"}]}], ",", "  ", 
                RowBox[{"random", " ", "values", " ", 
                 RowBox[{"o", ".", "w", "."}]}]}], " ", "*)"}], 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Head", "[", "g\[Mu]\[Nu]", "]"}], "===", 
                 "Integer"}], ",", 
                RowBox[{
                 RowBox[{"negSign", "=", "False"}], ";", " ", 
                 "\[IndentingNewLine]", "\t", 
                 RowBox[{"(*", " ", 
                  RowBox[{
                   RowBox[{"Special", " ", 
                    RowBox[{"case", ":", " ", 
                    RowBox[{"give", " ", "g\[Mu]\[Nu]"}]}]}], " ", "=", " ", 
                   RowBox[{"1", " ", "a", " ", "False", " ", "value"}]}], 
                  "  ", "*)"}], "\n", "\t", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"g\[Mu]\[Nu]", "<", "0"}], ",", 
                   RowBox[{"negSign", "=", "True"}]}], "]"}]}]}], 
               "\[IndentingNewLine]", "\t", 
               RowBox[{"(*", " ", 
                RowBox[{
                 RowBox[{"Special", " ", 
                  RowBox[{"case", ":", " ", 
                   RowBox[{"give", " ", "g\[Mu]\[Nu]"}]}]}], "=", " ", 
                 RowBox[{
                  RowBox[{"-", "1"}], " ", "a", " ", "True", " ", "value"}]}],
                 "  ", "*)"}], "\[IndentingNewLine]", "]"}], ";", "\n", "\n", 
              
              RowBox[{"factor", "=", "1"}], ";", "\[IndentingNewLine]", "\t", 
              
              RowBox[{"(*", " ", 
               RowBox[{
               "Factor", " ", "to", " ", "prevent", " ", "g\[Mu]\[Nu]", " ", 
                "from", " ", "being", " ", "negative", " ", "in", " ", 
                "nextTerm"}], " ", "*)"}], "\[IndentingNewLine]", "\n", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"negSign", "===", "True"}], ",", 
                "\[IndentingNewLine]", 
                RowBox[{
                 RowBox[{"plus", "=", "\"\< - \>\""}], ";", 
                 RowBox[{"factor", "=", 
                  RowBox[{"-", "1"}]}]}], ",", "\[IndentingNewLine]", 
                RowBox[{"plus", "=", "\"\< + \>\""}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"firstElem", "==", "1"}], ",", 
                RowBox[{
                 RowBox[{"firstElem", "=", "0"}], ";", 
                 RowBox[{"g\[Mu]\[Nu]", "=", 
                  RowBox[{
                   SuperscriptBox["c", "2"], 
                   RowBox[{"g", "[", 
                    RowBox[{"0", ",", "0"}], "]"}]}]}], ";", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"plus", "==", "\"\< + \>\""}], ",", 
                   RowBox[{"plus", "=", "\"\<\>\""}]}], "]"}]}]}], "]"}], ";",
               "\[IndentingNewLine]", "\t", 
              RowBox[{"(*", " ", 
               RowBox[{"Suppress", " ", "+", " ", 
                RowBox[{
                "sign", " ", "on", " ", "a", " ", "first", " ", "term", " ", 
                 "that", " ", "is", " ", "positive"}]}], " ", "*)"}], "\n", 
              "\t", "\[IndentingNewLine]", 
              RowBox[{"nextTerm", "=", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"factor", " ", "g\[Mu]\[Nu]"}], ",", "\"\< \>\"", ",",
                   "dx\[Mu]", ",", "\"\< \>\"", ",", "dx\[Nu]"}], "}"}], 
                "]"}]}], ";", " ", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"(*", " ", 
               RowBox[{
                RowBox[{"Next", " ", "off"}], "-", 
                RowBox[{
                "diagonal", " ", "line", " ", "element", " ", "term"}]}], " ",
                "*)"}], "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"\[Mu]", "==", "\[Nu]"}], ",", 
                RowBox[{"nextTerm", "=", 
                 RowBox[{"Row", "[", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"factor", " ", "g\[Mu]\[Nu]"}], ",", "\"\< d\>\"",
                     ",", 
                    SuperscriptBox[
                    RowBox[{"\[ScriptX]", "[", "\[Mu]", "]"}], "2"]}], "}"}], 
                  "]"}]}]}], "]"}], ";", " ", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"(*", " ", 
               RowBox[{
               "Next", " ", "diagonal", " ", "line", " ", "element", " ", 
                "term"}], " ", "*)"}], "\[IndentingNewLine]", 
              "\[IndentingNewLine]", 
              RowBox[{"lineElem", "=", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"lineElem", ",", "plus", ",", "nextTerm"}], "}"}], 
                "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], "]"}]}], "]"}],
       ";", "\n", "lineElem"}]}], "]"}]}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"end", " ", "of", " ", "module"}], " ", "*)"}], "\n"}], "\n", 
 RowBox[{"lineElem", "/.", "rulesLE", " ", 
  RowBox[{"(*", "  ", 
   RowBox[{"write", " ", "initial", " ", "line", " ", "element"}], "  ", 
   "*)"}]}]}], "Code",
