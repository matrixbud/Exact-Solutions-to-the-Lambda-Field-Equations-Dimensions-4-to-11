Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "These", " ", "statements", " ", "allow", " ", "rerunning", " ", "this", " ",
      "section", " ", "without", " ", "rerunning", " ", "the", " ", 
     "initialization", " ", "cells"}], ",", " ", 
    RowBox[{"which", " ", "can", " ", "take", " ", 
     RowBox[{"time", ".", "\[IndentingNewLine]", "They"}], " ", "can", " ", 
     "also", " ", "be", " ", "temporarily", " ", "inserted", " ", "later", " ",
      "in", " ", "order", " ", "to", " ", "run", " ", "this", " ", "sections",
      " ", "from", " ", "the", " ", "middle", " ", "by", " ", "commenting", " ",
      "out", " ", "the", " ", "beginning"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "A", ",", "B", ",", "\[ScriptCapitalA]", ",", "\[CapitalBeta]", ",", 
      "\[Alpha]", ",", "\[Beta]", ",", "\[CapitalLambda]", ",", "a", ",", 
      "k"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", "Subscript", "]"}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"Clears", " ", 
       SubscriptBox["p", "5"]}], " ", "&"}], " ", 
     SubscriptBox["p", "6"]}], "  ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rulesDisp", "=", "rulesDisp0"}], ";"}], "  ", 
   RowBox[{"(*", " ", 
    RowBox[{"Resets", " ", "to", " ", "original", " ", "rulesDisp"}], " ", 
    "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Use", " ", "Print", " ", "statements", " ", "and", " ", "then", " ", 
      "view", " ", "results", " ", "in", " ", "the", " ", "output"}], ",", 
     " ", 
     RowBox[{"not", " ", "in", " ", "this", " ", "code"}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "case", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"lhs", " ", "and", " ", "rhs", " ", 
      RowBox[{"(", "below", ")"}], " ", "set", " ", "field", " ", "equations",
       " ", "to", " ", "express", " ", "\[IndentingNewLine]", "         ", 
      FractionBox[
       SubscriptBox["R", "\[Mu]\[Nu]"], 
       SubscriptBox["g", "\[Mu]\[Nu]"]]}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"\[CapitalLambda]", " ", "if", " ", 
        SubscriptBox["g", "\[Mu]\[Nu]"]}], "\[NotEqual]", 
       RowBox[{"0", " ", "\[IndentingNewLine]", "  ", "and", "   ", 
        SubscriptBox["R", "\[Mu]\[Nu]"]}]}], " ", "=", " ", 
      RowBox[{"0", "   ", "otherwise"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"lhs", "[", 
      RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "leftside", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"g", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"leftside", " ", "=", 
           RowBox[{"R", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], ",", 
          RowBox[{"leftside", "=", 
           RowBox[{"xS", "[", 
            RowBox[{
             RowBox[{"R", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/", 
             RowBox[{"g", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}]}], "]"}], ";",
         "leftside"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rhs", "[", 
      RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "rightside", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"g", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"rightside", " ", "=", 
           RowBox[{"\[CapitalLambda]", " ", 
            RowBox[{"g", "[", 
             RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ",", 
          RowBox[{"rightside", "=", "\[CapitalLambda]"}]}], "]"}], ";", 
        "rightside"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<The Lambda field equations of Case 4D reduce to:\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
        RowBox[{"\[Nu]", "\[LessEqual]", "2"}], ",", 
        RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"R", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", 
             RowBox[{"\[CapitalLambda]", " ", 
              RowBox[{"g", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ")"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{
            SubscriptBox["\"\<R\>\"", 
             RowBox[{"Row", "[", 
              RowBox[{"{", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
            ",", "\"\<:  \>\"", ",", 
            RowBox[{
             RowBox[{"lhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
            ",", "\"\< = \>\"", ",", 
            RowBox[{
             RowBox[{"rhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}]}], 
           "]"}]}], "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<From \!\(\*SubscriptBox[\(R\), \(01\)]\):\>\"", "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}]}], ",", 
        RowBox[{"A", "[", 
         RowBox[{"t", ",", "r"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "r"}], "}"}]}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[ScriptCapitalA]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rulesDisp", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], " ", "->", " ", 
        "\[ScriptCapitalA]"}], ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ScriptCapitalA]", 
          TagBox[
           RowBox[{"(", "1", ")"}],
           Derivative],
          MultilineFunction->None], "[", "t_", "]"}], " ", "->", " ", 
        RowBox[{"OverDot", "[", "\[ScriptCapitalA]", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ScriptCapitalA]", 
          TagBox[
           RowBox[{"(", "2", ")"}],
           Derivative],
          MultilineFunction->None], "[", "t_", "]"}], " ", "->", " ", 
        RowBox[{"OverDot", "[", 
         RowBox[{"\[ScriptCapitalA]", ",", " ", "2"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "->", "\[CapitalBeta]"}], ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[CapitalBeta]", 
          TagBox[
           RowBox[{"(", "1", ")"}],
           Derivative],
          MultilineFunction->None], "[", "r", "]"}], "->", 
        SuperscriptBox["\[CapitalBeta]", "\[Prime]",
         MultilineFunction->None]}], ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[CapitalBeta]", 
          TagBox[
           RowBox[{"(", "2", ")"}],
           Derivative],
          MultilineFunction->None], "[", "r", "]"}], 
        "->", "\"\<\!\(\*SuperscriptBox[\(\[CapitalBeta]\), \
\(\[DoublePrime]\)]\)\>\""}], ",", 
       RowBox[{
        RowBox[{"a", "[", "t", "]"}], "->", "a"}], ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox["a", 
          TagBox[
           RowBox[{"(", "1", ")"}],
           Derivative],
          MultilineFunction->None], "[", "t", "]"}], "->", 
        RowBox[{"OverDot", "[", "a", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox["a", 
          TagBox[
           RowBox[{"(", "2", ")"}],
           Derivative],
          MultilineFunction->None], "[", "t", "]"}], "->", 
        RowBox[{"OverDot", "[", 
         RowBox[{"a", ",", "2"}], "]"}]}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     A(t,r) = \>\"", ",", 
      RowBox[{"A", "[", 
       RowBox[{"t", ",", "r"}], "]"}], 
      ",", "\"\<  where \[ScriptCapitalA](t) is a new unknown.\>\""}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(01\)]\) becomes an \
identity, 0=0, and we are left with 3 equations in the 2 unknowns \
\[ScriptCapitalA] and \[CapitalBeta]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{
        SubscriptBox["\"\<R\>\"", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
         ",", 
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
        ",", "\"\< = \>\"", ",", 
        RowBox[{"rhs", "[", 
         RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(11\)]\) for \
\[CapitalBeta]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"Together", "[", 
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"1", ",", "1"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"1", ",", "1"}], "]"}]}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", "r"}], "]"}], "]"}], 
      "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", 
       RowBox[{"-", "\[Beta]"}]}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rulesDisp", "=", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{
        RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], " ", "->", " ", 
        "\[ScriptCapitalA]"}], ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ScriptCapitalA]", 
          TagBox[
           RowBox[{"(", "1", ")"}],
           Derivative],
          MultilineFunction->None], "[", "t_", "]"}], " ", "->", " ", 
        RowBox[{"OverDot", "[", "\[ScriptCapitalA]", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ScriptCapitalA]", 
          TagBox[
           RowBox[{"(", "2", ")"}],
           Derivative],
          MultilineFunction->None], "[", "t_", "]"}], " ", "->", " ", 
        RowBox[{"OverDot", "[", 
         RowBox[{"\[ScriptCapitalA]", ",", " ", "2"}], "]"}]}], ",", 
       RowBox[{
        RowBox[{"a", "[", "t", "]"}], "->", "a"}], ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox["a", 
          TagBox[
           RowBox[{"(", "1", ")"}],
           Derivative],
          MultilineFunction->None], "[", "t", "]"}], "->", 
        RowBox[{"OverDot", "[", "a", "]"}]}], ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox["a", 
          TagBox[
           RowBox[{"(", "2", ")"}],
           Derivative],
          MultilineFunction->None], "[", "t", "]"}], "->", 
        RowBox[{"OverDot", "[", 
         RowBox[{"a", ",", "2"}], "]"}]}]}], "}"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}], 
      ",", "\"\<  where \[Beta] is a constant of integration.\>\""}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<The remaining 2 equations have just \[ScriptCapitalA] \
as an unknown:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(00\)]\):  \>\"", ",", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "/.", "rulesDisp"}], 
      ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"0", ",", "0"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}], "/.", "rulesDisp"}], 
      ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"2", ",", "2"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs02", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs02", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"0", ",", "0"}], "]"}], "-", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<and \!\(\*SubscriptBox[\(R\), \
\(00\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\) can be solved for \
\[ScriptCapitalA] \
\!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\):\>\"", "]"}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(00\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
      RowBox[{"lhs02", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      "rhs02"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", 
