 RowBox[{
  RowBox[{
  "line1", "=", \
"\"\<\!\(\*StyleBox[\"Backup\",FontWeight->\"Bold\",FontColor->RGBColor[0, 0, \
1]]\)\!\(\*StyleBox[\" \",FontWeight->\"Bold\",FontColor->RGBColor[0, 0, \
