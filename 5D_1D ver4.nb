1]]\)\!\(\*StyleBox[\"=\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"\[GothicCapitalC]\",FontWeight->\"Bold\",FontColor->\
RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "B", ",", "\[CapitalBeta]", ",", "\[DoubleStruckCapitalC]", ",", 
      "\[GothicCapitalC]"}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[DoubleStruckCapitalC]", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Normally we restrict this case to \
B(t,r)=\[CapitalBeta](r) and \
\[DoubleStruckCapitalC](t,r)=\[GothicCapitalC](r). But, in this instance we \
start with more general B(t,r) and show right away that, in fact, we get \
B(t,r)=\[CapitalBeta](r).\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<The standard Case b actually begins after we show \
this.\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<With the more general B(t,r), the field equations \
become:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
        RowBox[{"\[Nu]", "\[LessEqual]", "2"}], ",", 
        RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"R", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", 
             RowBox[{"\[CapitalLambda]", " ", 
              RowBox[{"g", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ")"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{
            SubscriptBox["\"\<R\>\"", 
             RowBox[{"Row", "[", 
              RowBox[{"{", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
            ",", "\"\<:  \>\"", ",", 
            RowBox[{
             RowBox[{"lhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
            ",", "\"\< = \>\"", ",", 
            RowBox[{"rhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
       "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[GothicCapitalC]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}]}], ",", 
        RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], ",", "r"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "k"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(01\)]\) is satisfied if \
either\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[GothicCapitalC](r) = \>\"", ",", 
