         ",", 
        RowBox[{"lhs", "[", 
         RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], ",", "\"\< = \>\"", ",", 
        RowBox[{"rhs", "[", 
         RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";", 
    RowBox[{
    "Print", "[", "\"\<All of the equations are satisfied and so we have an \
exact solution to \[CapitalLambda]=0 field equations:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \>\"", ",", 
      RowBox[{"a", "[", "t", "]"}], 
      ",", "\"\<,  where k and \[CapitalKappa] are constants of integration\>\
\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "a", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     A(t,r) = \>\"", ",", 
      RowBox[{
       RowBox[{"A", "[", 
        RowBox[{"t", ",", "r"}], "]"}], "/.", "rulesLE"}], ",", "\"\<,\>\""}],
      "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     B(t,r) = a[t\!\(\*SuperscriptBox[\(]\), \(2\)]\)\
\[CapitalBeta](r) = \>\"", ",", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"a", "[", "t", "]"}], "2"], 
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "/.", "rulesLE"}], 
      ",", "\"\<,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[DoubleStruckCapitalC](t,r) = \>\"", ",", 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         RowBox[{"a", "[", "t", "]"}], "2"], 
        RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], "/.", "rulesLE"}], 
      ",", "\"\<,  where \[GothicCapitalC](r) is a free parameter,\>\""}], 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[DoubleStruckCapitalD](t,r) = 1.\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
   "Print", "[", "\"\<However, this is \
\!\(\*StyleBox[\"not\",FontSlant->\"Italic\"]\) a new solution. This is the \
special case of the Case a solution having A(t,r) = \
\!\(\*SuperscriptBox[\(c\), \(2\)]\). \>\"", "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
