Cell[BoxData[{
 RowBox[{
  RowBox[{"lineElem", ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "firstElem", ",", "g\[Mu]\[Nu]", ",", "gzero", ",", "x\[Mu]", ",", 
       "x\[Nu]", ",", "dx\[Mu]", ",", "dx\[Nu]", ",", "negSign", ",", 
       "factor", ",", "\n", "plus", ",", "nextTerm", ",", "lineElem"}], "}"}],
      ",", "\n", "\n", 
     RowBox[{
      RowBox[{
      "lineElem", "=", "\"\<\!\(\*SuperscriptBox[\(ds\), \(2\)]\) = \>\""}], ";",
       "\n", 
      RowBox[{"firstElem", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"\[Mu]", "=", "dimL"}], ",", 
        RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
        RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "dimL"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"g", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], ",", 
             RowBox[{"gzero", "=", "0"}], ",", 
             RowBox[{"gzero", "=", "1"}], ",", 
             RowBox[{"gzero", "=", "1"}]}], "]"}], ";", " ", 
           RowBox[{"(*", " ", 
            RowBox[{
             RowBox[{"1", " ", "means", " ", 
              SubscriptBox["g", "\[Mu]\[Nu]"]}], "\[NotEqual]", "0"}], " ", 
            "*)"}], "\n", "\n", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"gzero", "==", "1"}], ",", "  ", 
             RowBox[{"(*", " ", 
              RowBox[{
               RowBox[{"If", " ", "there", " ", "is", " ", "a", " ", "non"}], 
               "-", 
               RowBox[{"zero", " ", 
                SubscriptBox["g", "\[Mu]\[Nu]"], " ", "term", " ", "to", " ", 
                "print"}]}], " ", "*)"}], "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"g\[Mu]\[Nu]", "=", 
               RowBox[{"g", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"x\[Mu]", "=", 
               RowBox[{"ToString", "[", 
                RowBox[{"\[ScriptX]", "[", "\[Mu]", "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"x\[Nu]", "=", 
               RowBox[{"ToString", "[", 
                RowBox[{"\[ScriptX]", "[", "\[Nu]", "]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"dx\[Mu]", "=", 
               RowBox[{"\"\<d\>\"", "<>", "x\[Mu]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"dx\[Nu]", "=", 
               RowBox[{"\"\<d\>\"", "<>", "x\[Nu]"}]}], ";", 
              "\[IndentingNewLine]", "\n", 
              RowBox[{"negSign", "=", 
               RowBox[{"g\[Mu]\[Nu]", "/.", " ", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Times", "[", 
                    RowBox[{
                    RowBox[{"c_", "?", "NumericQ"}], ",", "___"}], "]"}], ":>", 
                   RowBox[{"c", "<", "0"}]}], ",", 
                  RowBox[{"_Times", ":>", "False"}]}], "}"}]}]}], ";", " ", 
              "\n", "\t", 
              RowBox[{"(*", " ", 
               RowBox[{
                RowBox[{"=", " ", 
                 RowBox[{
                 "True", " ", "if", " ", "g\[Mu]\[Nu]", " ", "starts", " ", 
                  "with", " ", "neg", " ", "sign"}]}], ",", "  ", 
                RowBox[{"random", " ", "values", " ", 
                 RowBox[{"o", ".", "w", "."}]}]}], " ", "*)"}], 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Head", "[", "g\[Mu]\[Nu]", "]"}], "===", 
                 "Integer"}], ",", 
                RowBox[{
                 RowBox[{"negSign", "=", "False"}], ";", " ", 
                 "\[IndentingNewLine]", "\t", 
                 RowBox[{"(*", " ", 
                  RowBox[{
                   RowBox[{"Special", " ", 
                    RowBox[{"case", ":", " ", 
                    RowBox[{"give", " ", "g\[Mu]\[Nu]"}]}]}], " ", "=", " ", 
                   RowBox[{"1", " ", "a", " ", "False", " ", "value"}]}], 
                  "  ", "*)"}], "\n", "\t", 
                 RowBox[{"If", "[", 
                  RowBox[{
                   RowBox[{"g\[Mu]\[Nu]", "<", "0"}], ",", 
                   RowBox[{"negSign", "=", "True"}]}], "]"}]}]}], 
               "\[IndentingNewLine]", "\t", 
               RowBox[{"(*", " ", 
                RowBox[{
                 RowBox[{"Special", " ", 
                  RowBox[{"case", ":", " ", 
                   RowBox[{"give", " ", "g\[Mu]\[Nu]"}]}]}], "=", " ", 
                 RowBox[{
