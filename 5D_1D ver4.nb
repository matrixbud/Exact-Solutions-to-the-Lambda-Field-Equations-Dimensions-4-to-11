        RowBox[{"rhs", "[", 
         RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs012b", "=", 
