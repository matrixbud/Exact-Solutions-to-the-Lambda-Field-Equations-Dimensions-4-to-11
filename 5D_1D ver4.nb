   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Restarting Case b from scratch using these \
constraints, the field equations become:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
        RowBox[{"\[Nu]", "\[LessEqual]", "2"}], ",", 
        RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Mu]", "==", "\[Nu]"}], "||", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"\[Mu]", "==", "0"}], "&&", 
             RowBox[{"\[Nu]", "==", "1"}]}], ")"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{
            SubscriptBox["\"\<R\>\"", 
             RowBox[{"Row", "[", 
              RowBox[{"{", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
            ",", "\"\<:  \>\"", ",", 
            RowBox[{
             RowBox[{"lhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
            ",", "\"\< = \>\"", ",", 
            RowBox[{"rhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
       "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs12", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs12", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], "-", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We note that \!\(\*SubscriptBox[\(R\), \(00\)]\) and \
\!\(\*SubscriptBox[\(R\), \(01\)]\) are identities, leaving us just 2 \
equations in 2 unknowns.\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\) can be \
\!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) solved for \
\[CapitalBeta]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
      RowBox[{"lhs12", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      "rhs12"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", 
      RowBox[{"Last", "[", 
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"lhs12", "==", "rhs12"}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], "]"}]}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
