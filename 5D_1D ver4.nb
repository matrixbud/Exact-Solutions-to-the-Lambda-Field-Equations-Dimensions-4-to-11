 "\"  or else expressions like ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["k", "1"], "'"}], 
    SubscriptBox["k", "1"]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "76fce4e2-02dc-4fd7-9725-31687900bba2"],
 " cause a mess \n\tI avoid this need for quotes: \n\t     For example,  \
instead of using ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["k", "1"], "'"}], "[", "r", "]"}], TraditionalForm]],
  ExpressionUUID->"8b68a951-1d44-45da-9738-190547257e80"],
 " in rulesDisp, I use  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"x_", "'"}], "[", "r", "]"}], "\[RuleDelayed]", 
    SuperscriptBox["x", 
     StyleBox["\[Prime]",
      FontSize->13,
      FontWeight->"Regular",
      FontSlant->"Plain"]]}], TraditionalForm]],ExpressionUUID->
  "946540c2-b384-4d06-87cc-d69da6d692a3"],
 "  \n\t     where x_ stands for any parameter\n\n",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Clear", "[", "K", "]"}], " ", "works", " ", "but", " ", 
   RowBox[{"Clear", "[", 
    SubscriptBox["K", "1"], "]"}], " ", "gives", " ", "an", " ", "error", " ",
