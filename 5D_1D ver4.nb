Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \"\>", "\[InvisibleSpace]", 
   TemplateBox[{
     TemplateBox[{
       TemplateBox[{
         TemplateBox[{
           
           TemplateBox[{
            "\"\\!\\(\\*SuperscriptBox[\\(ds\\), \\(2\\)]\\) = \"", "\"\"", 
             TemplateBox[{
               SuperscriptBox["c", "2"], "\" d\"", 
               SuperscriptBox["t", "2"]}, "RowDefault"]}, "RowDefault"], 
           "\" - \"", 
           TemplateBox[{
             SuperscriptBox["\[Alpha]", "2"], "\" d\"", 
             SuperscriptBox["r", "2"]}, "RowDefault"]}, "RowDefault"], 
         "\" - \"", 
         TemplateBox[{
           SuperscriptBox[
            RowBox[{"(", 
              RowBox[{"k", "+", 
                RowBox[{"r", " ", "\[Alpha]"}]}], ")"}], "2"], "\" d\"", 
           SuperscriptBox["\[Theta]", "2"]}, "RowDefault"]}, "RowDefault"], 
       "\" - \"", 
       TemplateBox[{
         RowBox[{
           SuperscriptBox[
            RowBox[{"(", 
              RowBox[{"k", "+", 
                RowBox[{"r", " ", "\[Alpha]"}]}], ")"}], "2"], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"]}], "\" d\"", 
         SuperscriptBox["\[Phi]", "2"]}, "RowDefault"]}, "RowDefault"], 
     "\" - \"", 
     TemplateBox[{
       SuperscriptBox["p", "2"], "\" d\"", 
       SuperscriptBox["\[Psi]", "2"]}, "RowDefault"]},
    "RowDefault"]}],
  SequenceForm["     ", 
   Row[{
     Row[{
       Row[{
         Row[{
           Row[{"\!\(\*SuperscriptBox[\(ds\), \(2\)]\) = ", "", 
             Row[{$CellContext`c^2, " d", $CellContext`t^2}]}], " - ", 
           Row[{$CellContext`\[Alpha]^2, " d", $CellContext`r^2}]}], " - ", 
         Row[{($CellContext`k + $CellContext`r $CellContext`\[Alpha])^2, 
           " d", $CellContext`\[Theta]^2}]}], " - ", 
       Row[{($CellContext`k + $CellContext`r $CellContext`\[Alpha])^2 
         Sin[$CellContext`\[Theta]]^2, " d", $CellContext`\[Phi]^2}]}], " - ", 
     Row[{$CellContext`p^2, " d", $CellContext`\[Psi]^2}]}]],
  Editable->False]], "Print",
 CellChangeTimes->{3.980371987936595*^9, 3.980373421232917*^9, 
