Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \[CapitalBeta](r) = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", "\[GothicCapitalC]"}], "+", 
       RowBox[{"r", " ", 
        SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
         MultilineFunction->None]}]}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", "\[GothicCapitalC]", " ", 
        RowBox[{"(", 
         RowBox[{"1", "+", 
          RowBox[{"r", " ", "\[CapitalKappa]"}]}], ")"}]}], "+", 
       RowBox[{"r", " ", 
        SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
         MultilineFunction->None]}]}], ")"}]}], 
    RowBox[{"4", " ", "\[GothicCapitalC]"}]]}],
  SequenceForm[
  "     \[CapitalBeta](r) = ", 
   Rational[1, 4] $CellContext`\[GothicCapitalC]^(-1) (
    2 $CellContext`\[GothicCapitalC] + $CellContext`r 
     Derivative[1][$CellContext`\[GothicCapitalC]]) (
    2 $CellContext`\[GothicCapitalC] (
      1 + $CellContext`r $CellContext`\[CapitalKappa]) + $CellContext`r 
     Derivative[1][$CellContext`\[GothicCapitalC]])],
  Editable->False]], "Print",
 CellChangeTimes->{3.980371987936595*^9, 3.980373421232917*^9, 
