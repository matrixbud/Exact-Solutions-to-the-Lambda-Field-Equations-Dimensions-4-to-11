         RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "\[GothicCapitalC]", "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
