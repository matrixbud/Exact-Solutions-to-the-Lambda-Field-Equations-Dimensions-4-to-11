        RowBox[{"2", ",", "2"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(11\)]\)+2\!\(\*SubscriptBox[\(R\), \(22\
\)]\) can be \!\(\*StyleBox[\"algebaically\",FontSlant->\"Italic\"]\) solved \
for \[CapitalBeta](r);\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
