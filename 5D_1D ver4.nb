      RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{
        SubscriptBox["\"\<R\>\"", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
