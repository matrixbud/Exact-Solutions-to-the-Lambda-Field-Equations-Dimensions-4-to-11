Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"xS", "[", "x_", "]"}], ":=", 
    RowBox[{"Expand", "[", 
     RowBox[{"Simplify", "[", "x", "]"}], "]"}]}], ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[CapitalGamma]\[CapitalGamma]", "[", 
     RowBox[{"\[Mu]_", ",", "\[Nu]_", ",", "\[Sigma]_"}], "]"}], ":=", 
    RowBox[{"Simplify", "[", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"\[CapitalGamma]", "[", 
          RowBox[{"\[Rho]", ",", "\[Mu]", ",", "\[Sigma]"}], "]"}], " ", 
         RowBox[{"\[CapitalGamma]", "[", 
          RowBox[{"\[Sigma]", ",", "\[Rho]", ",", "\[Nu]"}], "]"}]}], "-", 
        RowBox[{
         RowBox[{"\[CapitalGamma]", "[", 
          RowBox[{"\[Rho]", ",", "\[Mu]", ",", "\[Nu]"}], "]"}], " ", 
         RowBox[{"\[CapitalGamma]", "[", 
          RowBox[{"\[Sigma]", ",", "\[Rho]", ",", "\[Sigma]"}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Rho]", ",", "dimL", ",", "dimH"}], "}"}]}], "]"}], "]"}]}],
    ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"R", "[", 
     RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", "\n", 
    RowBox[{"xS", "[", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[CapitalGamma]", "[", 
           RowBox[{"\[Sigma]", ",", "\[Mu]", ",", "\[Sigma]"}], "]"}], ",", 
          RowBox[{"\[ScriptX]", "[", "\[Nu]", "]"}]}], "]"}], "-", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[CapitalGamma]", "[", 
           RowBox[{"\[Sigma]", ",", "\[Mu]", ",", "\[Nu]"}], "]"}], ",", 
          RowBox[{"\[ScriptX]", "[", "\[Sigma]", "]"}]}], "]"}], "+", " ", 
        RowBox[{"\[CapitalGamma]\[CapitalGamma]", "[", 
         RowBox[{"\[Mu]", ",", "\[Nu]", ",", "\[Sigma]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Sigma]", ",", "dimL", ",", "dimH"}], "}"}]}], "]"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RMat", "=", 
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"R", "[", 
      RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Mu]", ",", "dimL", ",", "dimH"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Nu]", ",", "dimL", ",", "dimH"}], "}"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"column2F", "=", 
    RowBox[{"Flatten", "[", "RMat", "]"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
     SubscriptBox["R", "\[Mu]\[Nu]"], "-", 
     RowBox[{"column", " ", "values"}]}], ",", " ", 
    RowBox[{"stored", " ", "as", " ", "a", " ", "list"}]}], "  ", "*)"}], 
  "\n"}], "\n", 
 RowBox[{
  RowBox[{"indexr", "=", 
   RowBox[{"Style", "[", 
    RowBox[{
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{"Subscript", "[", 
        RowBox[{"\"\<R\>\"", ",", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{"index1", ",", "index2"}], "}"}], "]"}]}], "]"}], "}"}], 
      "]"}], ",", "Bold", ",", "Blue"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"indexR", "=", 
   RowBox[{"Style", "[", 
    RowBox[{
     RowBox[{"Row", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Subscript", "[", 
         RowBox[{"\"\<R\>\"", ",", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"index1", ",", "index2"}], "}"}], "]"}]}], "]"}], ",", 
        "\n", "\"\< = \!\(\*SubscriptBox[\"\[PartialD]\", FormBox[StyleBox[\"\
\[Nu]\",FontFamily->\"Symbol\",FontWeight->\"Regular\"],TraditionalForm]]\)\!\
\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \(\[Mu]\[Sigma]\), \(\[Sigma]\)]\) \
\[Dash] \!\(\*SubscriptBox[\(\[PartialD]\), \
\(\[Sigma]\)]\)\!\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \(\[Mu]\[Nu]\), \
\(\[Sigma]\)]\) + \!\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \
\(\[Mu]\[Sigma]\), \(\[Rho]\)]\)\!\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \
\(\[Rho]\[Nu]\), \(\[Sigma]\)]\) \[Dash] \!\(\*SubsuperscriptBox[\(\
\[CapitalGamma]\), \(\[Mu]\[Nu]\), \(\[Rho]\)]\)\!\(\*SubsuperscriptBox[\(\
\[CapitalGamma]\), \(\[Rho]\[Sigma]\), \(\[Sigma]\)]\)\>\""}], "}"}], "]"}], ",",
      "Bold", ",", "Blue"}], "]"}]}], ";"}], "\n"}], "Code",
