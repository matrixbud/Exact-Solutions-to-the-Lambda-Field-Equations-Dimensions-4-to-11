Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Use", " ", "Print", " ", "statements", " ", "and", " ", "then", " ", 
     "view", " ", "results", " ", "in", " ", "the", " ", "output"}], ",", " ", 
    RowBox[{"not", " ", "in", " ", "this", " ", "code"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Print", "[", "case", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[DoubleStruckCapitalD]", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"\[GothicCapitalD]", "[", "r", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[GothicCapitalD]", "[", "r_", "]"}], "=", "1"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"lhs", " ", "and", " ", "rhs", " ", 
      RowBox[{"(", "below", ")"}], " ", "set", " ", "field", " ", "equations",
       " ", "to", " ", "express", " ", "\[IndentingNewLine]", "         ", 
      FractionBox[
       SubscriptBox["R", "\[Mu]\[Nu]"], 
       SubscriptBox["g", "\[Mu]\[Nu]"]]}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"\[CapitalLambda]", " ", "if", " ", 
        SubscriptBox["g", "\[Mu]\[Nu]"]}], "\[NotEqual]", 
       RowBox[{"0", " ", "\[IndentingNewLine]", "  ", "and", "   ", 
        SubscriptBox["R", "\[Mu]\[Nu]"]}]}], " ", "=", " ", 
      RowBox[{"0", "   ", "otherwise"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"lhs", "[", 
      RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "leftside", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"g", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"leftside", " ", "=", 
           RowBox[{"R", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], ",", 
          RowBox[{"leftside", "=", 
           RowBox[{"xS", "[", 
            RowBox[{
             RowBox[{"R", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/", 
             RowBox[{"g", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}]}], "]"}], ";",
         "leftside"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rhs", "[", 
      RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "rightside", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"g", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"rightside", " ", "=", 
           RowBox[{"\[CapitalLambda]", " ", 
            RowBox[{"g", "[", 
             RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ",", 
          RowBox[{"rightside", "=", "\[CapitalLambda]"}]}], "]"}], ";", 
        "rightside"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<The Lambda field equations can be represented as \
\!\(\*FractionBox[SubscriptBox[\(R\), \(\[Mu]\[Nu]\)], SubscriptBox[\(g\), \(\
\[Mu]\[Nu]\)]]\) = \[CapitalLambda]:\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"R", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], "&&", 
               RowBox[{
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "===", "0"}]}], 
              ")"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
              SubscriptBox["\"\<R\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
              ",", "\"\<:  \>\"", ",", 
              RowBox[{
               RowBox[{"lhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
              ",", "\"\< = \>\"", ",", 
              RowBox[{"rhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We observed in Notebook 5D_1 that \
\!\(\*SubscriptBox[\(R\), \(33\)]\) is redundant and, so, \!\(\*SubscriptBox[\
\(R\), \(33\)]\) is omitted here and in all of the 5D notebooks.\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We observe from \!\(\*SubscriptBox[\(R\), \(44\)]\) \
that \[CapitalLambda] = 0.\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalLambda]", "=", "0"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<How this occured can be understood by observng \
\!\(\*SubscriptBox[\(R\), \(44\)]\) in the more general Case 5D_1A:\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<   \!\(\*SubscriptBox[\(R\), \(44\)]\):  \
\[InvisibleSpace]-\!\(\*FractionBox[SuperscriptBox[\"\[GothicCapitalD]\", \"\
\[Prime]\[Prime]\",MultilineFunction->None], RowBox[{\"2\", \" \", \
SuperscriptBox[\"a\", \"2\"], \" \", \"\[GothicCapitalD]\", \" \", \"\
\[CapitalBeta]\"}]]\)+\!\(\*FractionBox[\(3\\\ \*SuperscriptBox[\(c\), \(2\)]\
\\\ \*SuperscriptBox[OverscriptBox[\(a\), \(.\)], \(2\)]\), \
\(\*SuperscriptBox[\(a\), \(2\)]\\\ \
A\)]\)-\!\(\*FractionBox[\(\*SuperscriptBox[\(c\), \(2\)]\\\ \*OverscriptBox[\
\(a\), \(.\)]\\\ \*OverscriptBox[\(A\), \(.\)]\), \(2\\\ a\\\ \
\*SuperscriptBox[\(A\), \
\(2\)]\)]\)+\!\(\*FractionBox[\(\*SuperscriptBox[\(c\), \(2\)]\\\ \
\*OverscriptBox[\(a\), \(\[DoubleDot]\)]\), \(a\\\ \
A\)]\)-\!\(\*FractionBox[SuperscriptBox[\"\[GothicCapitalD]\", \
\"\[Prime]\",MultilineFunction->None], RowBox[{SuperscriptBox[\"a\", \"2\"], \
\" \", \"r\", \" \", \"\[GothicCapitalD]\", \" \", \"\[CapitalBeta]\"}]]\)-\!\
\(\*FractionBox[RowBox[{SuperscriptBox[\"A\", \
\"\[Prime]\",MultilineFunction->None], \" \", SuperscriptBox[\"\
\[GothicCapitalD]\", \"\[Prime]\",MultilineFunction->None]}], RowBox[{\"4\", \
\" \", SuperscriptBox[\"a\", \"2\"], \" \", \"A\", \" \", \"\[GothicCapitalD]\
\", \" \", \
\"\[CapitalBeta]\"}]]\)-\!\(\*FractionBox[RowBox[{SuperscriptBox[\"\
\[GothicCapitalC]\", \"\[Prime]\",MultilineFunction->None], \" \", \
SuperscriptBox[\"\[GothicCapitalD]\", \
\"\[Prime]\",MultilineFunction->None]}], RowBox[{\"2\", \" \", \
SuperscriptBox[\"a\", \"2\"], \" \", \"\[GothicCapitalC]\", \" \", \"\
\[GothicCapitalD]\", \" \", \
\"\[CapitalBeta]\"}]]\)+\!\(\*FractionBox[SuperscriptBox[RowBox[{\"(\", \
SuperscriptBox[\"\[GothicCapitalD]\", \"\[Prime]\",MultilineFunction->None], \
\")\"}], \"2\"], RowBox[{\"4\", \" \", SuperscriptBox[\"a\", \"2\"], \" \", \
SuperscriptBox[\"\[GothicCapitalD]\", \"2\"], \" \", \"\[CapitalBeta]\"}]]\)+\
\!\(\*FractionBox[RowBox[{SuperscriptBox[\"\[GothicCapitalD]\", \
\"\[Prime]\",MultilineFunction->None], \" \", SuperscriptBox[\"\[CapitalBeta]\
\", \"\[Prime]\",MultilineFunction->None]}], RowBox[{\"4\", \" \", \
SuperscriptBox[\"a\", \"2\"], \" \", \"\[GothicCapitalD]\", \" \", \
SuperscriptBox[\"\[CapitalBeta]\", \"2\"]}]]\) = \[CapitalLambda]\>\"", "]"}],
     ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";", 
    RowBox[{
    "Print", "[", "\"\<Here, in Case 5D_1D, the difference is that both \
a(t)=1 and \[GothicCapitalD](r)=1, which zeroes out every term on the \
LHS.\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Except that \[CapitalLambda] = 0 here, the remaining \
equations are exactly the same as in the general Case 4D. So, we use the Case \
4D methodologies as guidance for solving these 5D_1d cases.\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<\!\(\*StyleBox[\"a\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\":\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"  \",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, 1]]\
\)\!\(\*StyleBox[\"B\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, 1]]\)\!\
\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\",\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\" \",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"=\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\" \",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"a\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[SuperscriptBox[\")\", \
StyleBox[\"2\",FontWeight->\"Bold\"]],FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"\[CapitalBeta]\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"(\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\")\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\",\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[StyleBox[RowBox[{\" \", StyleBox[\" \",FontWeight->\"Bold\
\"]}]],FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"and\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\" \",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"\[DoubleStruckCapitalC]\",FontWeight->\"Bold\",\
FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"[\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\",\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"]\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\" \",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"=\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\" \",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"a\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"[\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[SuperscriptBox[\"]\", \
StyleBox[\"2\",FontWeight->\"Bold\"]],FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"\[GothicCapitalC]\",FontColor->RGBColor[1, 0, 1]]\)\!\(\
\*StyleBox[\"[\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"]\",FontColor->RGBColor[1, 0, 1]]\)\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"B", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"], 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[DoubleStruckCapitalC]", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"], 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<With these formulas, the field equations are:\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
        RowBox[{"\[Nu]", "\[LessEqual]", "2"}], ",", 
        RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"!", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"R", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", 
             RowBox[{"\[CapitalLambda]", " ", 
              RowBox[{"g", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ")"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"Print", "[", 
           RowBox[{
            SubscriptBox["\"\<R\>\"", 
             RowBox[{"Row", "[", 
              RowBox[{"{", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
            ",", "\"\<:  \>\"", ",", 
            RowBox[{
             RowBox[{"lhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
            ",", "\"\< = \>\"", ",", 
            RowBox[{"rhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
       "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Because a(t)\[NotEqual]constant, \
\!\(\*OverscriptBox[\(a\), \(.\)]\)(t)\[NotEqual]0, \
\!\(\*FractionBox[OverscriptBox[\(a\), \(.\)], \(a\)]\) can be factored out \
of \!\(\*SubscriptBox[\(R\), \(01\)]\), and we get that\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     A(t,r) = \[ScriptCapitalA](t), strictly a \
function of t.\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(01\)]\) becomes an \
identity, 0=0, and we are left with 3 equations in the 3 unknowns \
\[ScriptCapitalA], \[CapitalBeta], and \[GothicCapitalC]:\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{
        SubscriptBox["\"\<R\>\"", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
         ",", 
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
        ",", "\"\< = \>\"", ",", 
        RowBox[{"rhs", "[", 
         RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], ",", 
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", 
       RowBox[{
        SuperscriptBox["c", "2"], "/", "k"}]}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Solving \!\(\*SubscriptBox[\(R\), \(00\)]\) for \
\[ScriptCapitalA] yields\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptCapitalA](t) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesLE"}], 
      ",", "\"\<  where k is a constant of integration.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<This leaves 2 equations in the 2 unknowns, \
\[CapitalBeta] amd \[GothicCapitalC]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "1"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"Print", "[", 
       RowBox[{
        SubscriptBox["\"\<R\>\"", 
         RowBox[{"Row", "[", 
          RowBox[{"{", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
         ",", 
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
        ",", "\"\< = \>\"", ",", 
        RowBox[{"rhs", "[", 
         RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs12", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs12", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], "-", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can solve for \[CapitalBeta] algebraically:\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
      RowBox[{"lhs12", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
