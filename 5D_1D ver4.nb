      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(00\)]\) can be solved for \
a(t) and \!\(\*SubscriptBox[\(R\), \(11\)]\)-2\!\(\*SubscriptBox[\(R\), \
\(22\)]\) can be solve for \[CapitalBeta](r):\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \>\"", ",", 
      RowBox[{"a", "[", "t", "]"}], 
      ",", "\"\<,  where k and \[CapitalKappa] are constants of integration\>\
\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Plugging these formulas back into \
\!\(\*SubscriptBox[\(R\), \(11\)]\) and \!\(\*SubscriptBox[\(R\), \(22\)]\) \
yields:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "1"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{
        SubscriptBox["\"\<R\>\"", 
         RowBox[{"Row", "[", 
