 "\"  or else expressions like ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["k", "1"], "'"}], 
    SubscriptBox["k", "1"]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "65d3d8aa-6a8d-487d-b4e9-96d27d8a6947"],
 " cause a mess \n\tI avoid this need for quotes: \n\t     For example,  \
instead of using ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["k", "1"], "'"}], "[", "r", "]"}], TraditionalForm]],
  ExpressionUUID->"941e9a8a-2784-4acf-871e-deda9fef4e20"],
 " in rulesDisp, I use  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"x_", "'"}], "[", "r", "]"}], "\[RuleDelayed]", 
    SuperscriptBox["x", 
     StyleBox["\[Prime]",
      FontSize->13,
      FontWeight->"Regular",
      FontSlant->"Plain"]]}], TraditionalForm]],ExpressionUUID->
  "8756e5ea-4c09-4e24-8c5a-f3d0f4a4c2ef"],
 "  \n\t     where x_ stands for any parameter\n\n",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Clear", "[", "K", "]"}], " ", "works", " ", "but", " ", 
   RowBox[{"Clear", "[", 
    SubscriptBox["K", "1"], "]"}], " ", "gives", " ", "an", " ", "error", " ",
    "message", " ", "that", " ", 
   SubscriptBox["K", "1"], " ", "is", " ", "not", " ", "a", " ", 
   "variable"}]], "Text",
