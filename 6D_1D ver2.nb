Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"(\"\>", "\[InvisibleSpace]", "\<\"\[Mu]\"\>", 
   "\[InvisibleSpace]", "\<\"=\"\>", "\[InvisibleSpace]", "0", 
   "\[InvisibleSpace]", "\<\"): \"\>", "\[InvisibleSpace]", 
   InterpretationBox[Cell[BoxData[
     FormBox[
      OverscriptBox["t", "\[DoubleDot]"], TextForm]], "InlineText",
     ExpressionUUID->"4e869dbc-77f0-4cf6-a4bf-8373aa825553"],
    Text[
     OverDot[$CellContext`t, 2]]], "\[InvisibleSpace]", "\<\" + \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       SqrtBox["3"], " ", 
       SuperscriptBox["\[ExponentialE]", 
        FractionBox[
         RowBox[{"2", " ", "t", " ", 
          SqrtBox["\[CapitalLambda]"]}], 
         SqrtBox["3"]]], " ", "\[GothicCapitalC]", " ", 
       SuperscriptBox["\[Alpha]", "2"], " ", 
       SqrtBox["\[CapitalLambda]"], " ", 
       SuperscriptBox[
        OverscriptBox["r", "."], "2"]}], 
      RowBox[{
       RowBox[{"-", "3"}], "+", 
       RowBox[{"4", " ", 
        SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]", " ", "\[Alpha]", " ",
         "\[Beta]", " ", "\[CapitalLambda]"}]}]]}], "+", 
    FractionBox[
     RowBox[{
      SqrtBox["3"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"-", 
        FractionBox[
         RowBox[{"2", " ", "t", " ", 
