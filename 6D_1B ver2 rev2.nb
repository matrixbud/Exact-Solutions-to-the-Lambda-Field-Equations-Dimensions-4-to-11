   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"B", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     SuperscriptBox[
      RowBox[{"a", "[", "t", "]"}], "2"]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[DoubleStruckCapitalC]", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<The field equations become\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"R", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], "&&", 
               RowBox[{
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "===", "0"}]}], 
              ")"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
              SubscriptBox["\"\<R\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
              ",", "\"\<:  \>\"", ",", 
              RowBox[{
               RowBox[{"lhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
              ",", "\"\< = \>\"", ",", 
              RowBox[{"rhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ls01", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       FractionBox[
        RowBox[{"a", "[", "t", "]"}], 
        RowBox[{
         RowBox[{"a", "'"}], "[", "t", "]"}]], 
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "1"}], "]"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can simplify \!\(\*SubscriptBox[\(R\), \(01\)]\) \
and solve it for \[GothicCapitalC]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(01\)]\):  \>\"", ",", 
      RowBox[{"ls01", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"0", ",", "1"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[GothicCapitalC]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "1"}], "]"}]}], ",", 
        RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], ",", "r"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "k"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[GothicCapitalC](r) = \>\"", ",", 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], 
      ",", "\"\< where k is a constant of integration.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs04", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "-", 
       RowBox[{"3", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs04", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"0", ",", "0"}], "]"}], "-", 
      RowBox[{"3", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can also \
\!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) solve \
\!\(\*SubscriptBox[\(R\), \(00\)]\)-3\!\(\*SubscriptBox[\(R\), \(44\)]\) for \
\[ScriptCapitalA]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(00\)]\)-3\!\(\*SubscriptBox[\(R\), \(44\)]\):  \>\"", ",", 
      RowBox[{"lhs04", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      "rhs04"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", 
      RowBox[{"Last", "[", 
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"lhs04", "==", "rhs04"}], ",", 
         RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}]}], "]"}], "]"}]}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptCapitalA](t) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesLE"}], 
      ",", "\"\<.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<When we do this, the equations become\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"k", "=", 
     RowBox[{"1", "/", "\[CapitalLambda]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<When we set k = \!\(\*FractionBox[\(1\), \(\
\[CapitalLambda]\)]\) for \[CapitalLambda]\[NotEqual]0 , all of the equations \
are satisfied and we have found a solution to the \
\[CapitalLambda]\[NotEqual]0 field equations:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<     a(t) = is a free parameter,\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     A(t,r) = \>\"", ",", 
      RowBox[{
       RowBox[{"A", "[", 
        RowBox[{"t", ",", "r"}], "]"}], " ", "/.", "rulesLE"}], 
      ",", "\"\<  where \[CapitalLambda]\[NotEqual]0,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     B(t,r) = \>\"", ",", 
      RowBox[{"B", "[", 
       RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[DoubleStruckCapitalC](t,r) = \[GothicCapitalC](r) = \
\>\"", ",", 
      RowBox[{"\[DoubleStruckCapitalC]", "[", 
       RowBox[{"t", ",", "r"}], "]"}], 
      ",", "\"\<  where k is a free constant,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[DoubleStruckCapitalD](t,r) = \
a[t\!\(\*SuperscriptBox[\(]\), \(2\)]\),\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
