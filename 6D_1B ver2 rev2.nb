    3.977078597129016*^9, 3.9770796735652647`*^9, 3.97708240331208*^9, 
    3.977083799040372*^9, 3.977084046671598*^9, 3.977137876092766*^9, 
    3.977138494955165*^9, 3.977138638912294*^9, 3.977138802846717*^9, 
