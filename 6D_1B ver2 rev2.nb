Cell[BoxData[{
 RowBox[{
  RowBox[{"Print", "[", 
   RowBox[{"\"\<\!\(\*StyleBox[\"Computational\",FontWeight->\"Bold\",\
FontColor->RGBColor[0, 0, 1]]\)\!\(\*StyleBox[\" \
\",FontWeight->\"Bold\",FontColor->RGBColor[0, 0, 1]]\)\!\(\*StyleBox[\"steps\
\",FontWeight->\"Bold\",FontColor->RGBColor[0, 0, 1]]\)\!\(\*StyleBox[\" \
\",FontWeight->\"Bold\",FontColor->RGBColor[0, 0, \
1]]\)\!\(\*StyleBox[\"for\",FontWeight->\"Bold\",FontColor->RGBColor[0, 0, \
1]]\)\!\(\*StyleBox[\(\*StyleBox[\" \
\",FontWeight->\"Bold\",FontColor->RGBColor[0, 0, 1]]\\\ \)]\)\>\"", ",", 
    "indexR", ",", "\"\<: \>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Print", "[", "]"}], ";", 
  RowBox[{
  "Print", "[", "\"\<Methodology: Fix \[Mu], \[Nu], and \[Sigma]. Then we can \
write \>\"", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
  "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(\[Mu]\[Nu]\)]\) = \
\!\(\*SubscriptBox[\(\[Sum]\), \(\\\ \(\[Sigma]\)\)]\)[R(\[Sigma])+\
\[CapitalGamma](\[Sigma])] \>\"", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
  "Print", "[", "\"\<where R(\[Sigma]) = \!\(\*SubscriptBox[\"\[PartialD]\", \
FormBox[StyleBox[\"\[Nu]\",FontFamily->\"Symbol\",FontWeight->\"Regular\"],\
TraditionalForm]]\)\!\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \(\[Mu]\
\[Sigma]\), \(\[Sigma]\)]\) \[Dash] \!\(\*SubscriptBox[\(\[PartialD]\), \(\
\[Sigma]\)]\)\!\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \(\[Mu]\[Nu]\), \(\
\[Sigma]\)]\)\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
  "Print", "[", "\"\<and   \[CapitalGamma](\[Sigma]) = \!\(\*SubscriptBox[\(\
\[Sum]\), \(\\\ \(\[Rho]\)\)]\)[\!\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \
\(\[Mu]\[Sigma]\), \(\[Rho]\)]\)\!\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \
\(\[Rho]\[Nu]\), \(\[Sigma]\)]\) \[Dash] \!\(\*SubsuperscriptBox[\(\
\[CapitalGamma]\), \(\[Mu]\[Nu]\), \(\[Rho]\)]\)\!\(\*SubsuperscriptBox[\(\
\[CapitalGamma]\), \(\[Rho]\[Sigma]\), \(\[Sigma]\)]\)]\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
   "Print", "[", "\"\<Also  \[CapitalGamma](\[Sigma]) = \!\(\*SubscriptBox[\(\
\[Sum]\), \(\\\ \(\[Rho]\)\)]\)\[CapitalGamma](\[Sigma],\[Rho])  where  \
\[CapitalGamma](\[Sigma],\[Rho]) = \
\!\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \(\[Mu]\[Sigma]\), \(\[Rho]\)]\)\
\!\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \(\[Rho]\[Nu]\), \(\[Sigma]\)]\) \
\[Dash] \!\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \(\[Mu]\[Nu]\), \(\[Rho]\
\)]\)\!\(\*SubsuperscriptBox[\(\[CapitalGamma]\), \(\[Rho]\[Sigma]\), \(\
\[Sigma]\)]\)\>\"", "]"}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"For", "[", 
  RowBox[{
   RowBox[{"\[Mu]", "=", "dimL"}], ",", 
   RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
   RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
   RowBox[{"For", "[", 
    RowBox[{
     RowBox[{"\[Nu]", "=", "dimL"}], ",", 
     RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
     RowBox[{"\[Nu]", "++"}], ",", "\n", 
     RowBox[{
      RowBox[{
       RowBox[{"r\[Mu]\[Nu]", "[", 
        RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "=", "0"}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{"Recomputing", " ", "R", 
        RowBox[{"(", 
         RowBox[{"\[Mu]", ",", "\[Nu]"}], ")"}], " ", "using", " ", 
        "variable", " ", "r\[Mu]\[Nu]", 
        RowBox[{"(", 
         RowBox[{"\[Mu]", ",", "\[Nu]"}], ")"}]}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"TFHead", "=", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Head", "[", 
          RowBox[{"R", "[", 
           RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "]"}], "===", "Integer"}], 
        ")"}]}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{
        RowBox[{"True", " ", "only", " ", "if", " ", 
         RowBox[{"R", "[", 
          RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "=", "0"}], " ", "*)"}], 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"flag6", "==", "1"}], ",", 
        RowBox[{"TFHead", "=", "False"}]}], "]"}], ";", " ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "Make", " ", "false", " ", "so", " ", "all", " ", "cases", " ", 
        "print"}], " ", "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", " ", "[", 
       RowBox[{
        RowBox[{"TFHead", "==", "False"}], ",", " ", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"i", ".", "e", ".", " ", 
           SubscriptBox["R", "\[Mu]\[Nu]\[Gamma]"]}], " ", "\[NotEqual]", " ",
           "0"}], " ", "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"(*", " ", 
         RowBox[{"Summary", " ", 
          RowBox[{"row", ":", " ", 
           RowBox[{"The", " ", "value", " ", "of", " ", 
            SubscriptBox["R", "\[Mu]\[Nu]"], " ", "already", " ", "computed", 
            " ", "for", " ", "this", " ", "\[Mu]", " ", "and", " ", 
            "\[Nu]"}]}]}], "   ", "*)"}], "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           RowBox[{"Style", "[", 
            RowBox[{"index1", ",", "Bold", ",", "Magenta"}], "]"}], ",", 
           " ", "\"\<\!\(\*StyleBox[\"=\",FontWeight->\"Bold\",FontColor->\
RGBColor[1, 0, 1]]\)\>\"", ",", " ", 
           RowBox[{"Style", "[", 
            RowBox[{"\[Mu]", ",", "Bold", ",", "Magenta"}], "]"}], ",", 
           " ", "\"\<  \>\"", ",", "\n", " ", 
           RowBox[{"Style", "[", 
            RowBox[{"index2", ",", "Bold", ",", "Magenta"}], "]"}], ",", 
           " ", "\"\<\!\(\*StyleBox[\"=\",FontWeight->\"Bold\",FontColor->\
RGBColor[1, 0, 1]]\)\>\"", ",", " ", 
           RowBox[{"Style", "[", 
            RowBox[{"\[Nu]", ",", "Bold", ",", "Magenta"}], "]"}], ",", " ", 
           "\n", " ", 
           
           SubscriptBox["\"\<: Show that  \
\!\(\*StyleBox[\"R\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, 1]]\)\>\"", 
            RowBox[{"Style", "[", 
             RowBox[{
              RowBox[{"Row", "[", 
               RowBox[{"{", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}], ",", "Bold", ",",
               "Magenta"}], "]"}]], ",", "\"\< = \>\"", " ", ",", 
           RowBox[{
            RowBox[{"R", "[", 
             RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\<:\>\""}], "]"}], ";", "\[IndentingNewLine]", 
         "\[IndentingNewLine]", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"\[Sigma]", "=", "dimL"}], ",", 
           RowBox[{"\[Sigma]", "\[LessEqual]", "dimH"}], ",", 
           RowBox[{"\[Sigma]", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{"(*", " ", 
            RowBox[{
             RowBox[{
              RowBox[{"Compute", " ", "R", 
               RowBox[{"(", "\[Sigma]", ")"}]}], "=", " ", 
              RowBox[{
               SubscriptBox["\[PartialD]", 
                FormBox[
                 StyleBox["\[Nu]",
                  FontFamily->"Symbol",
                  FontWeight->"Regular"],
                 TraditionalForm]], 
               
               SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Sigma]", 
                "\[Sigma]"]}]}], " ", "\[Dash]", " ", 
             RowBox[{
              RowBox[{
               SubscriptBox["\[PartialD]", "\[Sigma]"], 
               
               SubsuperscriptBox["\[CapitalGamma]", "\[Mu]\[Nu]", 
                "\[Sigma]"]}], " ", "for", " ", "this", " ", "\[Mu]", " ", 
              "and", " ", "\[Nu]"}]}], " ", "*)"}], " ", "\n", "\t\t", 
           RowBox[{
            RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"R", "[", "\[Sigma]", "]"}], "=", 
             RowBox[{
              RowBox[{"D", "[", 
               RowBox[{
                RowBox[{"\[CapitalGamma]", "[", 
                 RowBox[{"\[Sigma]", ",", "\[Mu]", ",", "\[Sigma]"}], "]"}], ",", 
                RowBox[{"\[ScriptX]", "[", "\[Nu]", "]"}]}], "]"}], " ", "-", 
              " ", 
              RowBox[{"D", "[", 
               RowBox[{
                RowBox[{"\[CapitalGamma]", "[", 
                 RowBox[{"\[Sigma]", ",", "\[Mu]", ",", "\[Nu]"}], "]"}], ",", 
                RowBox[{"\[ScriptX]", "[", "\[Sigma]", "]"}]}], "]"}]}]}], ";",
             "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{"\"\<R(\>\"", ",", "\[Sigma]", ",", 
              SubscriptBox["\"\<) = \[PartialD]\>\"", 
               RowBox[{"\[ScriptX]", "[", "\[Nu]", "]"}]], ",", 
              SubsuperscriptBox["\"\<\[CapitalGamma]\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Sigma]"}], "}"}], "]"}], 
               RowBox[{"Text", "[", "\[Sigma]", "]"}]], ",", 
              SubscriptBox["\"\< - \[PartialD]\>\"", 
               RowBox[{"\[ScriptX]", "[", "\[Sigma]", "]"}]], ",", 
              SubsuperscriptBox["\"\<\[CapitalGamma]\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}], 
               RowBox[{"Text", "[", "\[Sigma]", "]"}]], ",", 
              SubscriptBox["\"\< = \[PartialD]\>\"", 
               RowBox[{"\[ScriptX]", "[", "\[Nu]", "]"}]], ",", 
              "\n", "\"\<(\>\"", ",", 
              RowBox[{
               RowBox[{"\[CapitalGamma]", "[", 
                RowBox[{"\[Sigma]", ",", "\[Mu]", ",", "\[Sigma]"}], "]"}], "/.",
                "rulesDisp"}], ",", 
              SubscriptBox["\"\<) \[Dash] \[PartialD]\>\"", 
               RowBox[{"\[ScriptX]", "[", "\[Sigma]", "]"}]], ",", "\"\<(\>\"",
               ",", 
              RowBox[{
               RowBox[{"\[CapitalGamma]", "[", 
                RowBox[{"\[Sigma]", ",", "\[Mu]", ",", "\[Nu]"}], "]"}], "/.",
                "rulesDisp"}], ",", "\n", "\"\<) = [\>\"", ",", 
              RowBox[{
               RowBox[{"D", "[", 
                RowBox[{
                 RowBox[{"\[CapitalGamma]", "[", 
                  RowBox[{"\[Sigma]", ",", "\[Mu]", ",", "\[Sigma]"}], "]"}], 
                 ",", 
                 RowBox[{"\[ScriptX]", "[", "\[Nu]", "]"}]}], "]"}], "/.", 
               "rulesDisp"}], ",", "\"\<] \[Dash] [\>\"", ",", 
              RowBox[{
               RowBox[{"D", "[", 
                RowBox[{
                 RowBox[{"\[CapitalGamma]", "[", 
