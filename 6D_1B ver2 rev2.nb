 "\"  or else expressions like ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["k", "1"], "'"}], 
    SubscriptBox["k", "1"]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8cc491a9-4bec-4b4e-9cf7-0893f017fd1f"],
 " cause a mess \n\tI avoid this need for quotes: \n\t     For example,  \
instead of using ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["k", "1"], "'"}], "[", "r", "]"}], TraditionalForm]],
  ExpressionUUID->"1c9f6689-12d8-42a7-9234-d2a96a8c1126"],
 " in rulesDisp, I use  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"x_", "'"}], "[", "r", "]"}], "\[RuleDelayed]", 
    SuperscriptBox["x", 
     StyleBox["\[Prime]",
      FontSize->13,
      FontWeight->"Regular",
      FontSlant->"Plain"]]}], TraditionalForm]],ExpressionUUID->
  "903fb997-4fba-4eee-bbd3-8ee4469d20c6"],
 "  \n\t     where x_ stands for any parameter\n\n",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Clear", "[", "K", "]"}], " ", "works", " ", "but", " ", 
   RowBox[{"Clear", "[", 
    SubscriptBox["K", "1"], "]"}], " ", "gives", " ", "an", " ", "error", " ",
    "message", " ", "that", " ", 
   SubscriptBox["K", "1"], " ", "is", " ", "not", " ", "a", " ", 
   "variable"}]], "Text",
