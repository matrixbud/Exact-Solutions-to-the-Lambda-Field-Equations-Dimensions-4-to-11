   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Since a(t) is not allowed to be a constant in Case c, \
then \!\(\*OverscriptBox[\(a\), \(.\)]\)\[NotEqual]0, and we can simplify and \
solve \!\(\*SubscriptBox[\(R\), \(01\)]\) by multiplying both sides \
by\!\(\*FractionBox[\(a\), \(2 \*OverscriptBox[\(a\), \(.\)]\)]\):\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(01\)]\):  \>\"", ",", 
