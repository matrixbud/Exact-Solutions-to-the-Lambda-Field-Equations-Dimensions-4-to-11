\[ScriptCapitalA]:\>\"", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     2\!\(\*SubscriptBox[\(R\), \
\(44\)]\)-\!\(\*SubscriptBox[\(R\), \(00\)]\):  \>\"", ",", 
      RowBox[{"lhs40", "/.", "rulesDisp"}], ",", 
      RowBox[{"\"\< = \>\"", "rhs40"}]}], "]"}], ";"}], "\[IndentingNewLine]",
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", 
