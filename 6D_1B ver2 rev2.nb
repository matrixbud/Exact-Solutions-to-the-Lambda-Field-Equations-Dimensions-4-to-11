   RowBox[{
    RowBox[{
    "Print", "[", "\"\<The RHS of \!\(\*SubscriptBox[\(R\), \(22\)]\) is \
\[CapitalLambda], a constant. In order for the LHS of \
\!\(\*SubscriptBox[\(R\), \(22\)]\) to not be a function of t, a(t) must be a \
constant:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<     a(t) = k, a constant.\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "t_", "]"}], "=", "k"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
