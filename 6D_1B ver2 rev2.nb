   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     B(t,r) = \[CapitalBeta](r) = \
-\!\(\*FractionBox[SuperscriptBox[RowBox[{\"(\", RowBox[{RowBox[{\"2\", \" \
\", RowBox[{\"\[GothicCapitalC]\", \"[\", \"r\", \"]\"}]}], \"+\", \
RowBox[{\"r\", \" \", RowBox[{SuperscriptBox[\"\[GothicCapitalC]\", \
\"\[Prime]\",MultilineFunction->None], \"[\", \"r\", \"]\"}]}]}], \")\"}], \
\"2\"], RowBox[{\"2\", \" \", RowBox[{\"\[GothicCapitalC]\", \"[\", \"r\", \
\"]\"}], \" \", RowBox[{\"(\", RowBox[{RowBox[{\"-\", \"2\"}], \"+\", \
RowBox[{SuperscriptBox[\"r\", \"2\"], \" \", \"\[CapitalLambda]\", \" \", \
RowBox[{\"\[GothicCapitalC]\", \"[\", \"r\", \"]\"}]}]}], \")\"}]}]]\) = \
-\!\(\*FractionBox[\(2\), \(\(-2\) + \[CapitalLambda]\\\ \*SuperscriptBox[\(r\
\), \(2\)]\)]\),\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<and\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     A(t,r) = \[ScriptCapitalA][t] = \
\!\(\*FractionBox[\(2\\\ \*SuperscriptBox[\(c\), \(2\)]\\\ \
\*SuperscriptBox[\(\(\*OverscriptBox[\(a\), \(.\)]\)[t]\), \(2\)]\), \(\
\[CapitalLambda]\\\ \*SuperscriptBox[\(a[t]\), \(2\)]\)]\).\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<However, it is possible we may obtain a different \
solution if we set \[GothicCapitalC](t,r)=1 and B(t,r)=\[CapitalBeta](r) \
before solving the ODEs. Thus, we work this case from scratch to find \
out.\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<The resulting field equations are identical to the 5D \
case except that \!\(\*SubscriptBox[\(R\), \(44\)]\) has one extra term:\>\"",
      "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
