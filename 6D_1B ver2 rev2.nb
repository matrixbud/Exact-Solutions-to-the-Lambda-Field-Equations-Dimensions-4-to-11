Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Use", " ", "Print", " ", "statements", " ", "and", " ", "then", " ", 
     "view", " ", "results", " ", "in", " ", "the", " ", "output"}], ",", " ", 
    RowBox[{"not", " ", "in", " ", "this", " ", "code"}]}], " ", "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Print", "[", "case", "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{"lhs", " ", "and", " ", "rhs", " ", 
      RowBox[{"(", "below", ")"}], " ", "set", " ", "field", " ", "equations",
       " ", "to", " ", "express", " ", "\[IndentingNewLine]", "         ", 
      FractionBox[
       SubscriptBox["R", "\[Mu]\[Nu]"], 
       SubscriptBox["g", "\[Mu]\[Nu]"]]}], " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"\[CapitalLambda]", " ", "if", " ", 
        SubscriptBox["g", "\[Mu]\[Nu]"]}], "\[NotEqual]", 
       RowBox[{"0", " ", "\[IndentingNewLine]", "  ", "and", "   ", 
        SubscriptBox["R", "\[Mu]\[Nu]"]}]}], " ", "=", " ", 
      RowBox[{
      "0", "   ", "otherwise", " ", "\[IndentingNewLine]", "   ", "lhs", " ", 
       "uses", " ", 
       RowBox[{
        RowBox[{"Expand", "[", "Simplify", "]"}], ".", " ", "lhsF"}], " ", 
       "uses", " ", 
       RowBox[{"Expand", "[", "FullSimplify", "]"}]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"lhs", "[", 
      RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "leftside", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"g", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"leftside", " ", "=", 
           RowBox[{"R", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], ",", 
          RowBox[{"leftside", "=", 
           RowBox[{"xS", "[", 
            RowBox[{
             RowBox[{"R", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/", 
             RowBox[{"g", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}]}], "]"}], ";",
         "leftside"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"lhsF", "[", 
      RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "leftside", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"g", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"leftside", " ", "=", 
           RowBox[{"R", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], ",", 
          RowBox[{"leftside", "=", 
           RowBox[{"xF", "[", 
            RowBox[{
             RowBox[{"R", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/", 
             RowBox[{"g", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}]}], "]"}], ";",
         "leftside"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"lhsP", "[", 
      RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "leftside", "}"}], ",", "  ", 
       RowBox[{"(*", " ", "PowerExpand", " ", "*)"}], "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"g", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"leftside", " ", "=", 
           RowBox[{"R", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], ",", 
          RowBox[{"leftside", "=", 
           RowBox[{"PowerExpand", "[", 
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "]"}]}]}], "]"}], ";", 
        "leftside"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"rhs", "[", 
      RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "rightside", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"g", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{"rightside", " ", "=", 
           RowBox[{"\[CapitalLambda]", " ", 
            RowBox[{"g", "[", 
             RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ",", 
          RowBox[{"rightside", "=", "\[CapitalLambda]"}]}], "]"}], ";", 
        "rightside"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<The Lambda field equations can be represented as \
\!\(\*FractionBox[SubscriptBox[\(R\), \(\[Mu]\[Nu]\)], SubscriptBox[\(g\), \(\
\[Mu]\[Nu]\)]]\) = \[CapitalLambda]:\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"R", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], "&&", 
               RowBox[{
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "===", "0"}]}], 
              ")"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
              SubscriptBox["\"\<R\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
              ",", "\"\<:  \>\"", ",", 
              RowBox[{
               RowBox[{"lhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
              ",", "\"\< = \>\"", ",", 
              RowBox[{"rhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We observed in Notebook 6D_1 that \
\!\(\*SubscriptBox[\(R\), \(33\)]\) is redundant and, so, \!\(\*SubscriptBox[\
\(R\), \(33\)]\) is omitted here and in all of the 6D notebooks.\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We observe here that \!\(\*SubscriptBox[\(R\), \(55\)]\
\), also, is redundant, the same as \!\(\*SubscriptBox[\(R\), \(44\)]\).\>\"",
      "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<The remaining equations are identical to the 5D case \
except for the magnitude of two or three of the coefficients. Thus, this \
notebook will closely follow the 5D notebook.\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<The reason that the equations are so closely identical \
is because the 5D case does not have \
\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\) terms, and this case does \
not have \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\) or \
\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(5\)]\) terms.\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<\!\(\*StyleBox[\"a\",FontWeight->\"Bold\",FontColor->RGBColor[0.\
