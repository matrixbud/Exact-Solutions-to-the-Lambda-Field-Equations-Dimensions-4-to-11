\" \", \"\[Alpha]\", \"  \", SuperscriptBox[RowBox[{SuperscriptBox[\"\
\[GothicCapitalD]\", \"\[Prime]\",MultilineFunction->None], \"[\", \"r\", \"]\
\"}], \"2\"]}], RowBox[{\"\[GothicCapitalD]\", \"[\", \"r\", \"]\"}]]\)\
\[InvisibleSpace]  where \[Alpha] is a free constant,\>\"", "]"}], ";", "\n", 
     
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[DoubleStruckCapitalC](t,r) = \[GothicCapitalC](r) = \
\>\"", ",", 
       RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], 
       ",", "\"\<  where \[Beta] is a free constant,\>\""}], "]"}], ";", "\n", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[DoubleStruckCapitalD](t,r) = \>\"", ",", 
       RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], " ", 
       ",", "\"\<  a free parameter,\>\""}], "]"}], ";", "\n", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<and line element\>\"", "]"}], ";", "\n", 
     RowBox[{"Print", "[", 
