9855344472419318, 0.00946059357595178, 0.9991760128175784]]\)\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"Clear", "[", 
      RowBox[{"\[CapitalBeta]", ",", "\[GothicCapitalC]"}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs124", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"1", ",", "1"}], "]"}], "-", 
        RowBox[{"2", 
         RowBox[{"lhs", "[", 
          RowBox[{"2", ",", "2"}], "]"}]}], "-", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs124", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"rhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}], "-", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Rather than solving for \[CapitalBeta] as in Solution \
1, we can algebraically solve \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \(44\
\)]\) for \[CapitalBeta](r):\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Print", "[", 
       RowBox[{"\"\<    \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \(44\
\)]\): \>\"", ",", 
        RowBox[{"lhs124", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
        "rhs124"}], "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", 
        RowBox[{"Last", "[", 
         RowBox[{"Solve", "[", 
          RowBox[{
           RowBox[{"lhs124", "==", "rhs124"}], ",", 
           RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], "]"}]}]}]}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesDisp"}]}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging back in, \!\(\*SubscriptBox[\(R\), \(11\)]\) \
and \!\(\*SubscriptBox[\(R\), \(44\)]\) are somewhat lengthy. However, \
\!\(\*SubscriptBox[\(R\), \(22\)]\) is reasonably succinct:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}], "/.", "rulesDisp"}], 
       ",", "\"\< = \>\"", ",", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"lhs22", "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{"lhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<or\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
       RowBox[{"lhs22", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"num22", "=", 
      RowBox[{
       RowBox[{"Numerator", "[", "lhs22", "]"}], "/", 
       RowBox[{"\[GothicCapitalD]", "[", "r", "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can ignore the denominator. Since \
\[GothicCapitalD](r)\[NotEqual]0, we have\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
       RowBox[{"num22", "/.", "rulesDisp"}], ",", "\"\< = 0\>\""}], "]"}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[GothicCapitalC]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"Simplify", "[", 
        RowBox[{"DSolveValue", "[", 
         RowBox[{
          RowBox[{"num22", "==", "0"}], ",", 
          RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], ",", "r"}], "]"}], 
        "]"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}], ",", 
         RowBox[{
          RowBox[{"C", "[", "2", "]"}], "->", "k"}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Solving for \[GothicCapitalC] yields\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[GothicCapitalC](r) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], "/.", "rulesDisp"}], 
