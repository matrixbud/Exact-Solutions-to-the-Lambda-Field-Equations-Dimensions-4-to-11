\"2\"],FontWeight->\"Bold\",FontColor->RGBColor[0.9855344472419318, \
0.00946059357595178, 0.9991760128175784]]\)\>\"", "]"}], "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"A", "[", 
        RowBox[{"t_", ",", "r_"}], "]"}], "=", 
       SuperscriptBox["c", "2"]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[DoubleStruckCapitalC]", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
