\",FontColor->RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\"1\",FontColor->RGBColor[0.\
9855344472419318, 0.00946059357595178, 0.9991760128175784]]\)\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<All of the equations have been solved, and so we have \
an exact solution to the \[CapitalLambda]=0 field equations:\>\"", "]"}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     A(t,r) = \>\"", ",", 
       RowBox[{"A", "[", 
        RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<, a free parameter\>\""}], 
      "]"}], ";", "\n", 
     RowBox[{
     "Print", "[", "\"\<     B(t,r) = \[CapitalBeta](r) = \
\!\(\*FractionBox[RowBox[{SuperscriptBox[\"r\", \"4\"], \" \", \
