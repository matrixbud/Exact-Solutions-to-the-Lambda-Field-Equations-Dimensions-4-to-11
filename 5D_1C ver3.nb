Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \"\>", "\[InvisibleSpace]", 
   TemplateBox[{
     TemplateBox[{
       TemplateBox[{
         TemplateBox[{
           
           TemplateBox[{
            "\"\\!\\(\\*SuperscriptBox[\\(ds\\), \\(2\\)]\\) = \"", "\"\"", 
             TemplateBox[{
               FractionBox[
                RowBox[{
                  SuperscriptBox["c", "2"], " ", 
                  SuperscriptBox[
                   RowBox[{
                    OverscriptBox["a", "."], "[", "t", "]"}], "2"]}], "k"], 
               "\" d\"", 
               SuperscriptBox["t", "2"]}, "RowDefault"]}, "RowDefault"], 
           "\" - \"", 
           TemplateBox[{
             FractionBox[
              RowBox[{
                SuperscriptBox[
                 RowBox[{"a", "[", "t", "]"}], "2"], " ", 
                SuperscriptBox[
                 RowBox[{"(", 
                   RowBox[{
                    RowBox[{"2", " ", 
                    RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], "+", 
                    RowBox[{"r", " ", 
                    RowBox[{
                    SuperscriptBox[
                    "\[GothicCapitalC]", "\[Prime]", MultilineFunction -> 
                    None], "[", "r", "]"}]}]}], ")"}], "2"]}], 
              RowBox[{"4", " ", 
                RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], " ", 
                RowBox[{"(", 
                  RowBox[{"1", "+", 
                    RowBox[{"k", " ", 
                    SuperscriptBox["r", "2"], " ", 
                    RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}]}], 
                  ")"}]}]], "\" d\"", 
             SuperscriptBox["r", "2"]}, "RowDefault"]}, "RowDefault"], 
         "\" - \"", 
         TemplateBox[{
           RowBox[{
             SuperscriptBox["r", "2"], " ", 
             SuperscriptBox[
              RowBox[{"a", "[", "t", "]"}], "2"], " ", 
             RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], "\" d\"", 
           SuperscriptBox["\[Theta]", "2"]}, "RowDefault"]}, "RowDefault"], 
       "\" - \"", 
       TemplateBox[{
         RowBox[{
           SuperscriptBox["r", "2"], " ", 
           SuperscriptBox[
            RowBox[{"a", "[", "t", "]"}], "2"], " ", 
           SuperscriptBox[
            RowBox[{"Sin", "[", "\[Theta]", "]"}], "2"], " ", 
           RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], "\" d\"", 
         SuperscriptBox["\[Phi]", "2"]}, "RowDefault"]}, "RowDefault"], 
     "\" - \"", 
     TemplateBox[{
       SuperscriptBox["p", "2"], "\" d\"", 
       SuperscriptBox["\[Psi]", "2"]}, "RowDefault"]},
    "RowDefault"]}],
  SequenceForm["     ", 
   Row[{
     Row[{
       Row[{
         Row[{
           Row[{"\!\(\*SuperscriptBox[\(ds\), \(2\)]\) = ", "", 
             
             Row[{$CellContext`c^2 $CellContext`k^(-1) 
               OverDot[$CellContext`a, 1][$CellContext`t]^2, 
               " d", $CellContext`t^2}]}], " - ", 
           
           Row[{Rational[
              1, 4] $CellContext`a[$CellContext`t]^2 $CellContext`\
\[GothicCapitalC][$CellContext`r]^(-1) (
               1 + $CellContext`k $CellContext`r^2 $CellContext`\
\[GothicCapitalC][$CellContext`r])^(-1) (
               2 $CellContext`\[GothicCapitalC][$CellContext`r] + \
$CellContext`r Derivative[
                 1][$CellContext`\[GothicCapitalC]][$CellContext`r])^2, 
             " d", $CellContext`r^2}]}], " - ", 
         Row[{$CellContext`r^2 $CellContext`a[$CellContext`t]^2 $CellContext`\
\[GothicCapitalC][$CellContext`r], " d", $CellContext`\[Theta]^2}]}], " - ", 
       Row[{$CellContext`r^2 $CellContext`a[$CellContext`t]^2 
         Sin[$CellContext`\[Theta]]^2 \
$CellContext`\[GothicCapitalC][$CellContext`r], 
         " d", $CellContext`\[Phi]^2}]}], " - ", 
     Row[{$CellContext`p^2, " d", $CellContext`\[Psi]^2}]}]],
  Editable->False]], "Print",
