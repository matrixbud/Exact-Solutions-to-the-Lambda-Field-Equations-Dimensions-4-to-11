0.9991760128175784]]\)\!\(\*StyleBox[\"1\",FontWeight->\"Bold\",FontColor->\
RGBColor[0.9855344472419318, 0.00946059357595178, 0.9991760128175784]]\)\>\"",
       "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[DoubleStruckCapitalC]", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", "1"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<The resulting field equations are:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
           RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
           RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"R", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", 
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ")"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"Print", "[", 
              RowBox[{
               SubscriptBox["\"\<R\>\"", 
                RowBox[{"Row", "[", 
                 RowBox[{"{", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
               ",", "\"\<:  \>\"", ",", 
               RowBox[{
                RowBox[{"lhs", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
               ",", "\"\< = \>\"", ",", 
               RowBox[{"rhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We note again that \!\(\*SubscriptBox[\(R\), \
\(01\)]\) does not appear because it is the identity 0=0.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs0124", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"0", ",", "0"}], "]"}], "-", 
        RowBox[{"lhs", "[", 
         RowBox[{"1", ",", "1"}], "]"}], "+", 
        RowBox[{"2", 
         RowBox[{"lhs", "[", 
          RowBox[{"2", ",", "2"}], "]"}]}], "+", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs0124", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "-", 
       RowBox[{"rhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "+", 
       RowBox[{"2", 
        RowBox[{"rhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}], "+", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(11\)]\)+2\!\(\*SubscriptBox[\(R\), \(22\
\)]\)+\!\(\*SubscriptBox[\(R\), \(44\)]\) can be solved \
\!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) for \[CapitalBeta]:\
\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(11\)]\)+2\!\(\*SubscriptBox[\(R\), \(22\
\)]\)+\!\(\*SubscriptBox[\(R\), \(44\)]\):  \>\"", ",", 
       RowBox[{"lhs0124", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rhs0124"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", 
       RowBox[{"Last", "[", 
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{"lhs0124", "==", "rhs0124"}], ",", 
          RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"\[CapitalBeta]r", "=", 
      RowBox[{"Collect", "[", 
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"A", "[", 
           RowBox[{"t", ",", "r"}], "]"}], ",", 
          RowBox[{"D", "[", 
           RowBox[{
            RowBox[{"A", "[", 
             RowBox[{"t", ",", "r"}], "]"}], ",", "r"}], "]"}]}], "}"}]}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesDisp"}]}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<          = \>\"", ",", 
       RowBox[{"\[CapitalBeta]r", "/.", "rulesDisp"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<In order for the 2nd term on the line above to be \
strictly a function of r, we must have that \
\!\(\*FractionBox[RowBox[{SuperscriptBox[\"A\", \
FormBox[StyleBox[\"\[Prime]\",FontSize->13,FontWeight->\"Regular\",FontSlant->\
\"Plain\"],TraditionalForm]], RowBox[{\"(\", RowBox[{\"t\", \",\", \"r\"}], \
\")\"}]}], RowBox[{\"A\", RowBox[{\"(\", RowBox[{\"t\", \",\", \"r\"}], \
\")\"}]}]]\) = \[GothicF](r) for some function \[GothicF] of r (possibly \
constant).\>\"", "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"A", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{
           SubscriptBox["\[PartialD]", "r"], 
           RowBox[{"A", "[", 
            RowBox[{"t", ",", "r"}], "]"}]}], "==", 
          RowBox[{
           RowBox[{"\[GothicF]", "[", "r", "]"}], 
           RowBox[{"A", "[", 
            RowBox[{"t", ",", "r"}], "]"}]}]}], ",", 
         RowBox[{"A", "[", 
          RowBox[{"t", ",", "r"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "r"}], "}"}]}], "]"}], "/.", 
       RowBox[{
        RowBox[{
         RowBox[{"C", "[", "1", "]"}], "[", "t", "]"}], "->", 
        SuperscriptBox[
         RowBox[{"a", "[", "t", "]"}], "2"]}]}]}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Solving \!\(\*SubscriptBox[\(\[PartialD]\), \
\(r\)]\)A(t,r)=\[GothicF](r)A(t,r) yields:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     A(t,r) = \>\"", ",", 
       RowBox[{
        RowBox[{"A", "[", 
         RowBox[{"t", ",", "r"}], "]"}], "/.", "rulesKr"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<     where we use the scale factor a(t) for the \
t-portion of A(t,r).\>\"", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   B(r) = \>\"", ",", 
       RowBox[{"\[CapitalBeta]r", "/.", "rulesDisp"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<          = \>\"", ",", 
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesDisp"}]}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Clear", "[", "\[CapitalBeta]", "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Observe that the A terms have canceled out and, so, \
\[CapitalBeta] is strictly a function of r.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging in both A(t,r) and \[CapitalBeta](r) makes \
the equations much more unwieldly.\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<If we only plug in A(t,r), the equations are more \
tractible, roughly resembling the original equations but with all mention of \
variable t eliminated:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(00\)]\)-\!\(\
\*SubscriptBox[\(R\), \(11\)]\)+\!\(\*SubscriptBox[\(R\), \(44\)]\) for f, \
and then either \!\(\*SubscriptBox[\(R\), \(22\)]\) for \[GothicCapitalD] or \
2\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \(44\)]\) for \
\[CapitalBeta]. But neither of those strategies, nor many more that I tried, \
led to a solution of the field equations.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<This subscase is too difficult for me to solve.\>\"", 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Clear", "[", 
       RowBox[{
       "A", ",", "B", ",", "\[CapitalBeta]", ",", "\[DoubleStruckCapitalC]", ",",
         "\[GothicCapitalC]", ",", "\[GothicF]", ",", "\[ScriptCapitalF]"}], 
       "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", \
"\"\<\!\(\*StyleBox[\"biii\",FontWeight->\"Bold\",FontColor->RGBColor[0.\
