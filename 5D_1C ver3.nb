     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Hence, we do not get the nice formula from above for \
\[GothicCapitalD].\>\"", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can \
\!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) solve for \
\[CapitalBeta] in \!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(11\)]\)+2\!\(\*SubscriptBox[\(R\), \(22\
\)]\)+\!\(\*SubscriptBox[\(R\), \(44\)]\), but the expression is lengthy, and \
it makes the other equations even more difficult.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can also eliminate \[GothicCapitalD], resulting in \
only 3 unknowns in \!\(\*SubscriptBox[\(R\), \(00\)]\)+\!\(\*SubscriptBox[\(R\
\), \(11\)]\)+2\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \
\(44\)]\), but the equation is too complex to solve.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<This case is too difficult to solve. The next \
strategy is to try subcases that simplify A(t,r), and then cases that \
simplify B(t,r) and/or C(t,r)\>\"", "]"}], ";", "\[IndentingNewLine]", 
