 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[CapitalGamma]\[CapitalGamma]", "[", 
     RowBox[{"\[Mu]_", ",", "\[Nu]_", ",", "\[Sigma]_"}], "]"}], ":=", 
    RowBox[{"Simplify", "[", 
