      RowBox[{
       RowBox[{
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[CapitalGamma]", "[", 
           RowBox[{"\[Sigma]", ",", "\[Mu]", ",", "\[Sigma]"}], "]"}], ",", 
          RowBox[{"\[ScriptX]", "[", "\[Nu]", "]"}]}], "]"}], "-", 
        RowBox[{"D", "[", 
         RowBox[{
          RowBox[{"\[CapitalGamma]", "[", 
           RowBox[{"\[Sigma]", ",", "\[Mu]", ",", "\[Nu]"}], "]"}], ",", 
          RowBox[{"\[ScriptX]", "[", "\[Sigma]", "]"}]}], "]"}], "+", " ", 
        RowBox[{"\[CapitalGamma]\[CapitalGamma]", "[", 
         RowBox[{"\[Mu]", ",", "\[Nu]", ",", "\[Sigma]"}], "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Sigma]", ",", "dimL", ",", "dimH"}], "}"}]}], "]"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"RMat", "=", 
   RowBox[{"Table", "[", 
