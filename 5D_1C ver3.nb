1]]\)\!\(\*SuperscriptBox[StyleBox[\")\",FontWeight->\"Bold\",FontColor->\
RGBColor[1, 0, 1]], \
StyleBox[\"2\",FontWeight->\"Bold\",FontColor->RGBColor[0.9855344472419318, \
0.00946059357595178, 0.9991760128175784]]]\)\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"A", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[DoubleStruckCapitalC]", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Restarting Case b from scratch using these \
constraints, the field equations become:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", " ", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(01\)]\) does not appear \
because we have assumed B(t,r) = \[CapitalBeta](r), which is the solution to \
\!\(\*SubscriptBox[\(R\), \(01\)]\).\>\"", "]"}], ";", "\[IndentingNewLine]", 
     
     RowBox[{
     "Print", "[", "\"\<From \!\(\*SubscriptBox[\(R\), \(00\)]\) we get that \
\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<     \[CapitalLambda] = 0.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[CapitalLambda]", "=", "0"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<By solving the equations in a different order, we are \
able to find two distinct exact solutions to these equation.\>\"", "]"}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", \
"\"\<\!\(\*StyleBox[\"Solution\",FontColor->RGBColor[0.9855344472419318, \
0.00946059357595178, 0.9991760128175784]]\)\!\(\*StyleBox[\" \
\",FontColor->RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\"1\",FontColor->RGBColor[0.\
9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\" \
\",FontColor->RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\"Method\",FontColor->RGBColor[0.\
9855344472419318, 0.00946059357595178, 0.9991760128175784]]\)\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"4", ",", "4"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"4", ",", "4"}], "]"}]}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", "r"}], "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(44\)]\) for \
\[CapitalBeta]: \>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesDisp"}], 
       ",", "\"\<  where \[Alpha] is a constant of integration.\>\""}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(00\)]\) and \
\!\(\*SubscriptBox[\(R\), \(44\)]\) become identities and the remaining \
equations become\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "1"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
         SubscriptBox["\"\<R\>\"", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
          ",", 
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
         ",", "\"\< = \>\"", ",", 
         RowBox[{"rhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs12", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"1", ",", "1"}], "]"}], "-", 
        RowBox[{"2", 
         RowBox[{"lhs", "[", 
          RowBox[{"2", ",", "2"}], "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs12", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"rhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\) can now be solved for \
\[GothicCapitalC]:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
       RowBox[{"lhs12", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rhs12"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"sol", "=", 
      RowBox[{"DSolve", "[", 
       RowBox[{
        RowBox[{"lhs12", "==", "rhs12"}], ",", 
        RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], ",", "r"}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[GothicCapitalC]", "[", "r_", "]"}], "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], "/.", 
         RowBox[{"Last", "[", "sol", "]"}]}], "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"C", "[", "1", "]"}], "->", 
           RowBox[{
            RowBox[{"-", "2"}], "\[Beta]"}]}], ",", 
          RowBox[{
           RowBox[{"a_", " ", 
            RowBox[{"Log", "[", "x_", "]"}]}], "->", 
           RowBox[{"Log", "[", 
            RowBox[{"x", "^", "a"}], "]"}]}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \[GothicCapitalC](r) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], "/.", "rulesDisp"}], 
       ",", "\"\<  where \[Beta] is a constant of integration.\>\""}], "]"}], 
     ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<When we plug these formulas back in, the remaining \
two equations also become identities:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "1"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
         SubscriptBox["\"\<R\>\"", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
          ",", 
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
         ",", "\"\< = \>\"", ",", 
         RowBox[{"rhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", \
"\"\<\!\(\*StyleBox[\"Solution\",FontColor->RGBColor[0.9855344472419318, \
