Cell[TextData[{
 "Mathematica bug sometimes confuses superscript double primes and 2nd \
derivative double primes, so must put ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["A", 
    StyleBox["\[Prime]\[Prime]",
     FontSize->13,
     FontWeight->"Regular",
     FontSlant->"Plain"]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "887dcdc0-7c93-4412-8554-8b9aa539cb79"],
 "[r] in quotes\n\nAlso, when doing replacements like x+y /. \
x\[RuleDelayed]z,  it is generally necessary to put derivatives of \
subscripted variables in quotes \n\te.g., use /.",
 Cell[BoxData[
  RowBox[{" ", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{
      SubscriptBox["k", "1"], "[", "r", "]"}], ",", "r"}], "]"}], " "}]], 
  "Text",
