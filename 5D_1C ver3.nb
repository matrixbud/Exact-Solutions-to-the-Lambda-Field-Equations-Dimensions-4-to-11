       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"lhs12", "==", "rhs12"}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], "]"}]}]}], ";"}],
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
