           RowBox[{"2", ",", "2"}], "]"}]}], ")"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs02", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "-", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"lhs014", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"3", 
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], "+", 
        RowBox[{"lhs", "[", 
         RowBox[{"1", ",", "1"}], "]"}], "-", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs014", "=", 
      RowBox[{
       RowBox[{"3", 
        RowBox[{"rhs", "[", 
         RowBox[{"0", ",", "0"}], "]"}]}], "+", 
       RowBox[{"rhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can solve for \[ScriptCapitalA] in the first \
equation below, and for \[CapitalBeta] in the other:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
       RowBox[{"lhs02", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rhs02"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     3\!\(\*SubscriptBox[\(R\), \
\(00\)]\)+\!\(\*SubscriptBox[\(R\), \(11\)]\)-\!\(\*SubscriptBox[\(R\), \
\(44\)]\):  \>\"", ",", 
       RowBox[{"lhs014", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rhs014"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"lhs02", "==", "rhs02"}], ",", 
         RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "k"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \[ScriptCapitalA](t) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesDisp"}], 
       ",", "\"\<  where k is a constant of integration.\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs014", "=", 
      RowBox[{"Simplify", "[", "lhs014", "]"}]}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   3\!\(\*SubscriptBox[\(R\), \
\(00\)]\)+\!\(\*SubscriptBox[\(R\), \(11\)]\)-\!\(\*SubscriptBox[\(R\), \
\(44\)]\):  \>\"", ",", 
       RowBox[{"lhs014", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rhs014"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"lhs014", "==", "rhs014"}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", "r"}], "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", 
        RowBox[{"\[Beta]", "/", "4"}]}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], 
       ",", "\"\<  where \[Beta] is a constant of integration\>\""}], "]"}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging these formula back in yields\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"!", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{
               RowBox[{"R", "[", 
                RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "===", "0"}], "&&", 
              RowBox[{
               RowBox[{"\[CapitalLambda]", " ", 
                RowBox[{"g", "[", 
                 RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "===", "0"}]}], 
             ")"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{"Print", "[", 
            RowBox[{
             SubscriptBox["\"\<R\>\"", 
              RowBox[{"Row", "[", 
               RowBox[{"{", 
                RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
             ",", "\"\<:  \>\"", ",", 
             RowBox[{
              RowBox[{"lhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
             ",", "\"\< = \>\"", ",", 
             RowBox[{"rhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], 
        "]"}]}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[GothicCapitalD]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"Simplify", "[", 
        RowBox[{"DSolveValue", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"0", ",", "0"}], "]"}], "==", 
           RowBox[{"rhs", "[", 
            RowBox[{"0", ",", "0"}], "]"}]}], ",", 
          RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], ",", "r"}], "]"}], 
        "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", 
        RowBox[{
         RowBox[{"-", "\[CapitalKappa]"}], "/", "4"}]}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(22\)]\) is redundant, the \
same as \!\(\*SubscriptBox[\(R\), \(00\)]\).\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(44\)]\) is redundant, the \
same as 3\!\(\*SubscriptBox[\(R\), \(00\)]\)+\!\(\*SubscriptBox[\(R\), \
\(11\)]\).\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(00\)]\) for \
\[GothicCapitalD]:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \[GothicCapitalD](r) = \!\(\*FractionBox[\(\
\[CapitalKappa]\), \(\[CapitalBeta]\((r)\)\)]\) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], "/.", "rulesDisp"}], 
       ",", "\"\<  where \[CapitalKappa] is a constant of integration\>\""}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"\[CapitalKappa]", "=", "1"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<As usual, since \!\(\*SubscriptBox[\(g\), \(44\)]\) = \
- \[GothicCapitalD](r)\!\(\*SuperscriptBox[\(p\), \(2\)]\), we can fold \
\[CapitalKappa] into the radius p:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[GothicCapitalD](r) = \!\(\*FractionBox[\(1\), \(\
\[CapitalBeta]\((r)\)\)]\) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], "/.", "rulesDisp"}]}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<This formula also satisfies \!\(\*SubscriptBox[\(R\), \
\(11\)]\):\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(11\)]\):  \>\"", ",", 
       RowBox[{"lhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], ",", "\"\< = \>\"", ",", 
       RowBox[{"rhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<All of the equations are satisfied and so we have an \
exact solution to \[CapitalLambda] field equations:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     A(t,r) = \>\"", ",", 
       RowBox[{
        RowBox[{"A", "[", 
         RowBox[{"t", ",", "r"}], "]"}], "/.", "rulesLE"}], 
       ",", "\"\<  where k is a free constant,\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     B(t,r) = \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], 
       ",", "\"\<  where \[Beta] is a free constant,\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[DoubleStruckCapitalC](t,r) = \>\"", ",", 
       RowBox[{"\[DoubleStruckCapitalC]", "[", 
        RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[DoubleStruckCapitalD](t,r) = \[GothicCapitalD](r) = \
\!\(\*FractionBox[\(1\), \(\[CapitalBeta]\((r)\)\)]\) = \>\"", ",", 
       RowBox[{"\[GothicCapitalD]", "[", "r", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<and line element\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \>\"", ",", 
       RowBox[{"lineElem", "/.", "rulesLE"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
