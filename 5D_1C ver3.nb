1]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<There is no solution because A(t,r) is a function of \
both t and r.\>\"", "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Clear", "[", 
       RowBox[{
       "A", ",", "\[ScriptCapitalA]", ",", "B", ",", "\[CapitalBeta]", ",", 
        "\[DoubleStruckCapitalC]", ",", "\[GothicCapitalD]", ",", "a", ",", 
        "\[CapitalKappa]"}], "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
      "Print", "[", \
"\"\<\!\(\*StyleBox[\"c_II\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
