0.9991760128175784]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->\
RGBColor[0.9855344472419318, 0.00946059357595178, 0.9991760128175784]]\)\>\"",
       "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[DoubleStruckCapitalC]", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<The field equations become\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
           RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
           RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"R", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], "&&", 
                
                RowBox[{
                 RowBox[{"\[CapitalLambda]", " ", 
                  RowBox[{"g", "[", 
                   RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "===", "0"}]}], 
               ")"}]}], ",", "\[IndentingNewLine]", 
             RowBox[{"Print", "[", 
              RowBox[{
               SubscriptBox["\"\<R\>\"", 
                RowBox[{"Row", "[", 
                 RowBox[{"{", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
               ",", "\"\<:  \>\"", ",", 
               RowBox[{
                RowBox[{"lhs", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
               ",", "\"\< = \>\"", ",", 
               RowBox[{"rhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
