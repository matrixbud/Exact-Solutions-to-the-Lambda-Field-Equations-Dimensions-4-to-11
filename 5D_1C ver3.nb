Cell[CellGroupData[{

Cell[TextData[StyleBox["Spacetime Geodesic Equations Of Motion",
 FontWeight->"Bold",
 FontColor->RGBColor[1, 0.5, 0]]], "Subsection",
 ShowGroupOpener->{"OutsideFrame", "Inline"},
 CellChangeTimes->{
  3.777917028094368*^9, {3.7779171065814333`*^9, 3.777917108077229*^9}, 
   3.77791726379779*^9, {3.7779228994059153`*^9, 3.77792290065598*^9}, 
   3.777923148955649*^9, 3.777923184038898*^9, 3.818237460918983*^9, {
   3.818237569247446*^9, 3.818237604570527*^9}, {3.8182376387843857`*^9, 
   3.818237642818903*^9}, 3.818237963099587*^9, 3.818238026983062*^9, 
   3.818238296078137*^9, 3.8182385063925343`*^9, 3.818239005664637*^9, 
   3.945895470355603*^9, 3.9458955048978987`*^9, 3.9458962051176767`*^9, {
   3.9459623265131607`*^9, 3.9459623320956287`*^9}, {3.947080532268507*^9, 
   3.9470805333658733`*^9}},ExpressionUUID->"4e67a3e2-9df0-4e64-b581-\
1dd417c7e6d5"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"\[Mu]", "=."}], ";", 
  RowBox[{"\[Nu]", "=."}], ";", 
  RowBox[{"\[Sigma]", "=."}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
  "Print", "[", "\"\<Geodesic Equations for a free particle with mass in the \
rotating frame K, corresponding to (1) the initial equations if this is run \
after initialization of this notebook or (2) the last run Lambda field \
equations case, above:\>\"", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Print", "[", 
    RowBox[{"\"\<     \>\"", ",", 
     RowBox[{"Style", "[", 
      RowBox[{
       RowBox[{"Row", "[", 
        RowBox[{"{", 
         RowBox[{
          
          SuperscriptBox["\"\<\!\(\*OverscriptBox[\(x\), \(\[DoubleDot]\)]\)\
\[InvisibleSpace]\>\"", "\[Mu]"], ",", "\"\< + \>\"", ",", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{
             SubsuperscriptBox["\[CapitalGamma]", 
              RowBox[{"Row", "[", 
               RowBox[{"{", 
                RowBox[{"\[Nu]", ",", "\[Sigma]"}], "}"}], "]"}], "\[Mu]"], ",", 
             
             SuperscriptBox["\"\<\!\(\*OverscriptBox[\(x\), \(.\)]\)\>\"", 
              "\[Nu]"], ",", 
             SuperscriptBox[
              OverscriptBox["\"\<x\>\"", "."], "\[Sigma]"]}], "}"}], "]"}], ",",
           "\n", "\"\< = 0\>\""}], "}"}], "]"}], ",", "Bold", ",", "Blue"}], 
      "]"}]}], "]"}], ";"}], "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
   "Print", "[", "\"\<where \!\(\*OverscriptBox[\(x\), \
\(\[DoubleDot]\)]\)\!\(\*SuperscriptBox[\(\[InvisibleSpace]\), \(\[Mu]\)]\), \
\!\(\*SuperscriptBox[OverscriptBox[\"x\", \".\"], \
FormBox[StyleBox[\"\[Nu]\",FontFamily->\"Symbol\",FontWeight->\"Regular\"],\
TraditionalForm]]\) and \!\(\*SuperscriptBox[OverscriptBox[\(x\), \(.\)], \(\
\[Sigma]\)]\) are differentiation wrt proper time \[Tau] and \
\!\(\*SuperscriptBox[StyleBox[\"A\",FontSize->12], StyleBox[FormBox[StyleBox[\
\"\[Prime]\",FontSize->14,FontWeight->\"Regular\",FontSlant->\"Plain\"],\
TraditionalForm],FontSize->2]]\) and \
\!\(\*SuperscriptBox[StyleBox[\"B\",FontSize->12], StyleBox[FormBox[StyleBox[\
\"\[Prime]\",FontSize->14,FontWeight->\"Regular\",FontSlant->\"Plain\"],\
TraditionalForm],FontSize->2]]\) are \ndifferentiation wrt r. \>\"", "]"}], 
   ";"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"\[CapitalGamma]dd", "[", 
     RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"\[CapitalGamma]", "[", 
        RowBox[{"\[Mu]", ",", "\[Nu]", ",", "\[Gamma]"}], "]"}], " ", 
       RowBox[{
        SuperscriptBox["\[ScriptX]", "\[Prime]",
         MultilineFunction->None], "[", "\[Nu]", "]"}], " ", 
       RowBox[{
        SuperscriptBox["\[ScriptX]", "\[Prime]",
         MultilineFunction->None], "[", "\[Gamma]", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Gamma]", ",", "dimL", ",", "dimH"}], "}"}]}], "]"}]}], 
   ";"}], " "}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"gammadd", "=", 
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"\[CapitalGamma]dd", "[", 
       RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Mu]", ",", "dimL", ",", "dimH"}], "}"}], ",", 
      RowBox[{"{", 
