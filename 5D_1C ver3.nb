     RowBox[{
     "Print", "[", "\"\<We note that \!\(\*SubscriptBox[\(R\), \(01\)]\) is \
not listed because it is the identity, 0=0.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"A", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
