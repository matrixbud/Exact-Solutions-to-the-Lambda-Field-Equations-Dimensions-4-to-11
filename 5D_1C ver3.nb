 "\"  or else expressions like ",
 Cell[BoxData[
  FormBox[
   FractionBox[
    RowBox[{
     SubscriptBox["k", "1"], "'"}], 
    SubscriptBox["k", "1"]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "c8272c03-9c37-4077-a007-ca65cc8b1ba6"],
 " cause a mess \n\tI avoid this need for quotes: \n\t     For example,  \
instead of using ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["k", "1"], "'"}], "[", "r", "]"}], TraditionalForm]],
  ExpressionUUID->"90b618b9-67bb-4ea8-ae0a-cc9932aa2a38"],
 " in rulesDisp, I use  ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"x_", "'"}], "[", "r", "]"}], "\[RuleDelayed]", 
    SuperscriptBox["x", 
     StyleBox["\[Prime]",
      FontSize->13,
      FontWeight->"Regular",
      FontSlant->"Plain"]]}], TraditionalForm]],ExpressionUUID->
  "16e90dee-673d-4030-b905-96435e1a31d2"],
 "  \n\t     where x_ stands for any parameter\n\n",
 Cell[BoxData[
  RowBox[{
   RowBox[{"Clear", "[", "K", "]"}], " ", "works", " ", "but", " ", 
   RowBox[{"Clear", "[", 
    SubscriptBox["K", "1"], "]"}], " ", "gives", " ", "an", " ", "error", " ",
    "message", " ", "that", " ", 
   SubscriptBox["K", "1"], " ", "is", " ", "not", " ", "a", " ", 
   "variable"}]], "Text",
