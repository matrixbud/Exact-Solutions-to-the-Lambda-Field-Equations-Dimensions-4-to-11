\",FontWeight->\"Bold\",FontColor->RGBColor[0.9855344472419318, \
0.00946059357595178, 0.9991760128175784]]\)\!\(\*StyleBox[\"\
\[DoubleStruckCapitalC]\",FontWeight->\"Bold\",FontColor->RGBColor[0.\
9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->\
RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->\
RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\",\",FontWeight->\"Bold\",FontColor->\
RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\"r\",FontWeight->\"Bold\",FontColor->\
RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->\
RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\"=\",FontWeight->\"Bold\",FontColor->\
