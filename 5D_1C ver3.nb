       RowBox[{"a", "[", "t", "]"}], "2"]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<The field equations now become:\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", " ", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"a", "[", "t_", "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}]}], ",", 
         RowBox[{"a", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}], ",", 
         RowBox[{
          RowBox[{"C", "[", "2", "]"}], "->", "\[Beta]"}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"aSave", "=", 
      RowBox[{"a", "[", "t", "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(00\)]\) for \
a(t)\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     a(t) = \>\"", ",", 
       RowBox[{"a", "[", "t", "]"}], 
       ",", "\"\<  where \[Alpha] and \[Beta] are constant of \
integration.\>\""}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Clear", "[", "a", "]"}], "\[IndentingNewLine]", 
      RowBox[{"lhs124", "=", 
       RowBox[{"Expand", "[", 
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"1", ",", "1"}], "]"}], "-", 
         RowBox[{"2", 
          RowBox[{"lhs", "[", 
           RowBox[{"2", ",", "2"}], "]"}]}], "-", 
         RowBox[{"lhs", "[", 
          RowBox[{"4", ",", "4"}], "]"}]}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs124", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"rhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}], "-", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \(44\
\)]\) algebraically for \[CapitalBeta]:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \(44\
\)]\):  \>\"", ",", 
       RowBox[{"lhs124", "/.", "rulesDisp"}], ",", 
       RowBox[{"\"\< = \>\"", "rhs124"}]}], "]"}], ";", "\[IndentingNewLine]",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", 
       RowBox[{"Last", "[", 
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{"lhs124", "==", "rhs124"}], ",", 
          RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesDisp"}]}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"a", "[", "t_", "]"}], "=", "aSave"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging in a(t) and simplifying yields\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesDisp"}]}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<In order for \[CapitalBeta](r) to be strictly a \
function of r, the t terms must cancel out. To check this, we can ignore the \
denominator since there are no t terms there. We can also ignore the (\
\[GothicCapitalD][r]+r \!\(\*SuperscriptBox[\"\[GothicCapitalD]\", \"\[Prime]\
\",MultilineFunction->None]\)[r]) factor because it also has no t terms. The \
remainder must result in a constant:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"remain", "=", 
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{
          RowBox[{"-", 
           SqrtBox["2"]}], " ", "t", " ", 
          SqrtBox["\[CapitalLambda]"]}]]}], " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{
             SqrtBox["2"], " ", "t", " ", 
             SqrtBox["\[CapitalLambda]"]}]], " ", "\[Alpha]"}], "+", 
          "\[Beta]"}], ")"}], "2"]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"remain2", "=", 
      RowBox[{"Expand", "[", "remain", "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \>\"", ",", "remain", ",", "\"\< = \>\"", ",", 
       "remain2"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<The e terms have different exponents, so cannot be \
combined so as to cancel. Thus, in order for the remainder to be constant, \
either \[CapitalLambda]=0 or both \[Alpha]=0 and \[Beta]=0:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<If \[Alpha]=\[Beta]=0 then\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<     a(t)=0 \[Implies] \[DoubleStruckCapitalC](t,r) = \
a(t\!\(\*SuperscriptBox[\()\), \(2\)]\) = 0, an unallowable value for \
\[DoubleStruckCapitalC](t,r).\>\"", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"\[CapitalLambda]", "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<So,\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<     \[CapitalLambda]=0\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   a(t) = \>\"", ",", 
       RowBox[{"a", "[", "t", "]"}], 
       ",", "\"\<, a constant that we can call k.\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Beta]", "=", 
      RowBox[{"k", "-", "\[Alpha]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", "\"\<.\>\""}], "]"}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs124", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"1", ",", "1"}], "]"}], "+", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}], "-", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs124", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "+", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}], "-", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging these values back into the equations, we \
get:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "1"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]    \!\(\*SubscriptBox[\(R\), \
\(11\)]\)+\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \
\(44\)]\):  \>\"", ",", 
       RowBox[{"lhs124", "/.", 
        RowBox[{
         RowBox[{"x_", "[", "r_", "]"}], "->", "x"}]}], ",", "\"\< = \>\"", ",",
        "rhs124"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     
     RowBox[{"sol", "=", 
      RowBox[{"DSolve", "[", 
       RowBox[{
        RowBox[{"lhs124", "==", "rhs124"}], ",", 
        RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], ",", "r"}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[GothicCapitalD]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], "/.", 
        RowBox[{"Last", "[", "sol", "]"}]}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"C", "[", "1", "]"}], "->", "\[CapitalKappa]"}], ",", 
         RowBox[{
          RowBox[{"C", "[", "2", "]"}], "->", "\[Gamma]"}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \[GothicCapitalD][r] = 0 or \
\[GothicCapitalD][r] = \>\"", ",", 
       RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], ",", "\"\<.\>\""}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Since \[GothicCapitalD][r] \[NotEqual] 0, we have\>\"",
       "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[GothicCapitalD][r] = \>\"", ",", 
       RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], 
       ",", "\"\<  where \[CapitalKappa] and \[Gamma] are constants of \
integration.\>\""}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging back in, we find that all the equations are \
now satisfied:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "1"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We have found an exact solution to \[CapitalLambda]=0 \
field equations:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     a(t) = \>\"", ",", 
       RowBox[{"a", "[", "t", "]"}], ",", "\"\<, a free constant,\>\""}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     A(t,r) = \>\"", ",", 
       RowBox[{"A", "[", 
        RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     B(t,r) = \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], 
       ",", "\"\<  where \[Gamma] and \[CapitalKappa] are free \
constants,\>\""}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[DoubleStruckCapitalC](t,r) = \>\"", ",", 
       RowBox[{"\[DoubleStruckCapitalC]", "[", 
        RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[DoubleStruckCapitalD](t,r) = \[GothicCapitalD](r) = \
\>\"", ",", 
       RowBox[{"\[GothicCapitalD]", "[", "r", "]"}], ",", "\"\<,\>\""}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<and line element\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \>\"", ",", "lineElem"}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<Confirming:\>\"", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"\[Mu]", "=", "dimL"}], ",", 
         RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
         RowBox[{"\[Mu]", "++"}], ",", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
           RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
           RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Print", "[", 
            RowBox[{
             SubscriptBox["\"\<R\>\"", 
              RowBox[{"Row", "[", 
               RowBox[{"{", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
             ",", "\"\<:  \>\"", ",", 
             RowBox[{"Simplify", "[", 
              RowBox[{"lhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "]"}], 
             ",", "\"\< = \>\"", ",", 
             RowBox[{"rhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
        "]"}], ";"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<This solution is new. It is neither a generalization \
nor a special case of Case c.\>\"", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Clear", "[", 
       RowBox[{
       "A", ",", "B", ",", "\[CapitalBeta]", ",", "\[DoubleStruckCapitalC]", ",",
         "\[DoubleStruckCapitalD]", ",", "\[GothicCapitalD]", ",", "a", ",", 
        "\[CapitalLambda]", ",", "\[Alpha]", ",", "\[Beta]", ",", "k"}], 
       "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", \
"\"\<\!\(\*StyleBox[\"d\",FontWeight->\"Bold\",FontColor->RGBColor[0.\
