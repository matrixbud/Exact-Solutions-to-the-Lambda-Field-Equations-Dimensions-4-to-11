      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Restarting Case b from scratch using these \
constraints, the field equations become:\>\"", "]"}], ";", "\n", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "<=", "dimH"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", 
         RowBox[{"Print", "[", 
          RowBox[{
           RowBox[{"Subscript", "[", 
            RowBox[{"\"\<R\>\"", ",", 
             RowBox[{"Row", "[", 
              RowBox[{"{", 
               RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]}], "]"}], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", " ", 
            RowBox[{
             RowBox[{"x_", "[", "s_", "]"}], "->", "x"}]}], ",", "\"\< = \>\"",
            ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", 
     RowBox[{
     "Print", "[", "\"\<These field equations are identical to Case b_I\
\[Alpha]. They involve \[CapitalBeta], \[GothicCapitalC], and \
\[GothicCapitalD] but not A or a. Therefore this case has the same two \
distinct solutions in terms of \[CapitalBeta], \[GothicCapitalC], and \
\[GothicCapitalD]; a(t) is a free parameter in each case; and A(t,r) retains \
its initial value: A(t,r)=a(t\!\(\*SuperscriptBox[\()\), \(2\)]\) in Case I\
\[Alpha] and A(t,r)=\!\(\*SuperscriptBox[\(c\), \(2\)]\) here, in Case \
II.\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Since \!\(\*SuperscriptBox[\(c\), \(2\)]\) is a \
special case of a(t\!\(\*SuperscriptBox[\()\), \(2\)]\), this case is a \
special case of Case b_I\[Alpha]. It is \
\!\(\*StyleBox[\"not\",FontSlant->\"Italic\"]\) a new solution.\>\"", "]"}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Clear", "[", 
      RowBox[{
      "A", ",", "B", ",", "\[CapitalBeta]", ",", "\[DoubleStruckCapitalC]", ",",
        "\[GothicCapitalC]"}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
