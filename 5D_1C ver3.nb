          RowBox[{"\[Sigma]", ",", "\[Rho]", ",", "\[Nu]"}], "]"}]}], "-", 
        RowBox[{
         RowBox[{"\[CapitalGamma]", "[", 
          RowBox[{"\[Rho]", ",", "\[Mu]", ",", "\[Nu]"}], "]"}], " ", 
         RowBox[{"\[CapitalGamma]", "[", 
          RowBox[{"\[Sigma]", ",", "\[Rho]", ",", "\[Sigma]"}], "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Rho]", ",", "dimL", ",", "dimH"}], "}"}]}], "]"}], "]"}]}],
    ";"}], "\n"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"R", "[", 
     RowBox[{"\[Mu]_", ",", "\[Nu]_"}], "]"}], ":=", "\n", 
