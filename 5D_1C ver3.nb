   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \>\"", ",", 
      RowBox[{"lineElem", "/.", "rulesLE"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<Confirming:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
