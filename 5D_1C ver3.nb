         RowBox[{"A", "[", 
          RowBox[{"t", ",", "r"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "r"}], "}"}]}], "]"}], "/.", 
       RowBox[{
        RowBox[{
         RowBox[{"C", "[", "1", "]"}], "[", "t_", "]"}], " ", "->", " ", 
        SuperscriptBox[
         RowBox[{"a", "[", "t", "]"}], "2"]}]}]}], ";", "\[IndentingNewLine]",
      "\n", 
     RowBox[{"Print", "[", "]"}], ";", "\n", 
     RowBox[{
     "Print", "[", "\"\<Solving \!\(\*SubscriptBox[\(R\), \(22\)]\) for A \
yields\>\"", "]"}], ";", "\n", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     A(t,r) = \>\"", ",", " ", 
       RowBox[{"A", "[", 
        RowBox[{"t", ",", "r"}], "]"}], " ", ",", 
       " ", "\"\<  where we have used the scaling factor a(t) to represent \
the factor of A(t,r) having the 't' terms.\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<Plugging this back in yields\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
