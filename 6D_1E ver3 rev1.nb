Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     a(t) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"t", " ", 
       SqrtBox["\[Zeta]"]}]], " ", "\[Alpha]"}], "+", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "t"}], " ", 
       SqrtBox["\[Zeta]"]}]], " ", "\[Beta]"}]}]}],
  SequenceForm[
  "     a(t) = ", 
   E^($CellContext`t $CellContext`\[Zeta]^
       Rational[1, 2]) $CellContext`\[Alpha] + 
   E^(-$CellContext`t $CellContext`\[Zeta]^
       Rational[1, 2]) $CellContext`\[Beta]],
  Editable->False]], "Print",
