     RowBox[{
      RowBox[{"A", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      SuperscriptBox["c", "2"]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[DoubleStruckCapitalC]", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We try Case b with the additional assumption that \
A(t,r)=\!\(\*SuperscriptBox[\(c\), \(2\)]\). Starting fresh, the field \
equations are:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
           RowBox[{"\[Nu]", "\[LessEqual]", "4"}], ",", 
           RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"R", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", 
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ")"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"Print", "[", 
              RowBox[{
               SubscriptBox["\"\<R\>\"", 
                RowBox[{"Row", "[", 
                 RowBox[{"{", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
               ",", "\"\<:  \>\"", ",", 
               RowBox[{
                RowBox[{"lhs", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
               ",", "\"\< = \>\"", ",", 
               RowBox[{"rhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"a", "[", "t_", "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}]}], ",", 
         RowBox[{"a", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}], ",", 
         RowBox[{
          RowBox[{"C", "[", "2", "]"}], "->", "\[Beta]"}]}], "}"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[GothicCapitalD]", "4"], "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"0", ",", "1"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"0", ",", "1"}], "]"}]}], ",", 
         RowBox[{
          SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], ",", "r"}],
         "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "1"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
