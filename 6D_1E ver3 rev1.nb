 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"0", "0"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], 
     RowBox[{"a", " ", "\[ScriptCapitalA]", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "."], " ", 
      OverscriptBox["\[ScriptCapitalA]", "."]}], 
     RowBox[{"a", " ", 
      SuperscriptBox["\[ScriptCapitalA]", "2"], " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     SuperscriptBox[
      SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
      MultilineFunction->None], 
     RowBox[{"r", " ", "\[CapitalBeta]", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox[
       SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{"2", " ", "\[GothicCapitalC]", " ", "\[CapitalBeta]", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[CapitalBeta]", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox[
       SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{"4", " ", 
      SuperscriptBox["\[CapitalBeta]", "2"], " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox[
        SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
        MultilineFunction->None], ")"}], "2"], 
