Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"4", "4"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox[
     RowBox[{"4", " ", 
      SuperscriptBox["c", "2"], " ", 
      SuperscriptBox[
       OverscriptBox["a", "."], "2"]}], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "\[ScriptCapitalA]"}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], 
     RowBox[{"a", " ", "\[ScriptCapitalA]"}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "."], " ", 
      OverscriptBox["\[ScriptCapitalA]", "."]}], 
     RowBox[{"2", " ", "a", " ", 
      SuperscriptBox["\[ScriptCapitalA]", "2"]}]], "-", 
    FractionBox[
     SuperscriptBox[
      SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
      MultilineFunction->None], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "r", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox[
       SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{"2", " ", 
      SuperscriptBox["a", "2"], " ", "\[GothicCapitalC]", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     SuperscriptBox[
      SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]\[Prime]",
      MultilineFunction->None], 
     RowBox[{"2", " ", 
      SuperscriptBox["a", "2"], " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   "\[CapitalLambda]"}],
  SequenceForm[
   Subscript["R", 
    Row[{4, 4}]], ":  ", 
   4 $CellContext`a^(-2) $CellContext`c^2 $CellContext`\[ScriptCapitalA]^(-1) 
    OverDot[$CellContext`a, 
       1]^2 + $CellContext`a^(-1) $CellContext`c^2 $CellContext`\
\[ScriptCapitalA]^(-1) OverDot[$CellContext`a, 2] + 
   Rational[-1, 
      2] $CellContext`a^(-1) $CellContext`c^2 \
$CellContext`\[ScriptCapitalA]^(-2) OverDot[$CellContext`a, 1] 
    OverDot[$CellContext`\[ScriptCapitalA], 
      1] - $CellContext`a^(-2) $CellContext`r^(-1) 
   Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) Derivative[1][
     Subscript[$CellContext`\[GothicCapitalD], 4]] + 
   Rational[-1, 2] $CellContext`a^(-2) $CellContext`\[GothicCapitalC]^(-1) 
    Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) 
    Derivative[1][$CellContext`\[GothicCapitalC]] Derivative[1][
      Subscript[$CellContext`\[GothicCapitalD], 4]] + 
   Rational[-1, 2] $CellContext`a^(-2) 
    Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) Derivative[2][
      Subscript[$CellContext`\[GothicCapitalD], 4]], 
   " = ", $CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
