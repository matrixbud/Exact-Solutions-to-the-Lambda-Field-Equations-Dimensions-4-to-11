       SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Plugging in the formula for a(t), we confirm that this \
really is a function strictly of r:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) \
= \>\"", ",", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "/.", 
       RowBox[{
