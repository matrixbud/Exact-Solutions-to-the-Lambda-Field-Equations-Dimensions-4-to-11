                "term"}], " ", "*)"}], "\[IndentingNewLine]", 
              "\[IndentingNewLine]", 
              RowBox[{"lineElem", "=", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"lineElem", ",", "plus", ",", "nextTerm"}], "}"}], 
                "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], "]"}]}], "]"}],
       ";", "\n", "lineElem"}]}], "]"}]}], " ", 
