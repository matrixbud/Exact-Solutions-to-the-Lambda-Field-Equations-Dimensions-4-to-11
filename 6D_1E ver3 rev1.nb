         RowBox[{"(", 
          RowBox[{"4", "I", " ", "x"}], ")"}]}]}]}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<This solution is new. Claim it is neither a special \
case\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<nor a generalization of either the Case d or Case d_I\
\[Alpha] solutions:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<First, compare it to Case d:\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[Bullet] Since a(t) in Case d is a free \
parameter, a(t) in\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<       Solution 2 is a special case of it.\>\"", "]"}],
     ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[Bullet] In order for \
A(t,r)=\!\(\*SuperscriptBox[\(c\), \(2\)]\) in Solution 2 to be a special \
case of\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<       Case d, Solution 2 must be a special case of of \
Solution 1\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<       because Solution 1 \
\!\(\*StyleBox[\"is\",FontSlant->\"Italic\"]\) the special case of Case d \
having A(t,r)=\!\(\*SuperscriptBox[\(c\), \(2\)]\).\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[Bullet] But, a(t)=\!\(\*SuperscriptBox[\(\
\[ExponentialE]\), FractionBox[\(t\\\ \*SqrtBox[\(\[CapitalLambda]\)]\), \
SqrtBox[\(3\)]]]\)\[Alpha] + \!\(\*SuperscriptBox[\(\[ExponentialE]\), \
\(-\*FractionBox[\(t\\\ \*SqrtBox[\(\[CapitalLambda]\)]\), SqrtBox[\(3\)]]\)]\
\)\[Beta] of Solution 2 is \!\(\*StyleBox[\"not\",FontSlant->\"Italic\"]\) a \
special\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<       case of \
a(t)=\!\(\*FractionBox[\(\*SqrtBox[\(3\)]\\\ c\\\ \*SqrtBox[\(\[Kappa]\)]\\\ \
Sinh[\*FractionBox[\(\*SqrtBox[\(\[CapitalLambda]\)]\\\ \((t - \
\[Upsilon])\)\), SqrtBox[\(3\)]]]\), \(\[CapitalLambda]\)]\)\[InvisibleSpace] \
of Solution 1:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<       \[Checkmark] In Solution 2,\>\"", "]"}],
     ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<         a(t) = \!\(\*SuperscriptBox[\(\[ExponentialE]\
\), FractionBox[\(t\\\ \*SqrtBox[\(\[CapitalLambda]\)]\), SqrtBox[\(3\)]]]\)\
\[Alpha] + \!\(\*SuperscriptBox[\(\[ExponentialE]\), \(-\*FractionBox[\(t\\\ \
\*SqrtBox[\(\[CapitalLambda]\)]\), SqrtBox[\(3\)]]\)]\)\[Beta] ]\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<              = \[Alpha]Cosh[\!\(\*FractionBox[\(t\\\ \
\*SqrtBox[\(\[CapitalLambda]\)]\), SqrtBox[\(3\)]]\)]+ \
\[Beta]Cosh[\!\(\*FractionBox[\(t\\\ \*SqrtBox[\(\[CapitalLambda]\)]\), \
SqrtBox[\(3\)]]\)] + \[Alpha]Sinh[\!\(\*FractionBox[\(t\\\ \*SqrtBox[\(\
\[CapitalLambda]\)]\), SqrtBox[\(3\)]]\)] - \[Beta]Sinh[\!\(\*FractionBox[\(t\
\\\ \*SqrtBox[\(\[CapitalLambda]\)]\), SqrtBox[\(3\)]]\)]\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<       \[Checkmark] \[Upsilon] in Solution 1 must be \
zero so that a(t)=\!\(\*SqrtBox[\(3  \[Kappa]\)]\)\!\(\*FractionBox[\(c\), \(\
\[CapitalLambda]\)]\)Sinh[\!\(\*FractionBox[\(\*SqrtBox[\(\[CapitalLambda]\)]\
\\\ t\), SqrtBox[\(3\)]]\)]\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<         That leaves \
\!\(\*StyleBox[\"Solution\",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\" \
\",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\"1\",FontSlant->\"Plain\"]\)\!\(\*\
StyleBox[\" \
\",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\"only\",FontSlant->\"Plain\"]\)\!\(\
\*StyleBox[\" \
\",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\"1\",FontSlant->\"Plain\"]\)\!\(\*\
StyleBox[\" \
\",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\"free\",FontSlant->\"Plain\"]\)\!\(\
\*StyleBox[\" \
\",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\"constant\",FontSlant->\"Plain\"]\)\
\!\(\*StyleBox[\",\",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\" \
\",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\"\[Kappa]\",FontSlant->\"Plain\"]\)\
\!\(\*StyleBox[\".\",FontSlant->\"Plain\"]\)\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<       \[Checkmark] But, Solution 2 has two free \
constants,\!\(\*StyleBox[\" \",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\"\
\[Alpha]\",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\" \
\",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\"and\",FontSlant->\"Plain\"]\)\!\(\*\
StyleBox[\" \
\",FontSlant->\"Plain\"]\)\!\(\*StyleBox[\"\[Beta]\",FontSlant->\"Plain\"]\).\
\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<       \[Checkmark] So, Solution 2 cannot be a special \
case of Solution 1.\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", 
     "[", "\"\<       \[Checkmark] Hence, Solution 2 is not a special case of \
Case d.\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[Bullet] Solution 2 also is not a generalization \
of Solution 1 because of\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<       constant \[Upsilon] in a(t) of Solution 1.\>\"",
      "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<As for Case d_I\[Alpha], a(t) is constant. In order \
for the Solution 2 a(t) to be constant, we would have to have \
\[CapitalLambda]=0 \[Implies] \[DoubleStruckCapitalC](t,r) is undefined. So, \
Case d_I\[Alpha] is not a special case of Solution 2. And, clearly the Case \
d_I\[Alpha] constant a(t) does not generalize a(t) of Solution 2. So, neither \
solution is a special case of the other.\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<In viewing all four solutions together (Cases d and \
d_I\[Alpha] and Solutions 1 and 2), we observe they are similar. All have the \
same B and \[DoubleStruckCapitalC], and essentially the same \
\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\). They only differ in a(t) \
and/or A(t,r).\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
