       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"lhs04b", "==", "rhs04"}], ",", 
         RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "k"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<         \[ScriptCapitalA][t] = \>\"", ",", 
       RowBox[{
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesLE"}], 
       ",", "\"\<  where k is a constant of integration.\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging this in, \!\(\*SubscriptBox[\(R\), \(44\)]\) \
becomes redundant, the same as \!\(\*SubscriptBox[\(R\), \(00\)]\):\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[GothicCapitalC]", "[", "r_", "]"}], "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}]}], ",", 
         RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], ",", "r"}], "]"}], 
       "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<I tried to solve the individual equations as well as \
several algebraic combinations, with no success. The furthest I got was \
soving \!\(\*SubscriptBox[\(R\), \(00\)]\) for \[GothicCapitalC]:\>\"", "]"}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[GothicCapitalC](r) = \>\"", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], "/.", "rulesKr"}], "/.",
         "rulesDisp"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging this back in, both \!\(\*SubscriptBox[\(R\), \
\(00\)]\) are \!\(\*SubscriptBox[\(R\), \(44\)]\) are satisfied, leaving just \
