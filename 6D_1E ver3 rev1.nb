               "\[IndentingNewLine]", "\t", 
              RowBox[{"(*", " ", 
               RowBox[{"Suppress", " ", "+", " ", 
                RowBox[{
                "sign", " ", "on", " ", "a", " ", "first", " ", "term", " ", 
                 "that", " ", "is", " ", "positive"}]}], " ", "*)"}], "\n", 
              "\t", "\[IndentingNewLine]", 
              RowBox[{"nextTerm", "=", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"factor", " ", "g\[Mu]\[Nu]"}], ",", "\"\< \>\"", ",",
