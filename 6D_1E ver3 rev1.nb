Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"\\!\\(\\*SubscriptBox[\\(R\\), \\(11\\)]\\):  \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[GothicCapitalL]", "2"], 
      RowBox[{"2", " ", 
       SuperscriptBox[
        RowBox[{"a", "[", "t", "]"}], "2"]}]]}], "+", 
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["c", "2"], " ", 
      SuperscriptBox[
       RowBox[{
        SuperscriptBox["a", "\[Prime]",
         MultilineFunction->None], "[", "t", "]"}], "2"]}], 
     RowBox[{"\[CapitalKappa]", " ", 
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"]}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      RowBox[{
       SuperscriptBox["a", "\[Prime]\[Prime]",
        MultilineFunction->None], "[", "t", "]"}]}], 
     RowBox[{"\[CapitalKappa]", " ", 
      RowBox[{"a", "[", "t", "]"}]}]]}], "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]",
    "\[CapitalLambda]"}],
  SequenceForm[
  "\!\(\*SubscriptBox[\(R\), \(11\)]\):  ", 
   Rational[-1, 
      2] $CellContext`\[GothicCapitalL]^2 $CellContext`a[$CellContext`t]^(-2) + 
   2 $CellContext`c^2 $CellContext`\[CapitalKappa]^(-1) \
$CellContext`a[$CellContext`t]^(-2) 
    Derivative[
      1][$CellContext`a][$CellContext`t]^2 + $CellContext`c^2 $CellContext`\
\[CapitalKappa]^(-1) $CellContext`a[$CellContext`t]^(-1) 
    Derivative[2][$CellContext`a][$CellContext`t], 
   " = ", $CellContext`\[CapitalLambda]],
