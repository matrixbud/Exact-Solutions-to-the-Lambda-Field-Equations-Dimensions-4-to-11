Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\" \[Implies]   \[ScriptCapitalA](t) = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"3", " ", 
     SuperscriptBox["c", "2"], " ", 
     SuperscriptBox["\[CapitalKappa]", "2"], " ", 
     SuperscriptBox[
      RowBox[{
       OverscriptBox["a", "."], "[", "t", "]"}], "2"]}], 
    RowBox[{
     RowBox[{"3", " ", 
      SuperscriptBox["c", "2"], " ", "\[Kappa]", " ", 
      SuperscriptBox["\[CapitalKappa]", "2"]}], "-", 
     SuperscriptBox[
      RowBox[{"a", "[", "t", "]"}], "2"], "+", 
     RowBox[{"2", " ", "\[CapitalKappa]", " ", "\[CapitalLambda]", " ", 
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"]}]}]], 
   "\[InvisibleSpace]", "\<\".\"\>"}],
  SequenceForm[
