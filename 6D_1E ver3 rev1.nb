Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \\!\\(\\*SubscriptBox[\\(R\\), \
\\(00\\)]\\)+\\!\\(\\*SubscriptBox[\\(R\\), \\(22\\)]\\):  \"\>", "\[InvisibleSpace]", 
   RowBox[{
    FractionBox[
     RowBox[{"\[CapitalAlpha]", " ", "\[CapitalLambda]"}], 
     RowBox[{
      SqrtBox["3"], " ", "c", " ", 
      SqrtBox["\[Kappa]"]}]], "+", 
    FractionBox[
     RowBox[{"3", " ", 
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], 
     RowBox[{"a", " ", "\[CapitalAlpha]"}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   RowBox[{"2", " ", "\[CapitalLambda]"}]}],
  SequenceForm[
  "     \!\(\*SubscriptBox[\(R\), \(00\)]\)+\!\(\*SubscriptBox[\(R\), \(22\)]\
\):  ", 3^
     Rational[-1, 
       2] $CellContext`c^(-1) $CellContext`\[CapitalAlpha] $CellContext`\
\[Kappa]^Rational[-1, 2] $CellContext`\[CapitalLambda] + 
   3 $CellContext`a^(-1) $CellContext`c^2 $CellContext`\[CapitalAlpha]^(-1) 
    OverDot[$CellContext`a, 2], " = ", 2 $CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
 CellChangeTimes->CompressedData["
