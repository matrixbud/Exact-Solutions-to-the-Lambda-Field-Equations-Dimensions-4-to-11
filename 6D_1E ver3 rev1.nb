     RowBox[{
     "Print", "[", "\"\<Except for \!\(\*SubscriptBox[\(R\), \(44\)]\), these \
equations are identical to Case 5D_1A. Thus, from solving \!\(\*SubscriptBox[\
\(R\), \(00\)]\) and \!\(\*SubscriptBox[\(R\), \(01\)]\), respectively, we \
get\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     a(t) = \>\"", ",", 
       RowBox[{"a", "[", "t", "]"}], 
       ",", "\"\<  where \[Alpha] and \[Beta] are constants of integration.\>\
\""}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) \
= \>\"", ",", 
       RowBox[{
        SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], 
       ",", "\"\<.\>\""}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging back in, \!\(\*SubscriptBox[\(R\), \(00\)]\) \
and \!\(\*SubscriptBox[\(R\), \(01\)]\) are satisfied and can be ignored:\>\"",
       "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "1"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"!", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"R", "[", 
               RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "===", 
              RowBox[{"\[CapitalLambda]", " ", 
               RowBox[{"g", "[", 
                RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}]}], ")"}]}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{"Print", "[", 
            RowBox[{
             SubscriptBox["\"\<R\>\"", 
              RowBox[{"Row", "[", 
               RowBox[{"{", 
                RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
             ",", "\"\<:  \>\"", ",", 
             RowBox[{
              RowBox[{"lhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
             ",", "\"\< = \>\"", ",", 
             RowBox[{"rhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], 
        "]"}]}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs44", "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}], "/", "\[CapitalLambda]"}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"rhs44", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}], "/", "\[CapitalLambda]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Assuming \[CapitalLambda]\[NotEqual]0, \
\!\(\*SubscriptBox[\(R\), \(44\)]\) can be simplified by factoring out \
\[CapitalLambda] from both sides:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \(44\)]\):  \>\"", ",", "lhs44", 
       ",", "\"\< = \>\"", ",", "rhs44"}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"\[Beta]", "=", "0"}], " ", ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<In order for this equation to be true, we must have\>\
\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<     \[Alpha] = 0 or \[Beta] = 0\>\"", "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   a(t) = \>\"", ",", 
       RowBox[{
        RowBox[{"a", "[", "t", "]"}], "/.", 
        RowBox[{
         RowBox[{"t", " ", "x_"}], "->", 
         RowBox[{"\[PlusMinus]", 
          RowBox[{"(", 
           RowBox[{"t", "  ", "x"}], ")"}]}]}]}], ",", "\"\<.\>\""}], "]"}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs12", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"1", ",", "1"}], "]"}], "-", 
        RowBox[{"2", " ", 
         RowBox[{"lhs", "[", 
          RowBox[{"2", ",", "2"}], "]"}]}]}], "]"}]}], ";", "\n", "   ", 
     RowBox[{"rhs12", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", " ", 
        RowBox[{"rhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(44\)]\) has now become an \
identity.\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can algebraically solve \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\) for \[CapitalBeta]:\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
       RowBox[{"lhs12", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rhs12"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", 
       RowBox[{"Last", "[", 
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{"lhs12", "==", "rhs12"}], ",", 
          RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<         \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We see that the remaining equations are both \
solved:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "1"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
         SubscriptBox["\"\<R\>\"", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
          ",", 
         RowBox[{"lhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], ",", "\"\< = \>\"", ",", 
         RowBox[{"rhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We have found an exact solution to the \
\[CapitalLambda] field equations:\>\"", "]"}], ";", "\n", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     a(t) = \>\"", ",", 
       RowBox[{
        RowBox[{"a", "[", "t", "]"}], "/.", 
        RowBox[{
         RowBox[{"t", " ", "x_"}], "->", 
         RowBox[{"\[PlusMinus]", 
          RowBox[{"(", 
           RowBox[{"t", "  ", "x"}], ")"}]}]}]}], 
       ",", "\"\<  where \[Alpha] is a free parameter,\>\""}], "]"}], ";", 
     "\n", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     A(t,r) = \>\"", ",", 
       RowBox[{"A", "[", 
        RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";", "\n", 
     
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     B(t,r) = \>\"", ",", 
       RowBox[{"B", "[", 
        RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";", "\n", 
     
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[DoubleStruckCapitalC](t,r) = \>\"", ",", 
       RowBox[{"\[DoubleStruckCapitalC]", "[", 
        RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<, a free parameter,\>\""}], 
      "]"}], ";", "\n", 
     RowBox[{
     "Print", "[", "\"\<     \!\(\*SubscriptBox[\(\[DoubleStruckCapitalD]\), \
\(4\)]\)(t,r) = \!\(\*SubscriptBox[\(\[DoubleStruckCapitalD]\), \(5\)]\)(t,r) \
= a(t\!\(\*SuperscriptBox[\()\), \(2\)]\),\>\"", "]"}], ";", "\n", 
     RowBox[{"Print", "[", "\"\<     and line element\>\"", "]"}], ";", "\n", 
     
     RowBox[{"Print", "[", 
      RowBox[{"lineElem", "/.", " ", "rulesLE"}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
