\[CapitalLambda]\)]\)(kt+\[Upsilon]) = -\[Pi]  for all t\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<       \[Implies]   k=0 and \[Upsilon] \
=-\!\(\*FractionBox[\(\[Pi]\), SqrtBox[\(2 \[CapitalLambda]\)]]\)\>\"", "]"}],
      ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<       \[Implies]   A(t,r) = a(t\!\(\*SuperscriptBox[\
\()\), \(2\)]\) = 0, an unallowable value.\>\"", "]"}], ";", 
