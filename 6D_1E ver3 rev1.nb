Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\" \[Implies]   a(t) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[PlusMinus]", 
      FractionBox[
       RowBox[{"t", " ", 
        SqrtBox["\[CapitalLambda]"]}], 
       SqrtBox["2"]]}]], " ", "\[Alpha]"}], "\[InvisibleSpace]", "\<\".\"\>"}],
  SequenceForm[
  " \[Implies]   a(t) = ", 
