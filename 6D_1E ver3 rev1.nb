         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We observed in Notebook 6D_1 that \
\!\(\*SubscriptBox[\(R\), \(33\)]\) is redundant and, so, \!\(\*SubscriptBox[\
