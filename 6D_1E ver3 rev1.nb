RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->\
RGBColor[0.9855344472419318, 0.00946059357595178, 0.9991760128175784]]\)\>\"",
       "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[DoubleStruckCapitalC]", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We preface this case with an observation of what is \
to come. We will generate 4 solutions, Cases d, d-II, d_I\[Alpha], and d_II, \
that are very similar. The solutions differ only in a(t) and A(t,r). B(r) and \
\[DoubleStruckCapitalC](r) are identical and the \!\(\*SubscriptBox[\(\
\[GothicCapitalD]\), \(4\)]\)(r)'s are essentially the same. These solutions \
are particularly difficult to develop.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<The field equations for Case d become\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
           RowBox[{"\[Nu]", "\[LessEqual]", "4"}], ",", 
           RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"R", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], "&&", 
                
                RowBox[{
                 RowBox[{"\[CapitalLambda]", " ", 
                  RowBox[{"g", "[", 
                   RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "===", "0"}]}], 
               ")"}]}], ",", "\[IndentingNewLine]", 
             RowBox[{"Print", "[", 
              RowBox[{
               SubscriptBox["\"\<R\>\"", 
                RowBox[{"Row", "[", 
                 RowBox[{"{", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
               ",", "\"\<:  \>\"", ",", 
               RowBox[{
                RowBox[{"lhs", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
               ",", "\"\< = \>\"", ",", 
               RowBox[{"rhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"ls01", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          RowBox[{"a", "[", "t", "]"}], 
          RowBox[{
           RowBox[{"a", "'"}], "[", "t", "]"}]]}], 
        RowBox[{"lhs", "[", 
         RowBox[{"0", ",", "1"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can simplify \!\(\*SubscriptBox[\(R\), \(01\)]\) \
by factoring out \!\(\*FractionBox[OverscriptBox[\(a\), \(.\)], \(a\)]\), and \
then solving for A:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(01\)]\):  \>\"", ",", 
       RowBox[{"ls01", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       RowBox[{"rhs", "[", 
        RowBox[{"0", ",", "1"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"A", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"ls01", "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"0", ",", "1"}], "]"}]}], ",", 
         RowBox[{"A", "[", 
          RowBox[{"t", ",", "r"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "r"}], "}"}]}], "]"}], "/.", " ", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "\[ScriptCapitalA]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     A(t,r) = \>\"", ",", 
       RowBox[{"A", "[", 
        RowBox[{"t", ",", "r"}], "]"}], 
       ",", "\"\<  where \[ScriptCapitalA](t) is a new unknown.\>\""}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<This eliminates \!\(\*SubscriptBox[\(R\), \(01\)]\), \
and the remaining equations become\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs02", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"0", ",", "0"}], "]"}], "+", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs02", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "+", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(00\)]\)+\!\(\
\*SubscriptBox[\(R\), \(22\)]\) for \[ScriptCapitalA]:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(00\)]\)+\!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
       RowBox[{"lhs02", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rhs02"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"lhs02", "==", "rhs02"}], ",", 
         RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "\[Kappa]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"num", "=", 
      RowBox[{
       RowBox[{"Numerator", "[", "%", "]"}], "/", 
       RowBox[{"(", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], "2"], 
         SuperscriptBox["r", "4"]}], ")"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"den", "=", 
      RowBox[{"Collect", "[", 
       RowBox[{
        RowBox[{"Expand", "[", 
         RowBox[{
          RowBox[{"Denominator", "[", "%%", "]"}], "/", 
          RowBox[{"(", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], "2"], 
            SuperscriptBox["r", "4"]}], ")"}]}], "]"}], ",", 
        RowBox[{"a", "[", "t", "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[ScriptCapitalA](t) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesLE"}]}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<          = \>\"", ",", 
       RowBox[{
        RowBox[{"num", "/", "den"}], "/.", "rulesLE"}]}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<     where \[Kappa] is a constant of integration.\>\"",
       "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[GothicCapitalC]", "[", "r_", "]"}], "=", 
      FractionBox["\[CapitalKappa]", 
       SuperscriptBox["r", "2"]]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<In order for \[ScriptCapitalA](t) not to be a \
function of r, the term in parentheses must be a constant.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\< \[Implies]   C(r) = \!\(\*FractionBox[\(\
\[CapitalKappa]\), SuperscriptBox[\(r\), \(2\)]]\)  for some proportionality \
constant \[CapitalKappa],\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \[ScriptCapitalA](t) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesLE"}], 
       ",", "\"\<.\>\""}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Moreover, this makes A(t,r) strictly a function of t:\
\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<     A(t,r) = \
\!\(\*FractionBox[\(\[ScriptCapitalA][t]\), \(\*SuperscriptBox[\(r\), \
\(2\)]\\\ \[GothicCapitalC][r]\)]\) = \
\!\(\*FractionBox[\(\[ScriptCapitalA]\((t)\)\), \(\[CapitalKappa]\)]\).\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<The equations now become\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<From \!\(\*SubscriptBox[\(R\), \(22\)]\) we get\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<     \[CapitalLambda]\[NotEqual]0  and  \
\[CapitalKappa] =\!\(\*FractionBox[\(1\), \(\[CapitalLambda]\)]\).\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[CapitalKappa]", "=", 
      FractionBox["1", "\[CapitalLambda]"]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"A", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{"A", "[", 
        RowBox[{"t", ",", "r"}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\n", 
     RowBox[{"Print", "[", "\"\<This modifies A(t,r) again:\>\"", "]"}], ";", 
     "\n", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     A(t,r) = \[CapitalLambda] \[ScriptCapitalA](t) = (\
\[CapitalLambda]) (\>\"", ",", 
       RowBox[{
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", " ", "rulesLE"}], 
       ",", "\"\<) = \>\""}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(00\)]\) and \
\!\(\*SubscriptBox[\(R\), \(22\)]\) have become identities, and the other \
equations become\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "1"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Mu]", "<", "2"}], "||", 
          RowBox[{"\[Mu]", ">", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"lhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "-", 
             "\[CapitalLambda]"}], "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
           RowBox[{
            RowBox[{"rhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "-", 
            "\[CapitalLambda]"}]}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs14", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"1", ",", "1"}], "]"}], "-", 
        RowBox[{"2", 
         RowBox[{"lhs", "[", 
          RowBox[{"4", ",", "4"}], "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs14", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"rhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
      "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(11\)]\)-2\!\
\(\*SubscriptBox[\(R\), \(44\)]\) for \
\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\):\>\"", "]"}], "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(44\)]\):  \>\"", ",", 
        RowBox[{"lhs14", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
        "rhs14"}], "]"}]}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[GothicCapitalD]", "4"], "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "/.", 
        RowBox[{"Last", "[", 
         RowBox[{"DSolve", "[", 
          RowBox[{
           RowBox[{"lhs14", "==", "rhs14"}], ",", 
           RowBox[{
            SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], ",", 
           "r"}], "]"}], "]"}]}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "\[Gamma]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) \
= \>\"", ",", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "/.", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "x_"}], ")"}], "->", 
         RowBox[{"\[PlusMinus]", 
          RowBox[{"(", 
           RowBox[{"2", "x"}], ")"}]}]}]}], 
       ",", "\"\<  where \[Gamma] is a constant of integration.\>\""}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"\[Gamma]", "=", "1"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Since \!\(\*SubscriptBox[\(g\), \(44\)]\) = \
-a(t\!\(\*SuperscriptBox[\()\), \
\(2\)]\)\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \
\(4\)]\)(r)\!\(\*SuperscriptBox[SubscriptBox[\(p\), \(4\)], \(2\)]\), \
\!\(\*SuperscriptBox[SubscriptBox[\(\[Gamma]p\), \(4\)], \(2\)]\) equals \!\(\
\*SuperscriptBox[SubscriptBox[OverscriptBox[\(p\), \(^\)], \(4\)], \(2\)]\) \
for a different radius, \!\(\*SubscriptBox[OverscriptBox[\(p\), \(^\)], \
\(4\)]\). So, we can roll \[Gamma] into the radius \!\(\*SubscriptBox[\(p\), \
\(4\)]\):\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) \
= \>\"", ",", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "/.", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", "x_"}], ")"}], "->", 
         RowBox[{"\[PlusMinus]", 
          RowBox[{"(", 
           RowBox[{"2", "x"}], ")"}]}]}]}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging this in, the remaining equations are \
satisfied:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "1"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"\[Mu]", "<", "2"}], "||", 
          RowBox[{"\[Mu]", ">", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"lhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "-", 
             "\[CapitalLambda]"}], "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
           RowBox[{
            RowBox[{"rhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "-", 
            "\[CapitalLambda]"}]}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<All of the equations are satisfied, so we have an \
exact solution to the \[CapitalLambda]\[NotEqual]0 field equations:\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<     a(t) is a free parameter,\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     A(t,r) = \>\"", ",", 
       RowBox[{
        RowBox[{"A", "[", 
         RowBox[{"t", ",", "r"}], "]"}], "/.", "rulesLE"}], 
       ",", "\"\<  where \[Kappa] is a free constant,\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     B(t,r) = \>\"", ",", 
       RowBox[{"B", "[", 
        RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[DoubleStruckCapitalC](t,r) = \>\"", ",", 
       RowBox[{"\[DoubleStruckCapitalC]", "[", 
        RowBox[{"t", ",", "r"}], "]"}], 
       ",", "\"\<  where \[CapitalLambda]\[NotEqual]0,\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(\[DoubleStruckCapitalD]\), \
\(4\)]\)(t,r) = \!\(\*SubscriptBox[\(\[DoubleStruckCapitalD]\), \(5\)]\)(t,r) \
= a(t\!\(\*SuperscriptBox[\()\), \(2\)]\)\!\(\*SubscriptBox[\(\
\[GothicCapitalD]\), \(4\)]\)(r) = \>\"", ",", 
       RowBox[{
        RowBox[{
         SuperscriptBox[
          RowBox[{"a", "[", "t", "]"}], "2"], 
         RowBox[{
          SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}]}], "/.", 
        " ", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"2", " ", "x_"}], ")"}], "->", 
         RowBox[{"\[PlusMinus]", 
          RowBox[{"(", 
           RowBox[{"2", " ", "x"}], ")"}]}]}]}], ",", "\"\<,\>\""}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<and line element\>\"", "]"}], ";", "\n", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \>\"", ",", 
       RowBox[{"lineElem", "/.", "rulesLE"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", "\"\<Confirming:\>\"", "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"\[Mu]", "=", "dimL"}], ",", 
         RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
         RowBox[{"\[Mu]", "++"}], ",", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
           RowBox[{"\[Nu]", "\[LessEqual]", "4"}], ",", 
           RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{"Print", "[", 
            RowBox[{
             SubscriptBox["\"\<R\>\"", 
              RowBox[{"Row", "[", 
               RowBox[{"{", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
             ",", "\"\<:  \>\"", ",", 
             RowBox[{"Expand", "[", 
              RowBox[{"lhsF", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "]"}], 
             ",", "\"\< = \>\"", ",", 
             RowBox[{"rhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
        "]"}], ";"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
