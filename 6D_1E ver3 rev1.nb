Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \\!\\(\\*SubscriptBox[\\(\[GothicCapitalD]\\), \
\\(4\\)]\\)(r) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[PlusMinus]", 
      FractionBox[
       RowBox[{"\[ImaginaryI]", " ", 
        SqrtBox["2"], " ", "r", " ", 
        SqrtBox[
         RowBox[{
          RowBox[{
           SuperscriptBox["a", "2"], " ", "\[CapitalKappa]", " ", 
           "\[CapitalLambda]"}], "-", 
          RowBox[{"2", " ", 
           SuperscriptBox["c", "2"], " ", 
           SuperscriptBox[
            OverscriptBox["a", "."], "2"]}], "-", 
          RowBox[{"a", " ", 
           SuperscriptBox["c", "2"], " ", 
           OverscriptBox["a", "\[DoubleDot]"]}]}]]}], 
       SqrtBox["\[CapitalKappa]"]]}]], " ", "k"}], 
   "\[InvisibleSpace]", "\<\"  where k is a constant of integration.\"\>"}],
  SequenceForm[
  "     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) = ", 
   E^PlusMinus[
     Complex[0, 1] 
      2^Rational[1, 2] $CellContext`r $CellContext`\[CapitalKappa]^
       Rational[-1, 
         2] ($CellContext`a^2 $CellContext`\[CapitalKappa] $CellContext`\
\[CapitalLambda] - 2 $CellContext`c^2 
        OverDot[$CellContext`a, 1]^2 - $CellContext`a $CellContext`c^2 
        OverDot[$CellContext`a, 2])^Rational[1, 2]] $CellContext`k, 
   "  where k is a constant of integration."],
