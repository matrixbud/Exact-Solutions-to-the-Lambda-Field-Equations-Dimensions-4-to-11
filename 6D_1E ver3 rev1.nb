Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \[GothicCapitalC](r) = \"\>", "\[InvisibleSpace]", 
   SuperscriptBox["\[ExponentialE]", 
    TemplateBox[{
      RowBox[{
        FractionBox["1", "2"], " ", 
        RowBox[{"(", 
          RowBox[{
            RowBox[{"-", 
              FractionBox["4", "\[Rho]"]}], "+", 
            FractionBox[
             SuperscriptBox[
             "\[CapitalBeta]", "\[Prime]", MultilineFunction -> None], 
             "\[CapitalBeta]"], "-", 
            FractionBox[
             RowBox[{"4", " ", "\[CapitalBeta]", " ", 
               RowBox[{"(", 
                 RowBox[{
                   RowBox[{
                    RowBox[{"-", "2"}], " ", 
                    SuperscriptBox["c", "2"]}], "+", 
                   RowBox[{"k", " ", "\[CapitalLambda]", " ", 
                    SubscriptBox["\[GothicCapitalD]", "4"]}]}], ")"}]}], 
             RowBox[{"k", " ", 
               SuperscriptBox[
                SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]", 
                MultilineFunction -> None]}]], "-", 
            FractionBox[
             SuperscriptBox[
              SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]", 
              MultilineFunction -> None], 
             SubscriptBox["\[GothicCapitalD]", "4"]], "-", 
            FractionBox[
             RowBox[{"2", " ", 
               SuperscriptBox[
                SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]\[Prime]", 
                MultilineFunction -> None]}], 
             SuperscriptBox[
              SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]", 
              MultilineFunction -> None]]}], ")"}]}], "\[Rho]", "1", "r"},
     "InactiveIntegrate",
     DisplayFunction->(RowBox[{
        SubsuperscriptBox[
         StyleBox["\[Integral]", "Inactive"], #3, #4], 
        RowBox[{#, 
          RowBox[{
            StyleBox["\[DifferentialD]", "Inactive"], #2}]}]}]& ),
     InterpretationFunction->(RowBox[{
        RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
        RowBox[{#, ",", 
          RowBox[{"{", 
            RowBox[{#2, ",", #3, ",", #4}], "}"}]}], "]"}]& )]], " ", 
   TemplateBox[{"1"},
    "C"]}],
  SequenceForm[
  "     \[GothicCapitalC](r) = ", 
   E^Inactive[Integrate][
     Rational[1, 
        2] ((-4)/$CellContext`\[Rho] + $CellContext`\[CapitalBeta]^(-1) 
        Derivative[1][$CellContext`\[CapitalBeta]] - 
       4 $CellContext`k^(-1) $CellContext`\[CapitalBeta] ((-2) \
$CellContext`c^2 + $CellContext`k $CellContext`\[CapitalLambda] 
         Subscript[$CellContext`\[GothicCapitalD], 4])/Derivative[1][
        Subscript[$CellContext`\[GothicCapitalD], 4]] - 
       Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) Derivative[1][
         Subscript[$CellContext`\[GothicCapitalD], 4]] - 2 Derivative[1][
          Subscript[$CellContext`\[GothicCapitalD], 4]]^(-1) Derivative[2][
         Subscript[$CellContext`\[GothicCapitalD], 4]]), {$CellContext`\[Rho],
        1, $CellContext`r}] C[1]],
  Editable->False]], "Print",
