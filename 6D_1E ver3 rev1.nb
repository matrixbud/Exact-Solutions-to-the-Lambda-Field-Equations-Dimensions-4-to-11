     RowBox[{"\[DoubleStruckCapitalC]", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"], 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Even though this case is a subset of the solution to \
Case a, it is possible we may find a different solution by setting \
A(t,r)=\!\(\*SuperscriptBox[\(c\), \(2\)]\) \
\!\(\*StyleBox[\"prior\",FontSlant->\"Italic\"]\) to solving the ODEs. \
Re-doing Case a from scratch, the field equations become\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "4"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"R", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], "&&", 
               RowBox[{
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "===", "0"}]}], 
              ")"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
              SubscriptBox["\"\<R\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
              ",", "\"\<:  \>\"", ",", 
              RowBox[{
               RowBox[{"lhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
              ",", "\"\< = \>\"", ",", 
              RowBox[{"rhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], ",", 
        RowBox[{"a", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{
         RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}], ",", 
        RowBox[{
         RowBox[{"C", "[", "2", "]"}], "->", "\[Beta]"}]}], "}"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"aSave", "=", 
     RowBox[{"a", "[", "t", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Solving \!\(\*SubscriptBox[\(R\), \(00\)]\) yields\>\"",
      "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \>\"", ",", 
      RowBox[{"a", "[", "t", "]"}], 
      ",", "\"\<  where \[Alpha] and \[Beta] are constants of \
integration.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<This a(t) is a generalization of the a(t) we found in \
Case a-II, unless either \[Alpha] or \[Beta] is zero. \>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "a", "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs124", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}], "-", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs124", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], "-", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}], "-", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can also \
\!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) solve \
\!\(\*SubscriptBox[\(R\), \(11\)]\)-2\!\(\*SubscriptBox[\(R\), \
\(22\)]\)-2\!\(\*SubscriptBox[\(R\), \(44\)]\) for \[CapitalBeta](r):\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \(11\)]\)-2\!\(\*SubscriptBox[\(R\
\), \(22\)]\)-2\!\(\*SubscriptBox[\(R\), \(44\)]\):  \>\"", ",", 
      RowBox[{"lhs124", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      "rhs124"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", 
      RowBox[{"Last", "[", 
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"lhs124", "==", "rhs124"}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], "]"}]}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\[CapitalBeta](r) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesDisp"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"p", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"Denominator", "[", 
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "]"}], "/", 
       RowBox[{"(", 
        RowBox[{"2", 
         RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], " ", 
         SuperscriptBox[
          RowBox[{
           SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "2"]}], 
        ")"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<In order for \[CapitalBeta](r) to strictly be a \
function of r, the t terms in the denominator must disappear. There are no \
terms in the numerator to cancel them out, so the denominator terms must be \
self-canceling. It turns out they are. Call the denominator expression in the \
parentheses p(t,r):\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     p(t,r) = \>\"", ",", 
      RowBox[{
       RowBox[{"p", "[", 
        RowBox[{"t", ",", "r"}], "]"}], "/.", "rulesDisp"}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "t_", "]"}], "=", "aSave"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"p", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"Expand", "[", 
      RowBox[{"p", "[", 
       RowBox[{"t", ",", "r"}], "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{"Simplify", "[", 
      FractionBox[
       RowBox[{"Numerator", "[", 
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "]"}], 
       RowBox[{"2", 
        RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], 
        SuperscriptBox[
         RowBox[{
          SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "2"], " ", 
        
        RowBox[{"p", "[", 
         RowBox[{"t", ",", "r"}], "]"}]}]], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<When we plug in the formula above for a(t), this \
simplifies to\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     p(t,r) = \>\"", ",", 
      RowBox[{"p", "[", 
       RowBox[{"t", ",", "r"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\< \[Implies]   B(r) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesDisp"}], 
      ",", "\"\<,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<strictly a function of r.\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Beta]", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs12", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"Numerator", "[", 
        RowBox[{"Together", "[", 
         RowBox[{"lhs", "[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}], "]"}], "-", 
       RowBox[{"Numerator", "[", 
        RowBox[{"Together", "[", 
         RowBox[{"lhs", "[", 
          RowBox[{"2", ",", "2"}], "]"}], "]"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs12", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], "-", 
      RowBox[{"rhs", "[", 
       RowBox[{"2", ",", "2"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We are imitating the Case 5D_1A methodology. When we \
plug \[CapitalBeta](r) into the remaining equations, they are each even \
longer than in Case 5D_1A, too long to display here. As in Case 5D_1A, we set \
\[Beta]=0 to shorten the equations, and we put the left-hand sides of \
\!\(\*SubscriptBox[\(R\), \(11\)]\), \!\(\*SubscriptBox[\(R\), \(22\)]\), and \
\!\(\*SubscriptBox[\(R\), \(44\)]\) over their common denominators, which \
turn out to be the same common denominator for each of three equations.\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";", 
    RowBox[{
    "Print", "[", "\"\<The three equations are still to long to display here. \
\!\(\*SubscriptBox[\(R\), \(11\)]\)-\!\(\*SubscriptBox[\(R\), \(22\)]\) is by \
far the simplest of the linear combination of the equations. We can ignore \
the LHS denominator of \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-\!\(\*SubscriptBox[\(R\), \(22\)]\) because the RHS is zero. The \
resulting numerator is more complex than in Case5D_1A but short enough to \
display here:\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \
\(11\)]\)-\!\(\*SubscriptBox[\(R\), \(22\)]\): \>\"", ",", 
      RowBox[{"lhs12", "/.", "rulesDisp"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<= \>\"", ",", "rhs12"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<However, unlike in Case 5D_1A, I am unable to solve \
this equation for either \[GothicCapitalC] or \!\(\*SubscriptBox[\(\
\[GothicCapitalD]\), \(4\)]\).\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<I am unable to solve this case.\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", 
     RowBox[{
     "A", ",", "B", ",", "\[CapitalBeta]", ",", "\[DoubleStruckCapitalC]", ",",
       "a", ",", "p", ",", "\[Beta]"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", \
"\"\<\!\(\*StyleBox[\"ai\",FontWeight->\"Bold\",FontColor->RGBColor[0.\
