              "\[IndentingNewLine]", "\n", 
              RowBox[{"negSign", "=", 
               RowBox[{"g\[Mu]\[Nu]", "/.", " ", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Times", "[", 
                    RowBox[{
                    RowBox[{"c_", "?", "NumericQ"}], ",", "___"}], "]"}], ":>", 
                   RowBox[{"c", "<", "0"}]}], ",", 
                  RowBox[{"_Times", ":>", "False"}]}], "}"}]}]}], ";", " ", 
              "\n", "\t", 
              RowBox[{"(*", " ", 
               RowBox[{
                RowBox[{"=", " ", 
                 RowBox[{
                 "True", " ", "if", " ", "g\[Mu]\[Nu]", " ", "starts", " ", 
                  "with", " ", "neg", " ", "sign"}]}], ",", "  ", 
                RowBox[{"random", " ", "values", " ", 
                 RowBox[{"o", ".", "w", "."}]}]}], " ", "*)"}], 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Head", "[", "g\[Mu]\[Nu]", "]"}], "===", 
