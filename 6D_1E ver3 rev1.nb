       RowBox[{"\[Mu]", "++"}], ";", 
       RowBox[{"\[Mu]", "++"}]}], ",", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{
        SubscriptBox["\"\<R\>\"", 
