      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None]}], "-", 
     RowBox[{
      SuperscriptBox["r", "2"], " ", 
      SubsuperscriptBox["\[GothicCapitalD]", "4", "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
         MultilineFunction->None], ")"}], "2"]}], "-", 
     RowBox[{"8", " ", "r", " ", 
      SuperscriptBox["\[GothicCapitalC]", "2"], " ", 
      SubscriptBox["\[GothicCapitalD]", "4"], " ", 
      SuperscriptBox[
       SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
       MultilineFunction->None]}], "-", 
     RowBox[{"4", " ", 
      SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"], " ", 
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox[
       SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
       MultilineFunction->None]}], "-", 
     RowBox[{
      SuperscriptBox["r", "2"], " ", 
      SuperscriptBox["\[GothicCapitalC]", "2"], " ", 
      SuperscriptBox[
       RowBox[{"(", 
        SuperscriptBox[
         SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
         MultilineFunction->None], ")"}], "2"]}]}], 
    RowBox[{"2", " ", "\[GothicCapitalC]", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", "2"}], "+", 
       RowBox[{"3", " ", 
        SuperscriptBox["a", "2"], " ", 
        SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]", " ", 
        "\[CapitalLambda]"}], "-", 
       RowBox[{"12", " ", 
        SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]", " ", 
        SuperscriptBox[
         OverscriptBox["a", "."], "2"]}], "-", 
       RowBox[{"3", " ", "a", " ", 
        SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]", " ", 
        OverscriptBox["a", "\[DoubleDot]"]}]}], ")"}], " ", 
     SubsuperscriptBox["\[GothicCapitalD]", "4", "2"]}]]}],
  SequenceForm[
