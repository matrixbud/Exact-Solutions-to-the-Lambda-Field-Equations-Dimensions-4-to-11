         RowBox[{
          RowBox[{"-", "4"}], 
          RowBox[{"lhs", "[", 
           RowBox[{"4", ",", "4"}], "]"}]}], "+", 
         RowBox[{"3", "\[CapitalLambda]"}]}], "]"}], "/", 
       "\[CapitalLambda]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rhs44", "=", 
