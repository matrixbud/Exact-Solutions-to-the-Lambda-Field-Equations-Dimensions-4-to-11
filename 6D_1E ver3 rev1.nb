              RowBox[{
               SubscriptBox["\"\<R\>\"", 
                RowBox[{"Row", "[", 
                 RowBox[{"{", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
               ",", "\"\<:  \>\"", ",", 
               RowBox[{
                RowBox[{"lhs", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
               ",", "\"\< = \>\"", ",", 
               RowBox[{"rhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"ls01", "=", 
      RowBox[{"Expand", "[", 
