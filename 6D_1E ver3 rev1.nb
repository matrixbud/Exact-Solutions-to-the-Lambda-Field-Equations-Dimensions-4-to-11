Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \[ScriptCapitalA](t) = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"3", " ", 
     SuperscriptBox["c", "2"], " ", 
     SuperscriptBox["r", "4"], " ", 
     SuperscriptBox[
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], "2"], " ", 
     SuperscriptBox[
      RowBox[{
       OverscriptBox["a", "."], "[", "t", "]"}], "2"]}], 
    RowBox[{
     RowBox[{"-", 
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"]}], "+", 
     RowBox[{"2", " ", 
      SuperscriptBox["r", "2"], " ", "\[CapitalLambda]", " ", 
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"], " ", 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], "+", 
     RowBox[{"3", " ", 
      SuperscriptBox["c", "2"], " ", 
      SuperscriptBox["r", "4"], " ", "\[Kappa]", " ", 
      SuperscriptBox[
       RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], "2"]}]}]]}],
  SequenceForm[
  "     \[ScriptCapitalA](t) = ", 
   3 $CellContext`c^2 $CellContext`r^4 \
