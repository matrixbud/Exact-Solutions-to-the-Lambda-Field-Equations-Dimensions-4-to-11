           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs04", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "-", 
       RowBox[{"lhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs04", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"0", ",", "0"}], "]"}], "-", 
      RowBox[{"rhs", "[", 
       RowBox[{"4", ",", "4"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<From \!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(44\)]\) we can solve for \
\[ScriptCapitalA](t):\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
