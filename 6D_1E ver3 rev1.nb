                  RowBox[{"-", "1"}]}]}], ",", "\[IndentingNewLine]", 
                RowBox[{"plus", "=", "\"\< + \>\""}]}], "]"}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"firstElem", "==", "1"}], ",", 
