Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"\\!\\(\\*SubscriptBox[\\(R\\), \\(11\\)]\\):  \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", " ", "t", " ", 
         SqrtBox["\[Zeta]"]}]], " ", 
       SuperscriptBox["\[GothicCapitalL]", "2"]}], 
      RowBox[{"2", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"2", " ", "t", " ", 
             SqrtBox["\[Zeta]"]}]], " ", "\[Alpha]"}], "+", "\[Beta]"}], 
         ")"}], "2"]}]]}], "+", 
    FractionBox[
     RowBox[{"3", " ", 
      SuperscriptBox["c", "2"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"4", " ", "t", " ", 
        SqrtBox["\[Zeta]"]}]], " ", 
      SuperscriptBox["\[Alpha]", "2"], " ", "\[Zeta]"}], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"2", " ", "t", " ", 
            SqrtBox["\[Zeta]"]}]], " ", "\[Alpha]"}], "+", "\[Beta]"}], ")"}],
        "2"], " ", "\[CapitalKappa]"}]], "-", 
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["c", "2"], " ", 
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", " ", "t", " ", 
        SqrtBox["\[Zeta]"]}]], " ", "\[Alpha]", " ", "\[Beta]", " ", 
      "\[Zeta]"}], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"2", " ", "t", " ", 
            SqrtBox["\[Zeta]"]}]], " ", "\[Alpha]"}], "+", "\[Beta]"}], ")"}],
        "2"], " ", "\[CapitalKappa]"}]], "+", 
    FractionBox[
     RowBox[{"3", " ", 
      SuperscriptBox["c", "2"], " ", 
      SuperscriptBox["\[Beta]", "2"], " ", "\[Zeta]"}], 
     RowBox[{
      SuperscriptBox[
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"2", " ", "t", " ", 
            SqrtBox["\[Zeta]"]}]], " ", "\[Alpha]"}], "+", "\[Beta]"}], ")"}],
        "2"], " ", "\[CapitalKappa]"}]]}], "\[InvisibleSpace]", "\<\" = \"\>",
    "\[InvisibleSpace]", "\[CapitalLambda]"}],
  SequenceForm[
  "\!\(\*SubscriptBox[\(R\), \(11\)]\):  ", 
   Rational[-1, 2] 
    E^(2 $CellContext`t $CellContext`\[Zeta]^
       Rational[1, 2]) $CellContext`\[GothicCapitalL]^2 (
      E^(2 $CellContext`t $CellContext`\[Zeta]^
          Rational[1, 2]) $CellContext`\[Alpha] + $CellContext`\[Beta])^(-2) + 
   3 $CellContext`c^2 
    E^(4 $CellContext`t $CellContext`\[Zeta]^
       Rational[1, 2]) $CellContext`\[Alpha]^2 (
      E^(2 $CellContext`t $CellContext`\[Zeta]^
          Rational[
           1, 2]) $CellContext`\[Alpha] + $CellContext`\[Beta])^(-2) \
$CellContext`\[Zeta]/$CellContext`\[CapitalKappa] - 2 $CellContext`c^2 
   E^(2 $CellContext`t $CellContext`\[Zeta]^
      Rational[1, 2]) $CellContext`\[Alpha] $CellContext`\[Beta] (
     E^(2 $CellContext`t $CellContext`\[Zeta]^
         Rational[
          1, 2]) $CellContext`\[Alpha] + $CellContext`\[Beta])^(-2) \
$CellContext`\[Zeta]/$CellContext`\[CapitalKappa] + 
   3 $CellContext`c^2 $CellContext`\[Beta]^2 (
      E^(2 $CellContext`t $CellContext`\[Zeta]^
          Rational[
           1, 2]) $CellContext`\[Alpha] + $CellContext`\[Beta])^(-2) \
$CellContext`\[Zeta]/$CellContext`\[CapitalKappa], 
   " = ", $CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
 CellChangeTimes->CompressedData["
