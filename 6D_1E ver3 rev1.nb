RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*SuperscriptBox[StyleBox[\"]\",FontWeight->\"Bold\"\
,FontColor->RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]], \
StyleBox[\"2\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]]\)\!\(\*StyleBox[\",\",FontWeight->\"Bold\",FontColor->RGBColor[0.\
9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\"  \
\",FontWeight->\"Bold\",FontColor->RGBColor[0.9855344472419318, \
0.00946059357595178, 0.9991760128175784]]\)\!\(\*StyleBox[\"\
\[DoubleStruckCapitalC]\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\",\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"=\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"a\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"t\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[SuperscriptBox[\")\", \
\"2\"],FontWeight->\"Bold\",FontColor->RGBColor[1, 0, 1]]\)\!\(\*StyleBox[\"\
\[GothicCapitalC]\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\"r\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"a", "[", "t", "]"}], "2"], 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", "1"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[DoubleStruckCapitalC]", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{
       SuperscriptBox[
        RowBox[{"a", "[", "t", "]"}], "2"], 
       RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Starting fresh, the field equations become\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
           RowBox[{"\[Nu]", "\[LessEqual]", "4"}], ",", 
           RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"R", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], "&&", 
                
                RowBox[{
                 RowBox[{"\[CapitalLambda]", " ", 
                  RowBox[{"g", "[", 
                   RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "===", "0"}]}], 
               ")"}]}], ",", "\[IndentingNewLine]", 
             RowBox[{"Print", "[", 
              RowBox[{
               SubscriptBox["\"\<R\>\"", 
                RowBox[{"Row", "[", 
                 RowBox[{"{", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
               ",", "\"\<:  \>\"", ",", 
               RowBox[{
                RowBox[{"lhs", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
               ",", "\"\< = \>\"", ",", 
               RowBox[{"rhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<We again get that\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<     A(t,r) = \[ScriptCapitalA](t), a function \
strictly of t.\>\"", "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"A", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(01\)]\) is eliminated, \
and the remaining equations become\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"0", ",", "0"}], "]"}]}], ",", 
         RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "k"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We solve \!\(\*SubscriptBox[\(R\), \(00\)]\) for \
\[ScriptCapitalA](t) and again get:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[ScriptCapitalA](t) =\>\"", ",", 
       RowBox[{
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesDisp"}], 
       ",", "\"\<  where k is a constant of integration.\>\""}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging this in gives us 3 equations in the 2 \
unknowns \[GothicCapitalC](r) and \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \
\(4\)]\)(r):\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "1"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs124", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"1", ",", "1"}], "]"}], "-", 
        RowBox[{"2", 
         RowBox[{"lhs", "[", 
          RowBox[{"2", ",", "2"}], "]"}]}], "-", 
        RowBox[{"2", 
         RowBox[{"lhs", "[", 
          RowBox[{"4", ",", "4"}], "]"}]}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs124", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"rhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}], "-", 
       RowBox[{"2", 
        RowBox[{"rhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can combine the three equations to eliminate the \
second derivatves:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-2\!\(\*SubscriptBox[\(R\), \
\(44\)]\):  \>\"", ",", 
       RowBox[{"lhs124", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rhs124"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[GothicCapitalD]", "4"], "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "/.", 
        RowBox[{"Last", "[", 
         RowBox[{"DSolve", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"lhs124", "+", 
             RowBox[{"3", "\[CapitalLambda]"}]}], "==", 
            RowBox[{"rhs124", "+", 
             RowBox[{"3", "\[CapitalLambda]"}]}]}], ",", 
           RowBox[{
            SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], ",", 
           "r"}], "]"}], "]"}]}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", 
        RowBox[{"Log", "[", "\[Gamma]", "]"}]}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We are unable to solve this equation for \
\[GothicCapitalC], but there is a solution for \!\(\*SubscriptBox[\(\
\[GothicCapitalD]\), \(4\)]\):\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) \
=\>\"", ",", 
       RowBox[{
        RowBox[{
         RowBox[{
          SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "/.", 
         "rulesKr"}], "/.", "rulesDisp"}], 
       ",", "\"\<  where \[Gamma] is a constant of integration.\>\""}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
      "Print", "[", "\"\<When we plug this back into the equations, the \
integral conveniently disappears but, unfortunately, the equatons are too \
unwieldy for me to solve.\>\"", "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Clear", "[", 
       RowBox[{
       "A", ",", "\[ScriptCapitalA]", ",", "B", ",", "\[CapitalBeta]", ",", 
        "\[DoubleStruckCapitalC]", ",", "\[GothicCapitalC]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[GothicCapitalD]", "4"], "[", "r_", "]"}], "=."}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
