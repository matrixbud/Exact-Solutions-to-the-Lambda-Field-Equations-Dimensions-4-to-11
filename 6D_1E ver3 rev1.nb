         RowBox[{"(", 
          RowBox[{"I", " ", "x_"}], ")"}], "->", 
         RowBox[{"\[PlusMinus]", 
          RowBox[{"(", 
           RowBox[{"I", " ", "x"}], ")"}]}]}]}], "/.", "rulesLE"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "t_", "]"}], "=", "aSave1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[GothicCapitalD]", "4"], "[", "r_", "]"}], "=", 
