Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \\!\\(\\*SubscriptBox[\\(\[GothicCapitalD]\\), \
\\(4\\)]\\)(r) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"\[PlusMinus]", 
      RowBox[{"(", 
       RowBox[{"\[ImaginaryI]", " ", 
        SqrtBox["2"], " ", "r", " ", 
        SqrtBox[
         RowBox[{
          RowBox[{"\[CapitalLambda]", " ", 
           SuperscriptBox[
            RowBox[{"a", "[", "t", "]"}], "2"]}], "-", 
          RowBox[{"2", " ", 
           SuperscriptBox[
            RowBox[{
             OverscriptBox["a", "."], "[", "t", "]"}], "2"]}], "-", 
          RowBox[{
           RowBox[{"a", "[", "t", "]"}], " ", 
           RowBox[{
            OverscriptBox["a", "\[DoubleDot]"], "[", "t", "]"}]}]}]]}], 
