Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\" \[Implies]   \[ScriptCapitalA](t) = \"\>", "\[InvisibleSpace]", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{"6", " ", 
      SuperscriptBox["c", "2"], " ", 
      SuperscriptBox[
       RowBox[{
        OverscriptBox["a", "."], "[", "t", "]"}], "2"]}], 
     RowBox[{
      SqrtBox["\[CapitalKappa]"], "-", 
      RowBox[{"6", " ", 
       SuperscriptBox["c", "2"], " ", "\[Alpha]", " ", 
       SuperscriptBox[
        RowBox[{"a", "[", "t", "]"}], "2"]}]}]]}]}],
  SequenceForm[
  " \[Implies]   \[ScriptCapitalA](t) = ", (-6) $CellContext`c^2 \
($CellContext`\[CapitalKappa]^Rational[1, 2] - 
     6 $CellContext`c^2 $CellContext`\[Alpha] \
$CellContext`a[$CellContext`t]^2)^(-1) 
