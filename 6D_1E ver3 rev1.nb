Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"1", "1"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"8", " ", 
       SuperscriptBox["c", "2"], " ", "k"}], 
      SuperscriptBox["a", "2"]]}], "-", 
    FractionBox["2", 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "\[CapitalKappa]"}]], "+", 
    "\[CapitalLambda]"}], "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]",
    "\[CapitalLambda]", "\[InvisibleSpace]", "\<\",   or   \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"8", " ", 
       SuperscriptBox["c", "2"], " ", "k"}], 
      SuperscriptBox["a", "2"]]}], "-", 
    FractionBox["2", 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "\[CapitalKappa]"}]]}], 
   "\[InvisibleSpace]", "\<\" = 0\"\>"}],
  SequenceForm[
   Subscript["R", 
    Row[{1, 1}]], 
   ":  ", (-8) $CellContext`a^(-2) $CellContext`c^2 $CellContext`k - 
   2 $CellContext`a^(-2)/$CellContext`\[CapitalKappa] + $CellContext`\
\[CapitalLambda], " = ", $CellContext`\[CapitalLambda], 
   ",   or   ", (-8) $CellContext`a^(-2) $CellContext`c^2 $CellContext`k - 
   2 $CellContext`a^(-2)/$CellContext`\[CapitalKappa], " = 0"],
  Editable->False]], "Print",
 CellChangeTimes->CompressedData["
