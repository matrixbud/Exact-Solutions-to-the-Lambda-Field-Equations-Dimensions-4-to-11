       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"ls01", "==", "0"}], ",", 
         RowBox[{
          SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], ",", "r"}],
         "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "\[ScriptK]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) \
= \>\"", ",", 
       RowBox[{
        SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], 
       ",", "\"\<  where \[ScriptK] is a constant of integration\>\""}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<             whose positive part can be rolled into \
\!\(\*SubscriptBox[\(p\), \(4\)]\),\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"\[ScriptK]", "=", "1"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) \
= \[PlusMinus]\>\"", ",", 
       RowBox[{
        SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], 
       ",", "\"\<.\>\""}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<This eliminates \!\(\*SubscriptBox[\(R\), \(01\)]\), \
and the remaining 4 equations become\>\"", "]"}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs024", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"2", 
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], "-", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}], "-", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs024", "=", 
      RowBox[{
       RowBox[{"2", 
        RowBox[{"rhs", "[", 
         RowBox[{"0", ",", "0"}], "]"}]}], "-", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}], "-", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Now we can \
\!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) solve for \
\[CapitalAlpha]:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     2\!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \
\(44\)]\):  \>\"", ",", 
       RowBox[{"lhs024", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rhs024"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalAlpha]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"\[CapitalAlpha]", "[", "r", "]"}], "/.", 
       RowBox[{"Last", "[", 
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{"lhs024", "==", "rhs024"}], ",", 
          RowBox[{"\[CapitalAlpha]", "[", "r", "]"}]}], "]"}], "]"}]}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]  \[CapitalAlpha](r) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[CapitalAlpha]", "[", "r", "]"}], "/.", "rulesLE"}]}], 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"a", "[", "t_", "]"}], "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"a", "[", "t", "]"}], "/.", 
         RowBox[{"First", "[", 
          RowBox[{"DSolve", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              SuperscriptBox[
               RowBox[{
                RowBox[{"a", "'"}], "[", "t", "]"}], "2"], "-", 
              RowBox[{
               RowBox[{"a", "[", "t", "]"}], 
               RowBox[{
                RowBox[{"a", "''"}], "[", "t", "]"}]}]}], "==", 
             "\[CapitalKappa]"}], ",", 
            RowBox[{"a", "[", "t", "]"}], ",", "t"}], "]"}], "]"}]}], "/.", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"C", "[", "1", "]"}], "->", 
           RowBox[{"Log", "[", "\[Alpha]", "]"}]}], ",", 
          RowBox[{
           RowBox[{"C", "[", "2", "]"}], "->", 
           RowBox[{"\[Beta]", "/", "\[Alpha]"}]}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalAlpha]", "[", "r_", "]"}], "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{"\[CapitalAlpha]", "[", "r", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<In order for \[CapitalAlpha](r) to be strictly a \
function of r, the expression in the parentheses must equal a constant, say \
\[CapitalKappa]:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \[CapitalAlpha](r) = \>\"", ",", 
       RowBox[{"\[CapitalAlpha]", "[", "r", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Solving 'parentheses = \[CapitalKappa]' for a(t) \
yields\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     a(t) = \>\"", ",", 
       RowBox[{"a", "[", "t", "]"}], 
       ",", "\"\<  where \[Alpha], \[Beta], and \[CapitalKappa] are constants\
\>\""}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"aSave", "=", 
      RowBox[{"a", "[", "t", "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \
\(4\)]\)(r) = \[PlusMinus]\>\"", ",", 
       RowBox[{
        SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}]}], "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"\[CapitalKappa]", "=", 
      RowBox[{"-", 
       FractionBox["k", 
        RowBox[{"6", 
         SuperscriptBox["c", "2"]}]]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Temporarily letting k = -6\!\(\*SuperscriptBox[\(c\), \
\(2\)]\)\[CapitalKappa] simplifies \[CapitalAlpha](r) to\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \[CapitalAlpha](r) = \>\"", ",", 
       RowBox[{"\[CapitalAlpha]", "[", "r", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"Clear", "[", "a", "]"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Having solved 2\!\(\*SubscriptBox[\(R\), \(00\)]\)-\!\
\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \(44\)]\)=0, the \
equations \!\(\*SubscriptBox[\(R\), \(00\)]\), \!\(\*SubscriptBox[\(R\), \(22\
\)]\), and \!\(\*SubscriptBox[\(R\), \(44\)]\) are dependent and we are free \
to designate \!\(\*SubscriptBox[\(R\), \(44\)]\) as redundant.\>\"", "]"}], ";",
      " ", "\n", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging in \[CapitalAlpha](r) (and, for now, \
expressing a(t) with just its symbol), the remaining 3 equations become:\>\"",
       "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
         SubscriptBox["\"\<R\>\"", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
          ",", 
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
         ",", "\"\< = \>\"", ",", 
         RowBox[{"rhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<From \!\(\*SubscriptBox[\(R\), \(11\)]\), we see that \
\!\(\*FractionBox[SuperscriptBox[\"\[CapitalBeta]\", FormBox[StyleBox[\"\
\[Prime]\",FontSize->13,FontWeight->\"Regular\",FontSlant->\"Plain\"],\
TraditionalForm]], RowBox[{\"2\", \"r\", \" \", SuperscriptBox[\"\
\[CapitalBeta]\", \"2\"], \" \"}]]\) = \
\!\(\*FractionBox[\(\[CapitalLambda]\), \(5\)]\).\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging this in, we simplify \
\!\(\*SubscriptBox[\(R\), \(00\)]\) and \!\(\*SubscriptBox[\(R\), \
\(22\)]\):\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
       RowBox[{
        RowBox[{"\[Mu]", "++"}], ";", 
        RowBox[{"\[Mu]", "++"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
         SubscriptBox["\"\<R\>\"", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
          ",", 
         RowBox[{
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", 
           RowBox[{
            FractionBox[
             RowBox[{
              RowBox[{"\[CapitalBeta]", "'"}], "[", "r", "]"}], 
             RowBox[{"2", "r", " ", 
              SuperscriptBox[
               RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "2"]}]], "->", 
            FractionBox["\[CapitalLambda]", "5"]}]}], "/.", "rulesDisp"}], 
         ",", "\"\< = \>\"", ",", 
         RowBox[{"rhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", 
       RowBox[{"Last", "[", 
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"0", ",", "0"}], "]"}], "-", 
            FractionBox[
             RowBox[{
              RowBox[{"\[CapitalBeta]", "'"}], "[", "r", "]"}], 
             RowBox[{"2", "r", " ", 
              SuperscriptBox[
               RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "2"]}]]}], "==", 
           RowBox[{
            RowBox[{"rhs", "[", 
             RowBox[{"0", ",", "0"}], "]"}], "-", 
            FractionBox["\[CapitalLambda]", "5"]}]}], ",", 
          RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], "]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Solving \!\(\*SubscriptBox[\(R\), \(00\)]\) gives \
us\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesLE"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"a", "[", "t_", "]"}], "=", "aSave"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<When we plug in the formula for a(t), we see that \
\[CapitalBeta] indeed is a function solely of r:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<This satisifies \!\(\*SubscriptBox[\(R\), \(11\)]\) \
as well as \!\(\*SubscriptBox[\(R\), \(00\)]\): \>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "0"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
         SubscriptBox["\"\<R\>\"", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
          ",", 
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "//", "Simplify"}], 
         ",", "\"\< = \>\"", ",", 
         RowBox[{"rhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<When \[Beta]=0, there is no value of \[Alpha] that \
satisfies \!\(\*SubscriptBox[\(R\), \(22\)]\).\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<When \[Beta]\[NotEqual]0, the only value of \[Alpha] \
that satisfies \!\(\*SubscriptBox[\(R\), \(22\)]\) is \[Alpha]=0:\>\"", "]"}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}], "/.", 
        RowBox[{"\[Alpha]", "->", "0"}]}], ",", "\"\< = \>\"", ",", 
       "\[CapitalLambda]"}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<             where \[Beta]\[NotEqual]0 or else Csch(\
\[Beta]) is undefined,\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(22\)]\):  \
\!\(\*FractionBox[\(1\), \(2\)]\)\>\"", ",", 
       RowBox[{"Collect", "[", 
        RowBox[{
         RowBox[{"Expand", "[", 
          RowBox[{
           RowBox[{"2", 
            RowBox[{"lhs", "[", 
             RowBox[{"2", ",", "2"}], "]"}]}], "/.", 
           RowBox[{"\[Alpha]", "->", "0"}]}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"\[CapitalLambda]", ",", 
           RowBox[{"Csch", "[", "\[Beta]", "]"}]}], "}"}]}], "]"}], 
       ",", "\"\< = \>\"", ",", "\[CapitalLambda]"}], "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<   Since Cosh(2\[Beta]) = \>\"", ",", 
       RowBox[{"TrigExpand", "[", 
        RowBox[{"Cosh", "[", 
         RowBox[{"2", "\[Beta]"}], "]"}], "]"}], 
       ",", "\"\<,  -1 + Cosh(2\[Beta]) = 2\!\(\*SuperscriptBox[\(Sinh\), \(2\
\)]\)(\[Beta]), and\>\""}], " ", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
       RowBox[{"Simplify", "[", 
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"2", ",", "2"}], "]"}], "/.", 
         RowBox[{"\[Alpha]", "->", "0"}]}], "]"}], ",", "\"\< = \>\"", ",", 
       RowBox[{"\[CapitalLambda]", "    ", "\[Checkmark]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<However, using L'Hospital's Rule\>\"", "]"}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<     a(t) = -\!\(\*UnderscriptBox[\(\\\ \(lim\)\), \(\
\[Alpha] \[Rule] 0\)]\) \!\(\*FractionBox[\(\*SqrtBox[\(\[CapitalKappa]\)]\\\ \
Sinh[t\\\ \[Alpha] + \[Beta]]\), \(\[Alpha]\)]\) = \!\(\*TagBox[GridBox[{{\"\
\[Piecewise]\", GridBox[{{RowBox[{SqrtBox[\"\[CapitalKappa]\"], \"t\"}], \
RowBox[{\"  \", RowBox[{RowBox[{\"if\", \" \", \"\[Beta]\"}], \"=\", \" \", \
\"0\"}]}]},{\"Indeterminate\", RowBox[{\"  \", \"otherwise\"}]}
},AllowedDimensions->{2, \
Automatic},Editable->True,GridBoxAlignment->{\"Columns\" -> {{Left}}, \
\"Rows\" -> {{Baseline}}},GridBoxItemSize->{\"Columns\" -> {{Automatic}}, \
\"Rows\" -> {{1.}}},GridBoxSpacings->{\"Columns\" -> {
Offset[0.27999999999999997`], {
Offset[0.84]}, 
Offset[0.27999999999999997`]}, \"Rows\" -> {
