            ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<This solution is new, neither a special case nor a \
generalization of the Case d solution:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[Bullet] In the Case d solution, the free \
parameter a(t) cannot be a constant\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<       or else A(t,r)=0, making \!\(\*SubscriptBox[\(g\
\), \(00\)]\)=0, not a metric.\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[Bullet] So, Case d_I\[Alpha] is a new solution \
even though \[CapitalBeta] and \[GothicCapitalC] are the same\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<         and the \
\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)'s are similar exponential \
functions.\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", 
