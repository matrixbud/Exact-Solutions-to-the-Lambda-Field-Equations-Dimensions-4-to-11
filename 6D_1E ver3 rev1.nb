   RowBox[{
    FractionBox[
     RowBox[{"4", " ", 
      SuperscriptBox["c", "2"], " ", "k"}], 
     SuperscriptBox["a", "2"]], "+", "\[CapitalLambda]", "+", 
    FractionBox[
     SuperscriptBox["\[CapitalBeta]", "\[Prime]",
      MultilineFunction->None], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "r", " ", 
