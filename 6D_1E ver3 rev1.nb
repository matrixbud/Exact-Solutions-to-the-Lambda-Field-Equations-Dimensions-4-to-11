Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \[CapitalBeta](r) = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{
     SuperscriptBox["r", "2"], " ", 
     SubsuperscriptBox["\[GothicCapitalD]", "4", "3"]}], 
    RowBox[{"\[Alpha]", "-", 
     TemplateBox[{
       RowBox[{"\[Rho]", " ", 
         SubsuperscriptBox["\[GothicCapitalD]", "4", "2"], " ", 
         RowBox[{"(", 
           RowBox[{
             RowBox[{
               RowBox[{"-", "2"}], " ", 
               SubscriptBox["\[GothicCapitalD]", "4"]}], "+", 
             RowBox[{"2", " ", "\[CapitalLambda]", " ", 
               SuperscriptBox["\[Rho]", "2"], " ", 
               SubscriptBox["\[GothicCapitalD]", "4"]}]}], ")"}]}], "\[Rho]", 
       "1", "r"},
      "InactiveIntegrate",
      DisplayFunction->(RowBox[{
         SubsuperscriptBox[
          StyleBox["\[Integral]", "Inactive"], #3, #4], 
         RowBox[{#, 
           RowBox[{
             StyleBox["\[DifferentialD]", "Inactive"], #2}]}]}]& ),
      InterpretationFunction->(RowBox[{
         RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
         RowBox[{#, ",", 
           RowBox[{"{", 
             RowBox[{#2, ",", #3, ",", #4}], "}"}]}], "]"}]& )]}]], 
   "\[InvisibleSpace]", "\<\"  where \[Alpha] is a constant of integration.\"\
\>"}],
  SequenceForm[
  "     \[CapitalBeta](r) = ", $CellContext`r^2 
   Subscript[$CellContext`\[GothicCapitalD], 4]^3/($CellContext`\[Alpha] - 
   Inactive[Integrate][$CellContext`\[Rho] 
    Subscript[$CellContext`\[GothicCapitalD], 4]^2 ((-2) 
      Subscript[$CellContext`\[GothicCapitalD], 4] + 
     2 $CellContext`\[CapitalLambda] $CellContext`\[Rho]^2 
      Subscript[$CellContext`\[GothicCapitalD], 4]), {$CellContext`\[Rho], 
     1, $CellContext`r}]), "  where \[Alpha] is a constant of integration."],
  Editable->False]], "Print",
