Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"4", "4"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      SuperscriptBox[
       OverscriptBox["a", "."], "2"]}], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "A"}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], 
     RowBox[{"a", " ", "A"}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "."], " ", 
      OverscriptBox["A", "."]}], 
     RowBox[{"2", " ", "a", " ", 
      SuperscriptBox["A", "2"]}]], "-", 
    FractionBox[
     SuperscriptBox[
      SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
      MultilineFunction->None], 
     RowBox[{"r", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["A", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox[
       SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{"4", " ", "A", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     SuperscriptBox[
      SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]\[Prime]",
      MultilineFunction->None], 
     RowBox[{"2", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   "\[CapitalLambda]"}],
  SequenceForm[
   Subscript["R", 
    Row[{4, 4}]], 
   ":  ", $CellContext`a^(-2) $CellContext`A^(-1) $CellContext`c^2 
    OverDot[$CellContext`a, 
       1]^2 + $CellContext`a^(-1) $CellContext`A^(-1) $CellContext`c^2 
    OverDot[$CellContext`a, 2] + 
   Rational[-1, 2] $CellContext`a^(-1) $CellContext`A^(-2) $CellContext`c^2 
    OverDot[$CellContext`a, 1] 
    OverDot[$CellContext`A, 1] - $CellContext`r^(-1) 
   Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) Derivative[1][
     Subscript[$CellContext`\[GothicCapitalD], 4]] + 
   Rational[-1, 4] $CellContext`A^(-1) 
    Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) 
    Derivative[1][$CellContext`A] Derivative[1][
      Subscript[$CellContext`\[GothicCapitalD], 4]] + 
   Rational[-1, 2] Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) 
    Derivative[2][
      Subscript[$CellContext`\[GothicCapitalD], 4]], 
   " = ", $CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
