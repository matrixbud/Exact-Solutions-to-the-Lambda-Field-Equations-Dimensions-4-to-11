      ",", "\"\<.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Observe that there are no r terms on the RHS, so if \
the t-terms cancel out, that will make A(r) a constant.\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<In order for  the t-terms to cancel out, the a(t) \
terms in the numerator must cancel with the one a(t) term in the denominator. \
That occurs precisely when \!\(\*OverscriptBox[\(a\), \(\[DoubleDot]\)]\)(t) \
is proportional to a(t).\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
