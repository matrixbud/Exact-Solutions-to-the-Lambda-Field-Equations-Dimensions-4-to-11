Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \\!\\(\\*SubscriptBox[\\(R\\), \
\\(00\\)]\\)+\\!\\(\\*SubscriptBox[\\(R\\), \\(22\\)]\\):  \"\>", "\[InvisibleSpace]", 
   RowBox[{
    FractionBox["1", 
     RowBox[{
      SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]"}]], "+", 
    FractionBox[
     RowBox[{"3", " ", 
      SuperscriptBox["c", "2"], " ", 
      SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]", " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], 
     RowBox[{"a", " ", "\[ScriptCapitalA]"}]], "-", 
    FractionBox[
     RowBox[{"3", " ", 
      SuperscriptBox["c", "2"], " ", 
      SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]", " ", 
      OverscriptBox["a", "."], " ", 
      OverscriptBox["\[ScriptCapitalA]", "."]}], 
     RowBox[{"2", " ", "a", " ", 
      SuperscriptBox["\[ScriptCapitalA]", "2"]}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   RowBox[{"2", " ", "\[CapitalLambda]"}]}],
  SequenceForm[
  "     \!\(\*SubscriptBox[\(R\), \(00\)]\)+\!\(\*SubscriptBox[\(R\), \(22\)]\
\):  ", $CellContext`r^(-2)/$CellContext`\[GothicCapitalC] + 
   3 $CellContext`a^(-1) $CellContext`c^2 $CellContext`r^2 $CellContext`\
\[ScriptCapitalA]^(-1) $CellContext`\[GothicCapitalC] 
    OverDot[$CellContext`a, 2] + 
   Rational[-3, 
      2] $CellContext`a^(-1) $CellContext`c^2 $CellContext`r^2 $CellContext`\
\[ScriptCapitalA]^(-2) $CellContext`\[GothicCapitalC] 
    OverDot[$CellContext`a, 1] OverDot[$CellContext`\[ScriptCapitalA], 1], 
   " = ", 2 $CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
