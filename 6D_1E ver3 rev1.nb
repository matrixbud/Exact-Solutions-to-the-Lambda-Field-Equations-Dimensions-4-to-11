     RowBox[{"a", "[", "t", "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Solving \!\(\*OverscriptBox[\(a\), \(..\)]\)(t) = \
\[Zeta] a(t), where \[Zeta] is a proportionality constant, yields\>\"", "]"}],
     ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \>\"", ",", 
      RowBox[{"a", "[", "t", "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     where \[Alpha] and \[Beta] are constants of \
integration, not both zero.\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Clear", "[", "a", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<With this value of a(t), the a(t) terms in the \
numerator cancel with the a(t) term in the denominator, leaving A(r) a \
constant:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \[CapitalAlpha](r) = \[CapitalKappa], a constant, \
\[CapitalKappa].\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalAlpha]", "[", "r_", "]"}], "=", "\[CapitalKappa]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<With this value for \[CapitalAlpha](r), equations \!\(\
\*SubscriptBox[\(R\), \(00\)]\) and \!\(\*SubscriptBox[\(R\), \(22\)]\) are \
dependent, and we are free to declare \!\(\*SubscriptBox[\(R\), \(00\)]\) \
redundant.\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<This reduces our situation to  3 equations in the one \
unknown, \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\):\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "1"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs14", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs14", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], "-", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<No mattter whether we solve for \!\(\*SubscriptBox[\(\
\[GothicCapitalD]\), \(4\)]\) from \!\(\*SubscriptBox[\(R\), \(11\)]\), \
\!\(\*SubscriptBox[\(R\), \(44\)]\), or \!\(\*SubscriptBox[\(R\), \(11\)]\)-2\
\!\(\*SubscriptBox[\(R\), \(44\)]\), when we plug in a(t) it is not obvious \
that \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) is strictly a \
function of r. So, we solve \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \
\(4\)]\) from \!\(\*SubscriptBox[\(R\), \(11\)]\)-2\!\(\*SubscriptBox[\(R\), \
\(44\)]\) and defer checking whether \
\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\) is strictly a function of \
r:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(44\)]\):  \>\"", ",", 
      RowBox[{"lhs14", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      "rhs14"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{
      RowBox[{"DSolve", "[", 
       RowBox[{
        RowBox[{"lhs14", "==", "rhs14"}], ",", 
        RowBox[{
         SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], ",", "r"}], 
       "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "k"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[GothicCapitalD]", "4"], "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "/.", 
      RowBox[{"Last", "[", "sol", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"D4Hold", "=", 
     RowBox[{
      SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) \
= \>\"", ",", 
      RowBox[{
       RowBox[{
        RowBox[{
         SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "/.", 
        "rulesDisp"}], "/.", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"I", " ", "x_"}], ")"}], "->", 
        RowBox[{"\[PlusMinus]", 
         RowBox[{"(", 
          RowBox[{"I", " ", "x"}], ")"}]}]}]}], 
      ",", "\"\<  where k is a constant of integration.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<For now, assume \!\(\*SubscriptBox[\(\[GothicCapitalD]\
\), \(4\)]\) is strictly a function of r. Then there is a constant \
\[GothicCapitalL] such that\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \
\(4\)]\)(r) = \!\(\*SuperscriptBox[\(e\), \(\[GothicCapitalL]\\\ r\)]\)\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[GothicCapitalD]", "4"], "[", "r_", "]"}], "=", 
     RowBox[{"Exp", "[", 
      RowBox[{"\[GothicCapitalL]", " ", "r"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Since \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(44\)]\)=-\[CapitalLambda], these \
equations are dependent and we are free to designate \
\!\(\*SubscriptBox[\(R\), \(44\)]\) to be redundant. Then we are left with \
two equations:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \(11\)]\):  \>\"", ",", 
      RowBox[{"lhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
      RowBox[{"lhs", "[", 
       RowBox[{"2", ",", "2"}], "]"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"2", ",", "2"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"a", "[", "t_", "]"}], "=", "aSave5"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<When we plug in a(t), we get\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \(11\)]\):  \>\"", ",", 
      RowBox[{"lhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Zeta]", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<I am unable to definitively find all the solutions to \
this for every combination of constants, but it seems likely that the only \
way to eliminate t is to set\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<     \[Zeta] = 0.\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\< \[Implies]   \!\(\*SubscriptBox[\(R\), \(11\)]\):  \>\"", ",", 
      RowBox[{"lhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[GothicCapitalL]", "=", 
     RowBox[{"\[GothicCapitalL]", "/.", 
      RowBox[{"Last", "[", 
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"1", ",", "1"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"1", ",", "1"}], "]"}]}], ",", "\[GothicCapitalL]"}], 
        "]"}], "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\< \[Implies]   \[GothicCapitalL] = \[PlusMinus]\>\"", ",", 
      "\[GothicCapitalL]"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(11\)]\) is now \
satisfied.\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Moreover, a(t) has become a constant:\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \>\"", ",", 
      RowBox[{"a", "[", "t", "]"}], ",", "\"\<.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\< \[Implies]   \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\
\)]\)(r) = \>\"", ",", 
      RowBox[{
       SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], 
      ",", "\"\<.\>\""}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We have confirmed the assumption that \
\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) is strictly a function \
of r.   \[Checkmark]\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(22\)]\), the \
last remaining equation, for \[Kappa]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
      RowBox[{"lhsP", "[", 
       RowBox[{"2", ",", "2"}], "]"}], ",", "\"\< = \>\"", ",", 
      RowBox[{"rhs", "[", 
       RowBox[{"2", ",", "2"}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Kappa]", "=", 
     RowBox[{"Quiet", "[", 
      RowBox[{"\[Kappa]", "/.", 
       RowBox[{"Last", "[", 
        RowBox[{"Solve", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"2", ",", "2"}], "]"}], "==", 
           RowBox[{"rhs", "[", 
            RowBox[{"2", ",", "2"}], "]"}]}], ",", "\[Kappa]"}], "]"}], 
        "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[Kappa] = \>\"", ",", "\[Kappa]"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<All of the equations are now satisfied.\>\"", "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Beta]", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Since a(t) now equals the constant, \[Alpha] + \
\[Beta], we can further simplify the equations by setting a(t)=\[Alpha]\>\"", 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<This solution to the \[CapitalLambda] field equations \
is\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \>\"", ",", 
      RowBox[{"a", "[", "t", "]"}], 
      ",", "\"\<  where \[Alpha] is a free constant,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     A(t,r) = \>\"", ",", 
      RowBox[{"A", "[", 
       RowBox[{"t", ",", "r"}], "]"}], 
      ",", "\"\<  where \[CapitalKappa] is a free constant\>\""}], "]"}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"aSave4", "=", 
     RowBox[{"a", "[", "t", "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "a", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     B(t,r) = \>\"", ",", 
      RowBox[{"B", "[", 
       RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[DoubleStruckCapitalC](t,r) = \>\"", ",", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{"\[DoubleStruckCapitalC]", "[", 
        RowBox[{"t", ",", "r"}], "]"}], "]"}], 
      ",", "\"\<  where \[CapitalLambda]\[NotEqual]0,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) \
= \>\"", ",", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "/.", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"I", " ", "x_"}], ")"}], "->", 
        RowBox[{"\[PlusMinus]", 
         RowBox[{"(", 
          RowBox[{"I", " ", "x"}], ")"}]}]}]}]}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"a", "[", "t_", "]"}], "=", "aSave4"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<Confirming:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"For", "[", 
        RowBox[{
         RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
         RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
