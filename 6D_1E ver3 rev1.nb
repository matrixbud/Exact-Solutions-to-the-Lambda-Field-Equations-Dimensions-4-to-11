  RowBox[{"\<\"\[CapitalBeta](r) = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{
     RowBox[{
      RowBox[{"-", "4"}], " ", 
      SuperscriptBox["\[GothicCapitalC]", "2"], " ", 
      SubsuperscriptBox["\[GothicCapitalD]", "4", "2"]}], "-", 
     RowBox[{"4", " ", "r", " ", "\[GothicCapitalC]", " ", 
