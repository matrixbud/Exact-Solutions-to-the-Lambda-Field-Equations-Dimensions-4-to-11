              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], ",", "\"\< = \>\"", ",", 
             RowBox[{"rhs", "[", 
              RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
        "]"}], ";"}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Clear", "[", 
      RowBox[{
      "A", ",", "B", ",", "\[CapitalBeta]", ",", "\[DoubleStruckCapitalC]", ",",
        "a", ",", "\[Beta]", ",", "Subscript"}], "]"}], ";", 
