1]]\)\!\(\*StyleBox[\")\",FontWeight->\"Bold\",FontColor->RGBColor[1, 0, \
1]]\)\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"B", "[", 
      RowBox[{"t", ",", "r"}], "]"}], "=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"], 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[DoubleStruckCapitalC]", "[", 
      RowBox[{"t", ",", "r"}], "]"}], "=", 
     RowBox[{
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"], 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<The field equations become\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "4"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{"If", "[", 
           RowBox[{
            RowBox[{"!", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"R", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], "&&", 
               RowBox[{
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "===", "0"}]}], 
              ")"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"Print", "[", 
             RowBox[{
              SubscriptBox["\"\<R\>\"", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
              ",", "\"\<:  \>\"", ",", 
              RowBox[{
               RowBox[{"lhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
              ",", "\"\< = \>\"", ",", 
              RowBox[{"rhs", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
         "]"}]}], "]"}]}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Since a(t) is not allowed to be a constant in Case a, \
then \!\(\*OverscriptBox[\(a\), \(.\)]\)\[NotEqual]0, and from \
\!\(\*SubscriptBox[\(R\), \(01\)]\) we get that A is a function solely of \
t:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<     A(t,r) = \[ScriptCapitalA](t)\>\"", "]"}],
     ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"A", "[", 
      RowBox[{"t_", ",", "r_"}], "]"}], "=", 
     RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<\!\(\*SubscriptBox[\(R\), \(01\)]\) is eliminated, and \
the remaining equations become\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "dimL"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}], "==", 
         RowBox[{"rhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], ",", 
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "k"}]}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(00\)]\) for \
\[ScriptCapitalA](t):\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[ScriptCapitalA](t) =\>\"", ",", 
      RowBox[{
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesDisp"}], 
      ",", "\"\<  where k is a constant of integration.\>\""}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Plugging this gives us 3 equations in the 3 unknowns \
\[CapitalBeta](r), \[GothicCapitalC](r), and \!\(\*SubscriptBox[\(\
\[GothicCapitalD]\), \(4\)]\)(r):\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"For", "[", 
     RowBox[{
      RowBox[{"\[Mu]", "=", "1"}], ",", 
      RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
      RowBox[{"\[Mu]", "++"}], ",", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"!", 
         RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{
          SubscriptBox["\"\<R\>\"", 
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
          ",", "\"\<:  \>\"", ",", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
          ",", "\"\< = \>\"", ",", 
          RowBox[{"rhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"lhs124", "=", 
     RowBox[{"Expand", "[", 
      RowBox[{
       RowBox[{"lhs", "[", 
        RowBox[{"1", ",", "1"}], "]"}], "-", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}]}], "-", 
       RowBox[{"2", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"rhs124", "=", 
     RowBox[{
      RowBox[{"rhs", "[", 
       RowBox[{"1", ",", "1"}], "]"}], "-", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}], "-", 
      RowBox[{"2", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<These equations, individually, are too difficult to be \
solved. However, \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-2\!\(\*SubscriptBox[\(R\), \
\(44\)]\) can be \!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) \
solved for \[CapitalBeta] or Dsolved for either of \[GothicCapitalC] or \
\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\). We choose to solve for \
\[CapitalBeta]:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \(11\)]\)-2\!\(\*SubscriptBox[\(R\
\), \(22\)]\)-2\!\(\*SubscriptBox[\(R\), \(44\)]\)-:  \>\"", ",", 
      RowBox[{"lhs124", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      "rhs124"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{
     RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", 
      RowBox[{"Last", "[", 
       RowBox[{"Solve", "[", 
        RowBox[{
         RowBox[{"lhs124", "==", "rhs124"}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], "]"}], "]"}]}]}], ";"}],
    "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
      RowBox[{
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", "rulesDisp"}]}], 
     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<Plugging back in, the equations are too lengthy to \
include here. However, \!\(\*SubscriptBox[\(R\), \
\(11\)]\)-\!\(\*SubscriptBox[\(R\), \(44\)]\) = 0, so the LHS can be put over \
a common denominator and then the denominator can be discarded. The  \
resulting LHS has a factor of (2\[GothicCapitalC]+\!\(\*SuperscriptBox[\"r\
\[GothicCapitalC]\", \"\[Prime]\",MultilineFunction->None]\)), so we can \
easily find at least one solution:\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<\!\(\*SubscriptBox[\(R\), \
\(11\)]\)-\!\(\*SubscriptBox[\(R\), \(44\)]\):  \>\"", ",", 
      RowBox[{"lhs14", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
      "rhs14"}], "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"\[GothicCapitalC]", "[", "r_", "]"}], "=", 
     RowBox[{
      RowBox[{"DSolveValue", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"2", " ", 
           RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], "+", 
          RowBox[{"r", " ", 
           RowBox[{
            SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
             MultilineFunction->None], "[", "r", "]"}]}]}], "==", "0"}], ",", 
        
        RowBox[{"\[GothicCapitalC]", "[", "r", "]"}], ",", "r"}], "]"}], "/.", 
      RowBox[{
       RowBox[{"C", "[", "1", "]"}], "->", "\[CapitalKappa]"}]}]}], ";"}], 
