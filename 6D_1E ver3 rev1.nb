                "*)"}], "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"\[Mu]", "==", "\[Nu]"}], ",", 
                RowBox[{"nextTerm", "=", 
                 RowBox[{"Row", "[", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"factor", " ", "g\[Mu]\[Nu]"}], ",", "\"\< d\>\"",
                     ",", 
                    SuperscriptBox[
                    RowBox[{"\[ScriptX]", "[", "\[Mu]", "]"}], "2"]}], "}"}], 
                  "]"}]}]}], "]"}], ";", " ", "\[IndentingNewLine]", "\t\t\t", 
              RowBox[{"(*", " ", 
               RowBox[{
               "Next", " ", "diagonal", " ", "line", " ", "element", " ", 
                "term"}], " ", "*)"}], "\[IndentingNewLine]", 
              "\[IndentingNewLine]", 
              RowBox[{"lineElem", "=", 
               RowBox[{"Row", "[", 
                RowBox[{"{", 
                 RowBox[{"lineElem", ",", "plus", ",", "nextTerm"}], "}"}], 
                "]"}]}]}]}], "\[IndentingNewLine]", "]"}]}]}], "]"}]}], "]"}],
       ";", "\n", "lineElem"}]}], "]"}]}], " ", 
