Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"1", "1"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["c", "2"], " ", 
      SuperscriptBox[
       OverscriptBox["a", "."], "2"]}], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "\[CapitalKappa]"}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], 
     RowBox[{"a", " ", "\[CapitalKappa]"}]], "+", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox[
        SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
        MultilineFunction->None], ")"}], "2"], 
     RowBox[{"2", " ", 
      SuperscriptBox["a", "2"], " ", 
      SubsuperscriptBox["\[GothicCapitalD]", "4", "2"]}]], "-", 
    FractionBox[
     SuperscriptBox[
      SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]\[Prime]",
      MultilineFunction->None], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   "\[CapitalLambda]"}],
  SequenceForm[
   Subscript["R", 
    Row[{1, 1}]], ":  ", 
   2 $CellContext`a^(-2) $CellContext`c^2 $CellContext`\[CapitalKappa]^(-1) 
    OverDot[$CellContext`a, 
       1]^2 + $CellContext`a^(-1) $CellContext`c^2 $CellContext`\
\[CapitalKappa]^(-1) OverDot[$CellContext`a, 2] + 
   Rational[1, 2] $CellContext`a^(-2) 
    Subscript[$CellContext`\[GothicCapitalD], 4]^(-2) Derivative[1][
       Subscript[$CellContext`\[GothicCapitalD], 4]]^2 - $CellContext`a^(-2) 
   Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) Derivative[2][
     Subscript[$CellContext`\[GothicCapitalD], 4]], 
   " = ", $CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
