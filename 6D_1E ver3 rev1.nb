       SuperscriptBox[
        OverscriptBox["a", "."], "2"]}], 
      SuperscriptBox["a", "2"]]}], "-", 
    FractionBox[
     OverscriptBox["a", "\[DoubleDot]"], "a"], "+", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox[
        SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
        MultilineFunction->None], ")"}], "2"], 
