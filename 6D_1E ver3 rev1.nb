              RowBox[{"(*", " ", 
               RowBox[{
                RowBox[{"=", " ", 
                 RowBox[{
                 "True", " ", "if", " ", "g\[Mu]\[Nu]", " ", "starts", " ", 
                  "with", " ", "neg", " ", "sign"}]}], ",", "  ", 
                RowBox[{"random", " ", "values", " ", 
                 RowBox[{"o", ".", "w", "."}]}]}], " ", "*)"}], 
              "\[IndentingNewLine]", 
              RowBox[{"If", "[", 
