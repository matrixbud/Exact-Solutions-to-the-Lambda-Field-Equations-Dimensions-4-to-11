Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\" \[Implies]   \[CapitalAlpha](r) = \"\>", "\[InvisibleSpace]", 
   
   FractionBox[
    RowBox[{
     SqrtBox["3"], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"c", " ", 
        SqrtBox["\[Kappa]"], " ", "\[CapitalLambda]", " ", 
        RowBox[{"a", "[", "t", "]"}]}], "+", 
       SqrtBox[
        RowBox[{
         SuperscriptBox["c", "2"], " ", 
         SqrtBox["\[Kappa]"], " ", "\[CapitalLambda]", " ", 
         RowBox[{"a", "[", "t", "]"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{
            SqrtBox["\[Kappa]"], " ", "\[CapitalLambda]", " ", 
            RowBox[{"a", "[", "t", "]"}]}], "-", 
           RowBox[{
            SqrtBox["3"], " ", "c", " ", 
            RowBox[{
             OverscriptBox["a", "\[DoubleDot]"], "[", "t", "]"}]}]}], 
          ")"}]}]]}], ")"}]}], 
    RowBox[{"\[CapitalLambda]", " ", 
     RowBox[{"a", "[", "t", "]"}]}]], "\[InvisibleSpace]", "\<\".\"\>"}],
  SequenceForm[
  " \[Implies]   \[CapitalAlpha](r) = ", 
   3^Rational[
     1, 2] $CellContext`\[CapitalLambda]^(-1) \
$CellContext`a[$CellContext`t]^(-1) ($CellContext`c $CellContext`\[Kappa]^
      Rational[1, 
        2] $CellContext`\[CapitalLambda] $CellContext`a[$CellContext`t] + \
($CellContext`c^2 $CellContext`\[Kappa]^
       Rational[
        1, 2] $CellContext`\[CapitalLambda] $CellContext`a[$CellContext`t] \
($CellContext`\[Kappa]^
         Rational[
          1, 2] $CellContext`\[CapitalLambda] $CellContext`a[$CellContext`t] - 
       3^Rational[1, 2] $CellContext`c 
       OverDot[$CellContext`a, 2][$CellContext`t]))^Rational[1, 2]), "."],
  Editable->False]], "Print",
 CellChangeTimes->CompressedData["
