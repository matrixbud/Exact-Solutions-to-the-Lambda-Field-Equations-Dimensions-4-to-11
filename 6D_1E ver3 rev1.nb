      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Restarting Case b from scratch using these \
constraints, the field equations become:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
           RowBox[{"\[Nu]", "\[LessEqual]", "4"}], ",", 
           RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"R", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", 
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ")"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"Print", "[", 
              RowBox[{
               SubscriptBox["\"\<R\>\"", 
                RowBox[{"Row", "[", 
                 RowBox[{"{", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
               ",", "\"\<:  \>\"", ",", 
               RowBox[{
                RowBox[{"lhs", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
               ",", "\"\< = \>\"", ",", 
               RowBox[{"rhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"a", "[", "t_", "]"}], "=", " ", 
      RowBox[{
       RowBox[{"a", "[", "t", "]"}], "/.", 
       RowBox[{"PowerExpand", "[", 
        RowBox[{"Simplify", "[", 
         RowBox[{
          RowBox[{"Last", "[", 
           RowBox[{"DSolve", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"lhs", "[", 
               RowBox[{"0", ",", "0"}], "]"}], "==", 
              RowBox[{"rhs", "[", 
               RowBox[{"0", ",", "0"}], "]"}]}], ",", 
             RowBox[{"a", "[", "t", "]"}], ",", "t"}], "]"}], "]"}], "/.", 
          " ", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"C", "[", "1", "]"}], "->", 
             RowBox[{"-", 
              FractionBox[
               RowBox[{"\[CapitalLambda]", " ", 
                SuperscriptBox["k", "2"]}], "2"]}]}], ",", 
            RowBox[{
             RowBox[{"C", "[", "2", "]"}], "->", 
             RowBox[{"\[Upsilon]", "/", "k"}]}]}], "}"}]}], "]"}], "]"}]}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[GothicCapitalD]", "4"], "[", "r_", "]"}], "=", "1"}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(00\)]\) for \
a(t), and from \!\(\*SubscriptBox[\(R\), \(01\)]\) we get that \
\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) is a constant:\>\"", 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     a(t)  = \>\"", ",", 
       RowBox[{"a", "[", "t", "]"}], 
       ",", "\"\<  where k and \[Upsilon] are constants of \
integration.\>\""}], "]"}], ";", 
     RowBox[{
     "Print", "[", "\"\<     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\
\)(r) = \[CapitalKappa], a positive constant\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<           = 1, where \[CapitalKappa] is rolled into \
radius \!\(\*SubscriptBox[\(p\), \(4\)]\).\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<With these values, \!\(\*SubscriptBox[\(R\), \
\(00\)]\) and \!\(\*SubscriptBox[\(R\), \(01\)]\) become identities, and the \
remaining equations become\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "1"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs44", "=", 
      RowBox[{
       RowBox[{"Expand", "[", 
