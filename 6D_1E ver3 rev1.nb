Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \\!\\(\\*SubscriptBox[\\(\[DoubleStruckCapitalD]\\), \\(4\
\\)]\\)(t,r) = \\!\\(\\*SubscriptBox[\\(\[DoubleStruckCapitalD]\\), \
\\(5\\)]\\)(t,r) = a(t\\!\\(\\*SuperscriptBox[\\()\\), \
\\(2\\)]\\)\\!\\(\\*SubscriptBox[\\(\[GothicCapitalD]\\), \\(4\\)]\\)(r) = \
a[t\\!\\(\\*SuperscriptBox[\\(]\\), \\(2\\)]\\)\"\>", "\[InvisibleSpace]", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"\[PlusMinus]", 
     FractionBox[
      RowBox[{"4", " ", "\[ImaginaryI]", " ", "r", " ", 
       SqrtBox[
        RowBox[{"\[Alpha]", " ", "\[Beta]", " ", "\[CapitalLambda]"}]]}], 
      SqrtBox["3"]]}]], "\[InvisibleSpace]", "\<\",\"\>"}],
  SequenceForm[
  "     \!\(\*SubscriptBox[\(\[DoubleStruckCapitalD]\), \(4\)]\)(t,r) = \
