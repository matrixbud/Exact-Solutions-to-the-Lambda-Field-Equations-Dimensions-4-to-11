Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"0", "0"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["c", "2"]}], 
     RowBox[{"k", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     SuperscriptBox[
      SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
      MultilineFunction->None], 
     RowBox[{"r", " ", "\[CapitalBeta]", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox[
       SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{"2", " ", "\[GothicCapitalC]", " ", "\[CapitalBeta]", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[CapitalBeta]", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox[
       SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{"4", " ", 
      SuperscriptBox["\[CapitalBeta]", "2"], " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox[
        SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
        MultilineFunction->None], ")"}], "2"], 
     RowBox[{"4", " ", "\[CapitalBeta]", " ", 
      SubsuperscriptBox["\[GothicCapitalD]", "4", "2"]}]], "-", 
    FractionBox[
     SuperscriptBox[
      SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]\[Prime]",
      MultilineFunction->None], 
     RowBox[{"2", " ", "\[CapitalBeta]", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   "\[CapitalLambda]"}],
  SequenceForm[
   Subscript["R", 
    Row[{0, 0}]], ":  ", 
   2 $CellContext`c^2 $CellContext`k^(-1)/
    Subscript[$CellContext`\[GothicCapitalD], 
     4] - $CellContext`r^(-1) $CellContext`\[CapitalBeta]^(-1) 
   Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) Derivative[1][
     Subscript[$CellContext`\[GothicCapitalD], 4]] + 
   Rational[-1, 
      2] $CellContext`\[GothicCapitalC]^(-1) $CellContext`\[CapitalBeta]^(-1) 
    Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) 
    Derivative[1][$CellContext`\[GothicCapitalC]] Derivative[1][
      Subscript[$CellContext`\[GothicCapitalD], 4]] + 
   Rational[1, 4] $CellContext`\[CapitalBeta]^(-2) 
    Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) 
    Derivative[1][$CellContext`\[CapitalBeta]] Derivative[1][
      Subscript[$CellContext`\[GothicCapitalD], 4]] + 
   Rational[-1, 4] $CellContext`\[CapitalBeta]^(-1) 
    Subscript[$CellContext`\[GothicCapitalD], 4]^(-2) Derivative[1][
       Subscript[$CellContext`\[GothicCapitalD], 4]]^2 + 
   Rational[-1, 2] $CellContext`\[CapitalBeta]^(-1) 
    Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) Derivative[2][
      Subscript[$CellContext`\[GothicCapitalD], 4]], 
   " = ", $CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
