Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     a(t) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      FractionBox[
       RowBox[{"t", " ", 
        SqrtBox["\[CapitalLambda]"]}], 
       SqrtBox["3"]]], " ", "\[Alpha]"}], "+", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"t", " ", 
         SqrtBox["\[CapitalLambda]"]}], 
        SqrtBox["3"]]}]], " ", "\[Beta]"}]}], 
   "\[InvisibleSpace]", "\<\"  where \[Alpha] and \[Beta] are free constants,\
