               ",", "\"\< = \>\"", ",", 
               RowBox[{"rhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"ls01", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          RowBox[{"a", "[", "t", "]"}], 
          RowBox[{
           RowBox[{"a", "'"}], "[", "t", "]"}]]}], 
        RowBox[{"lhs", "[", 
         RowBox[{"0", ",", "1"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can simplify \!\(\*SubscriptBox[\(R\), \(01\)]\) \
by factoring out \!\(\*FractionBox[OverscriptBox[\(a\), \(.\)], \(a\)]\), and \
then solving for A:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(01\)]\):  \>\"", ",", 
       RowBox[{"ls01", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       RowBox[{"rhs", "[", 
        RowBox[{"0", ",", "1"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"A", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"ls01", "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"0", ",", "1"}], "]"}]}], ",", 
         RowBox[{"A", "[", 
          RowBox[{"t", ",", "r"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "r"}], "}"}]}], "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "\[ScriptCapitalA]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     A(t,r) = \>\"", ",", 
       RowBox[{"A", "[", 
        RowBox[{"t", ",", "r"}], "]"}], 
       ",", "\"\<  where \[ScriptCapitalA](t) is a new unknown.\>\""}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<This eliminates \!\(\*SubscriptBox[\(R\), \(01\)]\), \
and the remaining 4 equations become\>\"", "]"}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"ls024", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"2", 
         RowBox[{"lhs", "[", 
          RowBox[{"0", ",", "0"}], "]"}]}], "-", 
        RowBox[{"lhs", "[", 
         RowBox[{"2", ",", "2"}], "]"}], "-", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rs024", "=", 
      RowBox[{
       RowBox[{"2", 
        RowBox[{"rhs", "[", 
         RowBox[{"0", ",", "0"}], "]"}]}], "-", 
       RowBox[{"rhs", "[", 
        RowBox[{"2", ",", "2"}], "]"}], "-", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Now we can solve 2\!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \
\(44\)]\) for \[ScriptCapitalA]:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     2\!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(22\)]\)-\!\(\*SubscriptBox[\(R\), \
\(44\)]\):  \>\"", ",", 
       RowBox[{"ls024", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rs024"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"ls024", "==", "rs024"}], ",", 
         RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "t"}], "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[ScriptCapitalA](t) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesLE"}], 
       ",", "\"\<  where \[Alpha] is a constant of integration;\>\""}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<This formula for \[ScriptCapitalA](t) makes \
\!\(\*SubscriptBox[\(R\), \(00\)]\), \!\(\*SubscriptBox[\(R\), \(22\)]\), and \
\!\(\*SubscriptBox[\(R\), \(44\)]\) dependent, so we are free to declare \!\(\
\*SubscriptBox[\(R\), \(44\)]\) redundant.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Also, in order for \[ScriptCapitalA](t) to be \
strictly a function of t, \!\(\*SqrtBox[SubscriptBox[\(\[ScriptCapitalD]\), \
\(4\)]]\) must be proportional to r:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     
     RowBox[{
     "Print", "[", "\"\<      \!\(\*SubscriptBox[\(\[ScriptCapitalD]\), \
\(4\)]\) = \!\(\*SuperscriptBox[\(\[CapitalKappa]r\), \(2\)]\)  where \
\[CapitalKappa] is the proportionality constant.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{
       SubscriptBox["\[GothicCapitalD]", "4"], "[", "r_", "]"}], "=", 
      RowBox[{"\[CapitalKappa]", " ", 
       SuperscriptBox["r", "2"]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{"PowerExpand", "[", 
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\< \[Implies]   \[ScriptCapitalA](t) = \>\"", ",", 
       RowBox[{
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], "/.", "rulesLE"}]}], 
      "]"}], ";", "  ", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging \[ScriptCapitalA](t) and \!\(\*SubscriptBox[\
\(\[GothicCapitalD]\), \(4\)]\)(r) back in, the equations become:\>\"", "]"}],
      ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
         SubscriptBox["\"\<R\>\"", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
          ",", 
         RowBox[{
          RowBox[{"lhsP", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
         ",", "\"\< = \>\"", ",", 
         RowBox[{"rhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"1", ",", "1"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"1", ",", "1"}], "]"}]}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", "r"}], "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", 
        FractionBox["\[Beta]", "5"]}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Solving \!\(\*SubscriptBox[\(R\), \(11\)]\) for \
\[CapitalBeta] yields\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{"\[CapitalBeta]", "[", "r", "]"}], 
       ",", "\"\<  where \[Beta] is a constant of integration.\>\""}], "]"}], 
     ";", "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs22", "=", 
      RowBox[{"PowerExpand", "[", 
       RowBox[{"Expand", "[", 
        RowBox[{
         SuperscriptBox["r", "2"], 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"2", ",", "2"}], "]"}], "-", "\[CapitalLambda]"}], 
          ")"}]}], "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"rhs22", "=", "0"}], ";", "\[IndentingNewLine]", 
     RowBox[{"ls22", "=", 
      RowBox[{"Collect", "[", 
       RowBox[{
        RowBox[{"Together", "[", "lhs22", "]"}], ",", 
        RowBox[{"a", "[", "t", "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Plugging this into the remaining 2 equations \
yields:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(00\)]\):  \>\"", ",", 
       RowBox[{"lhsP", "[", 
        RowBox[{"0", ",", "0"}], "]"}], ",", "\"\< = \>\"", ",", 
       RowBox[{"rhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(22\)]\):  \>\"", ",", 
       "lhs22", ",", "\"\< = \>\"", ",", "0"}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"sol", "=", 
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{"lhs22", "==", "0"}], ",", 
        RowBox[{"a", "[", "t", "]"}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"a", "[", "t_", "]"}], "=", 
      RowBox[{
       RowBox[{"a", "[", "t", "]"}], "/.", 
       RowBox[{"Last", "[", "sol", "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can \
\!\(\*StyleBox[\"algebraically\",FontSlant->\"Italic\"]\) solve \
\!\(\*SubscriptBox[\(R\), \(22\)]\) for a(t):\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     a(t) = \>\"", ",", 
       RowBox[{"a", "[", "t", "]"}], ",", "\"\<, a constant.\>\""}], "]"}], ";",
      "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<However, this makes\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[ScriptCapitalA](t) = \>\"", ",", 
       RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], ",", "\"\<,\>\""}], 
      "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<an unallowable value.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<This case has no possible solution.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We next re-do this case, but with various additional \
assumptions.  By making the assumptions upfront, before the ODEs have been \
solved, it may be possible to obtain solutions.\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<     \
\!\(\*StyleBox[\"I\[Alpha]\",FontWeight->\"Bold\"]\)\!\(\*StyleBox[\":\",\
FontWeight->\"Bold\"]\)\!\(\*StyleBox[\" \
