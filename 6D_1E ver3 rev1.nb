                RowBox[{"nextTerm", "=", 
                 RowBox[{"Row", "[", 
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"factor", " ", "g\[Mu]\[Nu]"}], ",", "\"\< d\>\"",
                     ",", 
                    SuperscriptBox[
                    RowBox[{"\[ScriptX]", "[", "\[Mu]", "]"}], "2"]}], "}"}], 
                  "]"}]}]}], "]"}], ";", " ", "\[IndentingNewLine]", "\t\t\t", 
