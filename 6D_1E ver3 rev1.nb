Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"1", "1"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{"2", " ", 
       SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
        MultilineFunction->None]}], 
      RowBox[{"r", " ", "\[GothicCapitalC]", " ", "\[CapitalBeta]"}]]}], "+", 
    
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
        MultilineFunction->None], ")"}], "2"], 
     RowBox[{"2", " ", 
      SuperscriptBox["\[GothicCapitalC]", "2"], " ", "\[CapitalBeta]"}]], "+", 
    FractionBox[
     SuperscriptBox["\[CapitalBeta]", "\[Prime]",
      MultilineFunction->None], 
     RowBox[{"r", " ", 
      SuperscriptBox["\[CapitalBeta]", "2"]}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox["\[CapitalBeta]", "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{"2", " ", "\[GothicCapitalC]", " ", 
      SuperscriptBox["\[CapitalBeta]", "2"]}]], "-", 
    FractionBox[
     SuperscriptBox["\[GothicCapitalC]", "\[Prime]\[Prime]",
      MultilineFunction->None], 
     RowBox[{"\[GothicCapitalC]", " ", "\[CapitalBeta]"}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   "\[CapitalLambda]"}],
  SequenceForm[
   Subscript["R", 
    Row[{1, 1}]], 
   ":  ", (-2) $CellContext`r^(-1) $CellContext`\[GothicCapitalC]^(-1) \
$CellContext`\[CapitalBeta]^(-1) 
    Derivative[1][$CellContext`\[GothicCapitalC]] + 
   Rational[1, 
      2] $CellContext`\[GothicCapitalC]^(-2) $CellContext`\[CapitalBeta]^(-1) 
    Derivative[
      1][$CellContext`\[GothicCapitalC]]^2 + $CellContext`r^(-1) \
$CellContext`\[CapitalBeta]^(-2) Derivative[1][$CellContext`\[CapitalBeta]] + 
   Rational[1, 
      2] $CellContext`\[GothicCapitalC]^(-1) $CellContext`\[CapitalBeta]^(-2) 
    Derivative[1][$CellContext`\[GothicCapitalC]] 
    Derivative[
     1][$CellContext`\[CapitalBeta]] - $CellContext`\[GothicCapitalC]^(-1) \
$CellContext`\[CapitalBeta]^(-1) 
   Derivative[2][$CellContext`\[GothicCapitalC]], 
