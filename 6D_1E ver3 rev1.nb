     "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
    "Print", "[", "\"\<We have discovered that the only solution to \
\!\(\*SubscriptBox[\(R\), \(22\)]\) requires \[Beta]\[NotEqual]0, and that \
causes a(t) to be undefined.\>\"", "]"}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
