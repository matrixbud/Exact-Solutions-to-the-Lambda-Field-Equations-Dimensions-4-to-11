                    RowBox[{"c_", "?", "NumericQ"}], ",", "___"}], "]"}], ":>", 
                   RowBox[{"c", "<", "0"}]}], ",", 
                  RowBox[{"_Times", ":>", "False"}]}], "}"}]}]}], ";", " ", 
