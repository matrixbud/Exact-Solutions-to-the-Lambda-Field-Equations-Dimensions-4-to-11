Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"4", "4"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", " ", 
        SqrtBox["2"], " ", "t", " ", 
        SqrtBox["\[CapitalLambda]"]}]], " ", 
      SuperscriptBox["\[Alpha]", "2"], " ", "\[CapitalLambda]"}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           SqrtBox["2"], " ", "t", " ", 
           SqrtBox["\[CapitalLambda]"]}]], " ", "\[Alpha]"}], "+", 
        "\[Beta]"}], ")"}], "2"]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[Beta]", "2"], " ", "\[CapitalLambda]"}], 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           SqrtBox["2"], " ", "t", " ", 
           SqrtBox["\[CapitalLambda]"]}]], " ", "\[Alpha]"}], "+", 
        "\[Beta]"}], ")"}], "2"]]}], "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]",
    "\[CapitalLambda]"}],
  SequenceForm[
   Subscript["R", 
    Row[{4, 4}]], ":  ", 
   E^(2 2^Rational[1, 2] $CellContext`t $CellContext`\[CapitalLambda]^
       Rational[1, 2]) $CellContext`\[Alpha]^2 (
      E^(2^Rational[1, 2] $CellContext`t $CellContext`\[CapitalLambda]^
          Rational[
           1, 2]) $CellContext`\[Alpha] + $CellContext`\[Beta])^(-2) \
$CellContext`\[CapitalLambda] + $CellContext`\[Beta]^2 (
      E^(2^Rational[1, 2] $CellContext`t $CellContext`\[CapitalLambda]^
          Rational[
           1, 2]) $CellContext`\[Alpha] + $CellContext`\[Beta])^(-2) \
$CellContext`\[CapitalLambda], " = ", $CellContext`\[CapitalLambda]],
  Editable->False]], "Print",
