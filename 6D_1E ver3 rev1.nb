Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \\!\\(\\*SubscriptBox[\\(R\\), \
\\(00\\)]\\)-\\!\\(\\*SubscriptBox[\\(R\\), \\(44\\)]\\):  \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      RowBox[{
       SuperscriptBox["c", "2"], " ", 
       SuperscriptBox[
        OverscriptBox["a", "."], "2"]}], 
      RowBox[{
       SuperscriptBox["a", "2"], " ", "\[ScriptCapitalA]", " ", 
       SubscriptBox["\[GothicCapitalD]", "4"]}]]}], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], 
     RowBox[{"a", " ", "\[ScriptCapitalA]", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "."], " ", 
      OverscriptBox["\[ScriptCapitalA]", "."]}], 
     RowBox[{"2", " ", "a", " ", 
      SuperscriptBox["\[ScriptCapitalA]", "2"], " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", "0"}],
  SequenceForm[
  "     \!\(\*SubscriptBox[\(R\), \(00\)]\)-\!\(\*SubscriptBox[\(R\), \(44\)]\
\):  ", -$CellContext`a^(-2) $CellContext`c^2 \
$CellContext`\[ScriptCapitalA]^(-1) OverDot[$CellContext`a, 1]^2/
    Subscript[$CellContext`\[GothicCapitalD], 
     4] + $CellContext`a^(-1) $CellContext`c^2 \
$CellContext`\[ScriptCapitalA]^(-1) OverDot[$CellContext`a, 2]/
    Subscript[$CellContext`\[GothicCapitalD], 4] + 
   Rational[-1, 
      2] $CellContext`a^(-1) $CellContext`c^2 \
$CellContext`\[ScriptCapitalA]^(-2) OverDot[$CellContext`a, 1] 
    OverDot[$CellContext`\[ScriptCapitalA], 1]/
    Subscript[$CellContext`\[GothicCapitalD], 4], " = ", 0],
  Editable->False]], "Print",
