Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \[ScriptCapitalA](t) = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"6", " ", 
     SuperscriptBox["c", "2"], " ", "r", " ", 
     SuperscriptBox[
      RowBox[{
       OverscriptBox["a", "."], "[", "t", "]"}], "2"]}], 
    RowBox[{
     RowBox[{"6", " ", 
      SuperscriptBox["c", "2"], " ", "r", " ", "\[Alpha]", " ", 
      SuperscriptBox[
       RowBox[{"a", "[", "t", "]"}], "2"]}], "-", 
     SqrtBox[
      RowBox[{
       SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}]]}]], 
   "\[InvisibleSpace]", "\<\"  where \[Alpha] is a constant of integration;\"\
\>"}],
  SequenceForm[
  "     \[ScriptCapitalA](t) = ", 6 $CellContext`c^2 $CellContext`r 
   OverDot[$CellContext`a, 1][$CellContext`t]^2/(
   6 $CellContext`c^2 $CellContext`r $CellContext`\[Alpha] \
$CellContext`a[$CellContext`t]^2 - 
   Subscript[$CellContext`\[GothicCapitalD], 4][$CellContext`r]^
   Rational[1, 2]), "  where \[Alpha] is a constant of integration;"],
  Editable->False]], "Print",
 CellChangeTimes->CompressedData["
