                "print"}]}], " ", "*)"}], "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"g\[Mu]\[Nu]", "=", 
               RowBox[{"g", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"x\[Mu]", "=", 
