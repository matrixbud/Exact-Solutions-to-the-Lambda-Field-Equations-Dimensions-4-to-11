Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"\\!\\(\\*SubscriptBox[\\(R\\), \
\\(11\\)]\\)-2\\!\\(\\*SubscriptBox[\\(R\\), \
\\(22\\)]\\)-2\\!\\(\\*SubscriptBox[\\(R\\), \\(44\\)]\\):  \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", 
     FractionBox["2", 
      RowBox[{
       SuperscriptBox["a", "2"], " ", 
       SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]"}]]}], "+", 
    FractionBox["2", 
     RowBox[{
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["r", "2"], " ", "\[CapitalBeta]"}]], "-", 
    FractionBox[
     RowBox[{"12", " ", 
      SuperscriptBox[
       OverscriptBox["a", "."], "2"]}], 
     SuperscriptBox["a", "2"]], "-", 
    FractionBox[
     RowBox[{"3", " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], "a"], "+", 
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "r", " ", "\[GothicCapitalC]", " ", 
      "\[CapitalBeta]"}]], "+", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
        MultilineFunction->None], ")"}], "2"], 
     RowBox[{"2", " ", 
      SuperscriptBox["a", "2"], " ", 
      SuperscriptBox["\[GothicCapitalC]", "2"], " ", "\[CapitalBeta]"}]], "+", 
    FractionBox[
     RowBox[{"4", " ", 
      SuperscriptBox[
       SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "r", " ", "\[CapitalBeta]", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "+", 
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox[
       SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{
      SuperscriptBox["a", "2"], " ", "\[GothicCapitalC]", " ", 
      "\[CapitalBeta]", " ", 
      SubscriptBox["\[GothicCapitalD]", "4"]}]], "+", 
    FractionBox[
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox[
        SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
        MultilineFunction->None], ")"}], "2"], 
     RowBox[{"2", " ", 
      SuperscriptBox["a", "2"], " ", "\[CapitalBeta]", " ", 
      SubsuperscriptBox["\[GothicCapitalD]", "4", "2"]}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{"-", "3"}], " ", "\[CapitalLambda]"}]}],
  SequenceForm[
  "\!\(\*SubscriptBox[\(R\), \(11\)]\)-2\!\(\*SubscriptBox[\(R\), \(22\)]\)-2\
\!\(\*SubscriptBox[\(R\), \(44\)]\):  ", (-2) $CellContext`a^(-2) \
$CellContext`r^(-2)/$CellContext`\[GothicCapitalC] + 
   2 $CellContext`a^(-2) $CellContext`r^(-2)/$CellContext`\[CapitalBeta] - 
   12 $CellContext`a^(-2) OverDot[$CellContext`a, 1]^2 - 
   3 $CellContext`a^(-1) OverDot[$CellContext`a, 2] + 
   2 $CellContext`a^(-2) $CellContext`r^(-1) \
$CellContext`\[GothicCapitalC]^(-1) $CellContext`\[CapitalBeta]^(-1) 
    Derivative[1][$CellContext`\[GothicCapitalC]] + 
   Rational[1, 
      2] $CellContext`a^(-2) $CellContext`\[GothicCapitalC]^(-2) \
$CellContext`\[CapitalBeta]^(-1) 
    Derivative[1][$CellContext`\[GothicCapitalC]]^2 + 
   4 $CellContext`a^(-2) $CellContext`r^(-1) $CellContext`\[CapitalBeta]^(-1) 
    Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) Derivative[1][
      Subscript[$CellContext`\[GothicCapitalD], 4]] + 
   2 $CellContext`a^(-2) $CellContext`\[GothicCapitalC]^(-1) $CellContext`\
\[CapitalBeta]^(-1) Subscript[$CellContext`\[GothicCapitalD], 4]^(-1) 
    Derivative[1][$CellContext`\[GothicCapitalC]] Derivative[1][
      Subscript[$CellContext`\[GothicCapitalD], 4]] + 
   Rational[1, 2] $CellContext`a^(-2) $CellContext`\[CapitalBeta]^(-1) 
    Subscript[$CellContext`\[GothicCapitalD], 4]^(-2) Derivative[1][
       Subscript[$CellContext`\[GothicCapitalD], 4]]^2, 
