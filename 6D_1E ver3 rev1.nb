     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<With this formula, \!\(\*SubscriptBox[\(R\), \
\(00\)]\) and \!\(\*SubscriptBox[\(R\), \(44\)]\) are dependent equations, so \
we can choose to designate \!\(\*SubscriptBox[\(R\), \(44\)]\) as \
redundant.\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<The remaining equations become:\>\"", "]"}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "0"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "2"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
         SubscriptBox["\"\<R\>\"", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
          ",", 
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
         ",", "\"\< = \>\"", ",", 
         RowBox[{"rhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[CapitalBeta]", "[", "r_", "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"lhs", "[", 
           RowBox[{"2", ",", "2"}], "]"}], "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"2", ",", "2"}], "]"}]}], ",", 
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], ",", "r"}], "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "\[Alpha]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We can solve \!\(\*SubscriptBox[\(R\), \(22\)]\) for \
\[CapitalBeta]:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \[CapitalBeta](r) = \>\"", ",", 
       RowBox[{
        RowBox[{
         RowBox[{"\[CapitalBeta]", "[", "r", "]"}], "/.", " ", "rulesKr"}], "/.",
         "rulesDisp"}], 
       ",", "\"\<  where \[Alpha] is a constant of integration.\>\""}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<With \!\(\*SubscriptBox[\(R\), \(22\)]\) being an \
identity, the equations now become\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "1"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Print", "[", 
        RowBox[{
         SubscriptBox["\"\<R\>\"", 
          RowBox[{"Row", "[", 
           RowBox[{"{", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], ",", "\"\<:  \>\"",
          ",", 
         RowBox[{
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesKr"}], "/.", 
          "rulesDisp"}], ",", "\"\< = \>\"", ",", 
         RowBox[{"rhs", "[", 
          RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"sol", "=", 
        RowBox[{"DSolve", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"lhs", "[", 
            RowBox[{"0", ",", "0"}], "]"}], "==", 
           RowBox[{"rhs", "[", 
            RowBox[{"0", ",", "0"}], "]"}]}], ",", 
          RowBox[{
           SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], ",", 
          "r"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         SubscriptBox["\[GothicCapitalD]", "4"], "[", "r_", "]"}], "=", 
        RowBox[{
         RowBox[{
          SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "/.", 
         RowBox[{"First", "[", "sol", "]"}]}]}], ";"}], "*)"}], 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<There is no algebraic combination of the equations \
that eliminate more than a single integral. However, if we simplify by \
setting \[Alpha]=0, we can solve \!\(\*SubscriptBox[\(R\), \(00\)]\) for the \
\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\), the remaining unknown. \
But, the expression is a fraction that includes an integral in an exponent in \
the numerator and a double integral in the denominator. Checking whether or \
not the remaining equation, \!\(\*SubscriptBox[\(R\), \(11\)]\), is an \
identity when using this expression is too computationally intensive for my \
home computer.\>\"", "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<This case, too, is too difficult for me to solve, so \
we proceed to \
