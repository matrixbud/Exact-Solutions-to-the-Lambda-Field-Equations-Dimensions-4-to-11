  RowBox[{"\<\" \[Implies]   \[CapitalBeta](r) = \"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{"\[CapitalKappa]", " ", 
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox[
        SubscriptBox["\[GothicCapitalD]", "4"], "\[Prime]",
        MultilineFunction->None], ")"}], "2"]}], 
    RowBox[{"4", " ", 
     RowBox[{"(", 
