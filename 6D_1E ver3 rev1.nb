Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"1", "1"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox[
     RowBox[{"4", " ", 
      SuperscriptBox["c", "2"], " ", "k"}], 
     SuperscriptBox["a", "2"]], "+", "\[CapitalLambda]", "-", 
    FractionBox[
     RowBox[{"2", " ", 
      SuperscriptBox["\[GothicCapitalC]", "\[Prime]",
