Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     \\!\\(\\*SubscriptBox[\\(\[GothicCapitalD]\\), \
\\(4\\)]\\)(r) =\"\>", "\[InvisibleSpace]", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     TemplateBox[{
       FractionBox[
        RowBox[{
          RowBox[{
            RowBox[{"-", "4"}], " ", "\[GothicCapitalC]"}], "-", 
          RowBox[{"2", " ", "\[Rho]", " ", 
            SuperscriptBox[
            "\[GothicCapitalC]", "\[Prime]", MultilineFunction -> None]}], 
          "+", 
          SqrtBox[
           RowBox[{
             RowBox[{"4", " ", "\[GothicCapitalC]"}], "+", 
             RowBox[{"12", " ", 
               SuperscriptBox["\[GothicCapitalC]", "2"]}], "+", 
             RowBox[{"24", " ", 
               SuperscriptBox["c", "2"], " ", "k", " ", 
               SuperscriptBox["\[GothicCapitalC]", "2"], " ", 
               SuperscriptBox["\[Rho]", "2"]}], "+", 
             RowBox[{"12", " ", "\[GothicCapitalC]", " ", "\[Rho]", " ", 
               SuperscriptBox[
               "\[GothicCapitalC]", "\[Prime]", MultilineFunction -> None]}], 
             "+", 
             RowBox[{"3", " ", 
               SuperscriptBox["\[Rho]", "2"], " ", 
               SuperscriptBox[
                RowBox[{"(", 
                  SuperscriptBox[
                  "\[GothicCapitalC]", "\[Prime]", MultilineFunction -> None],
                   ")"}], "2"]}]}]]}], 
        RowBox[{"\[GothicCapitalC]", " ", "\[Rho]"}]], "\[Rho]", "1", "r"},
      "InactiveIntegrate",
      DisplayFunction->(RowBox[{
         SubsuperscriptBox[
          StyleBox["\[Integral]", "Inactive"], #3, #4], 
         RowBox[{#, 
           RowBox[{
             StyleBox["\[DifferentialD]", "Inactive"], #2}]}]}]& ),
      InterpretationFunction->(RowBox[{
         RowBox[{"Inactive", "[", "Integrate", "]"}], "[", 
         RowBox[{#, ",", 
           RowBox[{"{", 
             RowBox[{#2, ",", #3, ",", #4}], "}"}]}], "]"}]& )]], " ", 
    "\[Gamma]"}], 
   "\[InvisibleSpace]", "\<\"  where \[Gamma] is a constant of integration.\"\
\>"}],
  SequenceForm[
  "     \!\(\*SubscriptBox[\(\[GothicCapitalD]\), \(4\)]\)(r) =", 
   E^Inactive[
     Integrate][$CellContext`\[GothicCapitalC]^(-1) $CellContext`\[Rho]^(-1) \
((-4) $CellContext`\[GothicCapitalC] - 2 $CellContext`\[Rho] 
       Derivative[
        1][$CellContext`\[GothicCapitalC]] + (
         4 $CellContext`\[GothicCapitalC] + 
         12 $CellContext`\[GothicCapitalC]^2 + 
         24 $CellContext`c^2 $CellContext`k $CellContext`\[GothicCapitalC]^2 \
$CellContext`\[Rho]^2 + 
         12 $CellContext`\[GothicCapitalC] $CellContext`\[Rho] 
          Derivative[1][$CellContext`\[GothicCapitalC]] + 
         3 $CellContext`\[Rho]^2 
          Derivative[1][$CellContext`\[GothicCapitalC]]^2)^
        Rational[1, 2]), {$CellContext`\[Rho], 
       1, $CellContext`r}] $CellContext`\[Gamma], 
   "  where \[Gamma] is a constant of integration."],
  Editable->False]], "Print",
