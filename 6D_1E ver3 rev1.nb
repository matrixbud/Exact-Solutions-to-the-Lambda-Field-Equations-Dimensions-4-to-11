Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     a(t) = \"\>", "\[InvisibleSpace]", 
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      SqrtBox["\[CapitalKappa]"], " ", 
      RowBox[{"Sinh", "[", 
       RowBox[{
        RowBox[{"t", " ", "\[Alpha]"}], "+", "\[Beta]"}], "]"}]}], 
     "\[Alpha]"]}], 
   "\[InvisibleSpace]", "\<\"  where \[Alpha], \[Beta], and \[CapitalKappa] \
are constants\"\>"}],
  SequenceForm[
  "     a(t) = ", -$CellContext`\[Alpha]^(-1) $CellContext`\[CapitalKappa]^
    Rational[1, 2] 
   Sinh[$CellContext`t $CellContext`\[Alpha] + $CellContext`\[Beta]], 
   "  where \[Alpha], \[Beta], and \[CapitalKappa] are constants"],
  Editable->False]], "Print",
