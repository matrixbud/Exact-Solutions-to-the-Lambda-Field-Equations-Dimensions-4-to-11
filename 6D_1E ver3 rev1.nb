   FractionBox[
    RowBox[{
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"2", " ", 
        SqrtBox["2"], " ", "t", " ", 
        SqrtBox["\[CapitalLambda]"]}]], " ", 
      SuperscriptBox["\[Alpha]", "2"]}], "+", 
