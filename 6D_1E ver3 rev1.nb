Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SubscriptBox["\<\"R\"\>", 
    TemplateBox[{"0", "0"},
     "RowDefault"]], "\[InvisibleSpace]", "\<\":  \"\>", "\[InvisibleSpace]", 
   
   RowBox[{
    FractionBox[
     RowBox[{"4", " ", 
      SuperscriptBox["c", "2"], " ", 
      OverscriptBox["a", "\[DoubleDot]"]}], 
     RowBox[{"a", " ", "\[CapitalAlpha]"}]], "-", 
    FractionBox[
     RowBox[{"3", " ", 
      SuperscriptBox[
       RowBox[{"(", 
        SuperscriptBox["\[CapitalAlpha]", "\[Prime]",
         MultilineFunction->None], ")"}], "2"]}], 
     RowBox[{"4", " ", 
      SuperscriptBox["\[CapitalAlpha]", "2"], " ", "\[CapitalBeta]"}]], "+", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[CapitalAlpha]", "\[Prime]",
       MultilineFunction->None], " ", 
      SuperscriptBox["\[CapitalBeta]", "\[Prime]",
       MultilineFunction->None]}], 
     RowBox[{"4", " ", "\[CapitalAlpha]", " ", 
      SuperscriptBox["\[CapitalBeta]", "2"]}]], "-", 
    FractionBox[
     SuperscriptBox["\[CapitalAlpha]", "\[Prime]\[Prime]",
      MultilineFunction->None], 
     RowBox[{"2", " ", "\[CapitalAlpha]", " ", "\[CapitalBeta]"}]]}], 
   "\[InvisibleSpace]", "\<\" = \"\>", "\[InvisibleSpace]", 
   "\[CapitalLambda]"}],
  SequenceForm[
   Subscript["R", 
    Row[{0, 0}]], ":  ", 
   4 $CellContext`a^(-1) $CellContext`c^2 $CellContext`\[CapitalAlpha]^(-1) 
    OverDot[$CellContext`a, 2] + 
   Rational[-3, 
      4] $CellContext`\[CapitalAlpha]^(-2) $CellContext`\[CapitalBeta]^(-1) 
    Derivative[1][$CellContext`\[CapitalAlpha]]^2 + 
   Rational[1, 
