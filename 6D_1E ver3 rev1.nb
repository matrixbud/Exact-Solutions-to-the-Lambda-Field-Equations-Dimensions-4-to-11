            RowBox[{
             RowBox[{"gzero", "==", "1"}], ",", "  ", 
             RowBox[{"(*", " ", 
              RowBox[{
               RowBox[{"If", " ", "there", " ", "is", " ", "a", " ", "non"}], 
               "-", 
               RowBox[{"zero", " ", 
