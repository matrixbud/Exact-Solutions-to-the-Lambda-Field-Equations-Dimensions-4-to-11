              "\[IndentingNewLine]", "\n", 
              RowBox[{"negSign", "=", 
               RowBox[{"g\[Mu]\[Nu]", "/.", " ", 
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{
                   RowBox[{"Times", "[", 
