Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     a(t) = \"\>", "\[InvisibleSpace]", 
   RowBox[{
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      FractionBox[
       RowBox[{"t", " ", 
        SqrtBox["\[CapitalLambda]"]}], 
       SqrtBox["2"]]], " ", "\[Alpha]"}], "+", 
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", 
       FractionBox[
        RowBox[{"t", " ", 
         SqrtBox["\[CapitalLambda]"]}], 
        SqrtBox["2"]]}]], " ", "\[Beta]"}]}], 
   "\[InvisibleSpace]", "\<\"  where \[Alpha] and \[Beta] are constants of \
integration.\"\>"}],
  SequenceForm[
  "     a(t) = ", 
   E^(2^Rational[-1, 2] $CellContext`t $CellContext`\[CapitalLambda]^
       Rational[1, 2]) $CellContext`\[Alpha] + 
