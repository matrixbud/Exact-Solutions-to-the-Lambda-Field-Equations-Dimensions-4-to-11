         SuperscriptBox["r", "2"], " ", "\[GothicCapitalC]", " ", "\[Alpha]", 
         " ", "\[Beta]", " ", "\[CapitalLambda]"}]}], ")"}], " ", 
      SubsuperscriptBox["\[GothicCapitalD]", "4", "2"]}]]}], 
   "\[InvisibleSpace]", "\<\",\"\>"}],
  SequenceForm[
  " \[Implies]   B(r) = ", 
   Rational[-5, 4] $CellContext`\[GothicCapitalC]^(-1) (-5 + 
     24 $CellContext`r^2 $CellContext`\[GothicCapitalC] $CellContext`\[Alpha] \
