\(\*StyleBox[\"2\",FontWeight->\"Bold\",FontColor->RGBColor[0.\
1450980392156863, 0.5450980392156862, 0.]]\)\>\"", "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     a(t) = \>\"", ",", 
      RowBox[{"a", "[", "t", "]"}], 
      ",", "\"\<  where \[Alpha] and \[Beta] are free constants,\>\""}], 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"Clear", "[", "a", "]"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     A(t,r) = \>\"", ",", 
      RowBox[{"A", "[", 
       RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     B(t,r) = \>\"", ",", 
      RowBox[{"B", "[", 
       RowBox[{"t", ",", "r"}], "]"}], ",", "\"\<,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \[DoubleStruckCapitalC](t,r) = \>\"", ",", 
      RowBox[{"\[DoubleStruckCapitalC]", "[", 
       RowBox[{"t", ",", "r"}], "]"}], 
      ",", "\"\<  where \[CapitalLambda]\[NotEqual]0,\>\""}], "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[GothicCapitalD]", "4"], "[", "r_", "]"}], "=", 
     SuperscriptBox["\[ExponentialE]", 
      FractionBox[
       RowBox[{"4", " ", "\[ImaginaryI]", " ", "r", " ", 
        SqrtBox[
         RowBox[{"\[Alpha]", " ", "\[Beta]", " ", "\[CapitalLambda]"}]]}], 
       SqrtBox["3"]]]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \!\(\*SubscriptBox[\(\[DoubleStruckCapitalD]\), \(4\)]\
\)(t,r) = \!\(\*SubscriptBox[\(\[DoubleStruckCapitalD]\), \(5\)]\)(t,r) = a(t\
\!\(\*SuperscriptBox[\()\), \(2\)]\)\!\(\*SubscriptBox[\(\[GothicCapitalD]\), \
\(4\)]\)(r) = a[t\!\(\*SuperscriptBox[\(]\), \(2\)]\)\>\"", ",", 
      RowBox[{
       RowBox[{
        SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], "/.", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"4", "I", " ", "x_"}], ")"}], "->", 
        RowBox[{"\[PlusMinus]", 
         RowBox[{"(", 
          RowBox[{"4", "I", " ", "x"}], ")"}]}]}]}], ",", "\"\<,\>\""}], 
     "]"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Print", "[", "\"\<and line element\>\"", "]"}], ";"}], "\n", 
   RowBox[{
    RowBox[{"Print", "[", 
     RowBox[{"\"\<     \>\"", ",", 
      RowBox[{
       RowBox[{"lineElem", "/.", "rulesLE"}], "/.", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"4", "I", " ", "x_"}], ")"}], "->", 
