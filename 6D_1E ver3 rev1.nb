Offset[0.4]}, 
Offset[0.2]}},Selectable->True]}
},GridBoxAlignment->{\"Columns\" -> {{Left}}, \"Rows\" -> \
{{Baseline}}},GridBoxItemSize->{\"Columns\" -> {{Automatic}}, \"Rows\" -> \
{{1.}}},GridBoxSpacings->{\"Columns\" -> {
Offset[0.27999999999999997`], {
Offset[0.35]}, 
Offset[0.27999999999999997`]}, \"Rows\" -> {
Offset[0.2], {
Offset[0.4]}, 
Offset[0.2]}}],\"Piecewise\",DeleteWithContents->True,Editable->False,\
SelectWithContents->True,Selectable->False,StripWrapperBoxes->True]\)\>\"", 
      "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<We have discovered that the only solution to \
\!\(\*SubscriptBox[\(R\), \(22\)]\) requires \[Beta]\[NotEqual]0, and that \
causes a(t) to be undefined.\>\"", "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Case c_I\[Beta] has no possible solution.\>\"", "]"}],
      ";", "\n", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Clear", "[", 
      RowBox[{
      "A", ",", "\[CapitalAlpha]", ",", "B", ",", "\[CapitalBeta]", ",", 
       "\[DoubleStruckCapitalC]", ",", "a", ",", "Subscript", ",", 
       "\[CapitalKappa]"}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", \
"\"\<\!\(\*StyleBox[\"c_II\",FontWeight->\"Bold\",FontColor->RGBColor[0.\
9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\":\",FontWeight->\"Bold\",FontColor->\
RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\" \
\",FontWeight->\"Bold\",FontColor->RGBColor[0.9855344472419318, \
0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\"B\",FontWeight->\"Bold\",FontColor->\
RGBColor[0.9855344472419318, 0.00946059357595178, \
0.9991760128175784]]\)\!\(\*StyleBox[\"(\",FontWeight->\"Bold\",FontColor->\
RGBColor[0.9855344472419318, 0.00946059357595178, \
