 RowBox[{
  RowBox[{"lineElem", ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "firstElem", ",", "g\[Mu]\[Nu]", ",", "gzero", ",", "x\[Mu]", ",", 
       "x\[Nu]", ",", "dx\[Mu]", ",", "dx\[Nu]", ",", "negSign", ",", 
       "factor", ",", "\n", "plus", ",", "nextTerm", ",", "lineElem"}], "}"}],
      ",", "\n", "\n", 
     RowBox[{
      RowBox[{
      "lineElem", "=", "\"\<\!\(\*SuperscriptBox[\(ds\), \(2\)]\) = \>\""}], ";",
       "\n", 
      RowBox[{"firstElem", "=", "1"}], ";", "\[IndentingNewLine]", 
      RowBox[{"For", "[", 
       RowBox[{
        RowBox[{"\[Mu]", "=", "dimL"}], ",", 
        RowBox[{"\[Mu]", "\[LessEqual]", "dimH"}], ",", 
        RowBox[{"\[Mu]", "++"}], ",", "\[IndentingNewLine]", 
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"\[Nu]", "=", "dimL"}], ",", 
          RowBox[{"\[Nu]", "\[LessEqual]", "dimH"}], ",", 
          RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"g", "[", 
               RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", "0"}], ",", 
             RowBox[{"gzero", "=", "0"}], ",", 
             RowBox[{"gzero", "=", "1"}], ",", 
             RowBox[{"gzero", "=", "1"}]}], "]"}], ";", " ", 
           RowBox[{"(*", " ", 
            RowBox[{
             RowBox[{"1", " ", "means", " ", 
              SubscriptBox["g", "\[Mu]\[Nu]"]}], "\[NotEqual]", "0"}], " ", 
            "*)"}], "\n", "\n", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"gzero", "==", "1"}], ",", "  ", 
             RowBox[{"(*", " ", 
              RowBox[{
               RowBox[{"If", " ", "there", " ", "is", " ", "a", " ", "non"}], 
               "-", 
               RowBox[{"zero", " ", 
                SubscriptBox["g", "\[Mu]\[Nu]"], " ", "term", " ", "to", " ", 
                "print"}]}], " ", "*)"}], "\[IndentingNewLine]", 
             RowBox[{
              RowBox[{"g\[Mu]\[Nu]", "=", 
               RowBox[{"g", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], ";", 
              "\[IndentingNewLine]", 
              RowBox[{"x\[Mu]", "=", 
