       "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"B", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{"\[CapitalBeta]", "[", "r", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[DoubleStruckCapitalC]", "[", 
       RowBox[{"t", ",", "r"}], "]"}], "=", 
      RowBox[{"\[GothicCapitalC]", "[", "r", "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<The field equations become:\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", 
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"\[Nu]", "=", "\[Mu]"}], ",", 
           RowBox[{"\[Nu]", "\[LessEqual]", "4"}], ",", 
           RowBox[{"\[Nu]", "++"}], ",", "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{"!", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"R", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "===", 
                RowBox[{"\[CapitalLambda]", " ", 
                 RowBox[{"g", "[", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}]}], ")"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"Print", "[", 
              RowBox[{
               SubscriptBox["\"\<R\>\"", 
                RowBox[{"Row", "[", 
                 RowBox[{"{", 
                  RowBox[{"\[Mu]", ",", "\[Nu]"}], "}"}], "]"}]], 
               ",", "\"\<:  \>\"", ",", 
               RowBox[{
                RowBox[{"lhs", "[", 
                 RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "/.", "rulesDisp"}], 
               ",", "\"\< = \>\"", ",", 
               RowBox[{"rhs", "[", 
                RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}]}], "]"}]}], "]"}]}], 
          "]"}]}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"ls01", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"-", 
         FractionBox[
          RowBox[{"a", "[", "t", "]"}], 
          RowBox[{
           RowBox[{"a", "'"}], "[", "t", "]"}]]}], 
        RowBox[{"lhs", "[", 
         RowBox[{"0", ",", "1"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<Because a(t)\[NotEqual]constant, \!\(\*OverscriptBox[\
\(a\), \(.\)]\)\[NotEqual]0. This allows us to simplify \
\!\(\*SubscriptBox[\(R\), \(01\)]\) by factoring out \
\!\(\*FractionBox[OverscriptBox[\(a\), \(.\)], \(a\)]\), and then we can \
solve for A:\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \(01\)]\):  \>\"", ",", 
       RowBox[{"ls01", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       RowBox[{"rhs", "[", 
        RowBox[{"0", ",", "1"}], "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"A", "[", 
       RowBox[{"t_", ",", "r_"}], "]"}], "=", 
      RowBox[{
       RowBox[{"DSolveValue", "[", 
        RowBox[{
         RowBox[{"ls01", "==", 
          RowBox[{"rhs", "[", 
           RowBox[{"0", ",", "1"}], "]"}]}], ",", 
         RowBox[{"A", "[", 
          RowBox[{"t", ",", "r"}], "]"}], ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "r"}], "}"}]}], "]"}], "/.", 
       RowBox[{
        RowBox[{"C", "[", "1", "]"}], "->", "\[ScriptCapitalA]"}]}]}], ";", 
     "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     A(t,r) = \>\"", ",", 
       RowBox[{"A", "[", 
        RowBox[{"t", ",", "r"}], "]"}], 
       ",", "\"\<  where \[ScriptCapitalA](t) is a new unknown.\>\""}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "\"\<The equations now become\>\"", "]"}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"For", "[", 
      RowBox[{
       RowBox[{"\[Mu]", "=", "dimL"}], ",", 
       RowBox[{"\[Mu]", "\[LessEqual]", "4"}], ",", 
       RowBox[{"\[Mu]", "++"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"!", 
          RowBox[{"\[Mu]", "==", "3"}]}], ",", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{
           SubscriptBox["\"\<R\>\"", 
            RowBox[{"Row", "[", 
             RowBox[{"{", 
              RowBox[{"\[Mu]", ",", "\[Mu]"}], "}"}], "]"}]], 
           ",", "\"\<:  \>\"", ",", 
           RowBox[{
            RowBox[{"lhs", "[", 
             RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}], "/.", "rulesDisp"}], 
           ",", "\"\< = \>\"", ",", 
           RowBox[{"rhs", "[", 
            RowBox[{"\[Mu]", ",", "\[Mu]"}], "]"}]}], "]"}]}], "]"}]}], "]"}],
      ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs04", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"lhs", "[", 
         RowBox[{"0", ",", "0"}], "]"}], "-", 
        RowBox[{"lhs", "[", 
         RowBox[{"4", ",", "4"}], "]"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"rhs04", "=", 
      RowBox[{
       RowBox[{"rhs", "[", 
        RowBox[{"0", ",", "0"}], "]"}], "-", 
       RowBox[{"rhs", "[", 
        RowBox[{"4", ",", "4"}], "]"}]}]}], ";", "\[IndentingNewLine]", 
     "\[IndentingNewLine]", 
     RowBox[{"Print", "[", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{
     "Print", "[", "\"\<From \!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(44\)]\) we can solve for \
\[ScriptCapitalA](t):\>\"", "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<     \!\(\*SubscriptBox[\(R\), \
\(00\)]\)-\!\(\*SubscriptBox[\(R\), \(44\)]\):  \>\"", ",", 
       RowBox[{"lhs04", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rhs04"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{"lhs04b", "=", 
      RowBox[{"Expand", "[", 
       RowBox[{
        RowBox[{"\[ScriptCapitalA]", "[", "t", "]"}], 
        RowBox[{"a", "[", "t", "]"}], 
        RowBox[{
         SubscriptBox["\[GothicCapitalD]", "4"], "[", "r", "]"}], 
        RowBox[{"lhs04", "/", 
         SuperscriptBox["c", "2"]}]}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Print", "[", 
      RowBox[{"\"\<or             \>\"", ",", 
       RowBox[{"lhs04b", "/.", "rulesDisp"}], ",", "\"\< = \>\"", ",", 
       "rhs04"}], "]"}], ";", "\[IndentingNewLine]", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"\[ScriptCapitalA]", "[", "t_", "]"}], "=", 
