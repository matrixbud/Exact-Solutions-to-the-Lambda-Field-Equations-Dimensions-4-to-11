Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"     a(t) = \[PlusMinus]\"\>", "\[InvisibleSpace]", 
   FractionBox[
    RowBox[{
     SqrtBox["3"], " ", "c", " ", 
     SqrtBox["\[Kappa]"], " ", 
     RowBox[{"Sinh", "[", 
      FractionBox[
       RowBox[{
        SqrtBox["\[CapitalLambda]"], " ", 
        RowBox[{"(", 
         RowBox[{"t", "-", "\[Upsilon]"}], ")"}]}], 
       SqrtBox["3"]], "]"}]}], "\[CapitalLambda]"], 
   "\[InvisibleSpace]", "\<\"  where \[Kappa] and \[Upsilon] are free \
constants,\"\>"}],
  SequenceForm[
  "     a(t) = \[PlusMinus]", 
   3^Rational[1, 2] $CellContext`c $CellContext`\[Kappa]^
    Rational[1, 2] $CellContext`\[CapitalLambda]^(-1) 
   Sinh[3^Rational[-1, 2] $CellContext`\[CapitalLambda]^
      Rational[1, 2] ($CellContext`t - $CellContext`\[Upsilon])], 
   "  where \[Kappa] and \[Upsilon] are free constants,"],
  Editable->False]], "Print",
